}

# ================================================================
# Enum constants — StringEncoding
# ================================================================

var STRING_ENCODING_ASCII   = 0;
var STRING_ENCODING_UTF16LE = 1;

# ================================================================
# Struct layouts
# ================================================================

# ScanTarget: kind (i64), data (Str — path or name, 0 for Memory)
struct ScanTarget {
    kind;
    data;
}

fn scan_target_new(kind, data) {
    var t = ScanTarget {};
    t.kind = kind;
    t.data = data;
    return t;
}

fn scan_target_file(path) {
    return scan_target_new(SCAN_TARGET_FILE, path);
}

fn scan_target_agent(name) {
    return scan_target_new(SCAN_TARGET_AGENT, name);
}

fn scan_target_package(name) {
    return scan_target_new(SCAN_TARGET_PACKAGE, name);
}

fn scan_target_memory() {
    return scan_target_new(SCAN_TARGET_MEMORY, 0);
}

# ThreatFinding
struct ThreatFinding {
    target;       # ScanTarget ptr
    category;     # FindingCategory enum
    severity;     # FindingSeverity enum
    rule_name;    # Str
    description;  # Str
    metadata;     # HashMap (map_new)
    timestamp;    # i64 (unix epoch seconds)
}

fn finding_new(target, category, severity, rule_name, description) {
    var f = ThreatFinding {};
    f.target = target;
    f.category = category;
    f.severity = severity;
    f.rule_name = rule_name;
    f.description = description;
    f.metadata = map_new();
    f.timestamp = 0;
    return f;
}

fn finding_is_critical(f) {
    return f.severity == SEVERITY_CRITICAL;
}

# ScanResult
struct ScanResult {
    target;           # ScanTarget ptr
    findings;         # Vec of ThreatFinding ptrs
    scan_duration_ms; # i64 milliseconds
    scanner_version;  # Str
}

fn scan_result_new(target) {
    var r = ScanResult {};
    r.target = target;
    r.findings = vec_new();
    r.scan_duration_ms = 0;
    r.scanner_version = VERSION;
    return r;
}

fn scan_result_highest_severity(r) {
    var len = vec_len(r.findings);
    if (len == 0) { return None(); }
    var best = SEVERITY_INFO;
    for (var i = 0; i < len; i = i + 1) {
        var f = vec_get(r.findings, i);
        if (f.severity > best) {
            best = f.severity;
        }
    }
    return Some(best);
}

fn scan_result_has_threats(r) {
    return vec_len(r.findings) > 0;
}

fn scan_result_finding_count(r) {
    return vec_len(r.findings);
}

# ScanConfig
struct ScanConfig {
    max_file_size;      # i64 bytes
    timeout_secs;       # i64
    enable_yara;        # i64 (0/1)
    enable_entropy;     # i64 (0/1)
    enable_magic_bytes; # i64 (0/1)
    enable_ml;          # i64 (0/1)
    rule_paths;         # Vec of Str
}

fn scan_config_default() {
    var c = ScanConfig {};
    c.max_file_size = 50 * 1024 * 1024;
    c.timeout_secs = 60;
    c.enable_yara = 1;
    c.enable_entropy = 1;
    c.enable_magic_bytes = 1;
    c.enable_ml = 1;
    c.rule_paths = vec_new();
    return c;
}

# BinaryAnalysis
struct BinaryAnalysis {
    file_type; # FileType enum
    entropy;   # f64 (as i64 bit pattern)
    size;      # i64
    sha256;    # Str
}

# SectionEntropy
struct SectionEntropy {
    name;       # Str
    entropy;    # f64 bit pattern
    raw_size;   # i64
    executable; # i64 (0/1)
    writable;   # i64 (0/1)
}

# OverlayInfo
struct OverlayInfo {
    offset;  # i64
    size;    # i64
    entropy; # f64 bit pattern
}

# PackingSignals
struct PackingSignals {
    packer_sections;      # Vec of Str
    wx_sections;          # Vec of Str
    hollow_sections;      # Vec of Str
    import_count;         # i64
    entry_in_high_entropy; # i64 (0/1)
    has_encrypted_overlay; # i64 (0/1)
}

fn packing_signals_new() {
    var s = PackingSignals {};
    s.packer_sections = vec_new();
    s.wx_sections = vec_new();
    s.hollow_sections = vec_new();
    s.import_count = 0;
    s.entry_in_high_entropy = 0;
    s.has_encrypted_overlay = 0;
    return s;
}

fn packing_signal_count(s) {
    var count = 0;
    if (vec_len(s.packer_sections) > 0) { count = count + 1; }
    if (vec_len(s.wx_sections) > 0)     { count = count + 1; }
    if (vec_len(s.hollow_sections) > 0) { count = count + 1; }
    if (s.import_count < 5) {
        if (s.import_count > 0) { count = count + 1; }
    }
    if (s.entry_in_high_entropy) { count = count + 1; }
    if (s.has_encrypted_overlay) { count = count + 1; }
    return count;
}

# ObfuscationSignals
struct ObfuscationSignals {
    high_entropy_lines; # i64
    total_lines;        # i64
    patterns;           # Vec of Str
    score;              # i64
}

fn obfuscation_signals_new() {
    var s = ObfuscationSignals {};
    s.high_entropy_lines = 0;
    s.total_lines = 0;
    s.patterns = vec_new();
    s.score = 0;
    return s;
}

# ExtractedString
struct ExtractedString {
    value;    # Str
    offset;   # i64
    encoding; # StringEncoding enum
}

# SsdeepHash
struct SsdeepHash {
    digest;     # Str
    block_size; # i64 (u32)
}

# TlshHash
struct TlshHash {
    digest; # Str
}

# Baseline suppression
struct Baseline {
    fingerprints; # Vec of Str (64-char hex fingerprints)
    rule_names;   # Vec of Str
}

fn baseline_new() {
    var b = Baseline {};
    b.fingerprints = vec_new();
    b.rule_names = vec_new();
    return b;
}

fn baseline_is_empty(b) {
    return vec_len(b.fingerprints) == 0 & vec_len(b.rule_names) == 0;
}

fn baseline_len(b) {
    return vec_len(b.fingerprints) + vec_len(b.rule_names);
}

# ================================================================
# Error handling
# ================================================================

var ERR_NONE               = 0;
var ERR_IO                 = 1;
var ERR_FILE_TOO_LARGE     = 2;
var ERR_TIMEOUT            = 3;
var ERR_RULE_PARSE         = 4;
var ERR_INVALID_SEVERITY   = 5;
var ERR_INVALID_CATEGORY   = 6;
var ERR_SCAN               = 7;
var ERR_CONFIG             = 8;
var ERR_SERIALIZATION      = 9;
var ERR_AGENT              = 10;

# PhylaxError: tagged result using Err(code)
# Usage: return Err(ERR_FILE_TOO_LARGE);
#        var result = do_thing(); if (!is_ok(result)) { ... }

fn err_name(code) {
    if (code == ERR_IO)               { return str_from("IO error"); }
    if (code == ERR_FILE_TOO_LARGE)   { return str_from("file too large"); }
    if (code == ERR_TIMEOUT)          { return str_from("scan timed out"); }
    if (code == ERR_RULE_PARSE)       { return str_from("rule parse error"); }
    if (code == ERR_INVALID_SEVERITY) { return str_from("invalid severity"); }
    if (code == ERR_INVALID_CATEGORY) { return str_from("invalid category"); }
    if (code == ERR_SCAN)             { return str_from("scan error"); }
    if (code == ERR_CONFIG)           { return str_from("configuration error"); }
    if (code == ERR_SERIALIZATION)    { return str_from("serialization error"); }
    if (code == ERR_AGENT)            { return str_from("agent error"); }
    return str_from("unknown error");
}

# ================================================================
# Utility — hex encoding
# ================================================================

fn hex_nibble(n) {
    if (n < 10) { return 48 + n; }  # '0' = 48
    return 97 + n - 10;             # 'a' = 97
}

# Encode a buffer of bytes at addr, len bytes, into a hex Str
fn hex_encode(addr, len) {
    var out = alloc(len * 2 + 1);
    for (var i = 0; i < len; i = i + 1) {
        var b = load8(addr + i);
        store8(out + i * 2,     hex_nibble((b >> 4) & 15));
        store8(out + i * 2 + 1, hex_nibble(b & 15));
    }
    store8(out + len * 2, 0);  # null terminator
    return str_from_raw(out, len * 2);
}

fn hex_digit_value(ch) {
    if (ch >= 48) { if (ch <= 57) { return ch - 48; } }       # '0'-'9'
    if (ch >= 97) { if (ch <= 102) { return ch - 97 + 10; } } # 'a'-'f'
    if (ch >= 65) { if (ch <= 70) { return ch - 65 + 10; } }  # 'A'-'F'
    return -1;
}

# Decode hex string to raw buffer. Returns addr of bytes, sets *out_len.
fn hex_decode(s, out_len_ptr) {
    var slen = str_len(s);
    if (slen & 1) { return 0; }  # odd length
    var blen = slen >> 1;
    var buf = alloc(blen);
    var sdata = str_data(s);
    for (var i = 0; i < blen; i = i + 1) {
        var hi = hex_digit_value(load8(sdata + i * 2));
        var lo = hex_digit_value(load8(sdata + i * 2 + 1));
        if (hi < 0) { return 0; }
        if (lo < 0) { return 0; }
        store8(buf + i, (hi << 4) | lo);
    }
    store64(out_len_ptr, blen);
    return buf;
}

# ================================================================
# Utility — memmem (substring search in raw bytes)
# ================================================================

# Search for needle in haystack. Returns offset or -1.
fn memmem(haystack, hlen, needle, nlen) {
    if (nlen == 0) { return 0; }
    if (nlen > hlen) { return -1; }
    var limit = hlen - nlen;
    for (var i = 0; i <= limit; i = i + 1) {
        var match = 1;
        for (var j = 0; j < nlen; j = j + 1) {
            if (load8(haystack + i + j) != load8(needle + j)) {
                match = 0;
                j = nlen;  # break inner
            }
        }
        if (match) { return i; }
    }
    return -1;
}

# Search for a Str needle inside a Str haystack
fn str_contains(haystack, needle) {
    var hdata = str_data(haystack);
    var hlen  = str_len(haystack);
    var ndata = str_data(needle);
    var nlen  = str_len(needle);
    return memmem(hdata, hlen, ndata, nlen) >= 0;
}

# Count occurrences of needle Str in haystack Str
fn str_count(haystack, needle) {
    var hdata = str_data(haystack);
    var hlen  = str_len(haystack);
    var ndata = str_data(needle);
    var nlen  = str_len(needle);
    if (nlen == 0) { return 0; }
    var count = 0;
    var pos = 0;
    while (pos + nlen <= hlen) {
        var found = memmem(hdata + pos, hlen - pos, ndata, nlen);
        if (found < 0) { return count; }
        count = count + 1;
        pos = pos + found + nlen;
    }
    return count;
}

# ================================================================
# Utility — f64 constants
# ================================================================

# f64 zero: 0x0000000000000000
var F64_ZERO = 0;

# f64 one: 0x3FF0000000000000
var F64_ONE = 4607182418800017408;

# f64 8.0: 0x4020000000000000
var F64_EIGHT = 4620693217682128896;

# f64 256.0: 0x4070000000000000
var F64_256 = 4643985272004935680;

# f64 100.0: 0x4059000000000000
var F64_100 = 4636737291354636288;

# f64 7.5: 0x401E000000000000
var F64_7_5 = 4619567317775286272;

# f64 7.0: 0x401C000000000000
var F64_7_0 = 4619004359213244416;

# f64 512.0: 0x4080000000000000
var F64_512 = 4652007308841189376;

# f64 4096.0: 0x40B0000000000000
var F64_4096 = 4672051446919364608;

# f64 15.0: 0x402E000000000000
var F64_15 = 4622382067542392832;

# f64 255.0: 0x406FE00000000000
var F64_255 = 4643808755916185600;

# f64 5.5: 0x4016000000000000
var F64_5_5 = 4617878467915022336;

# f64 0.9 (90%): 0x3FECCCCCCCCCCCCD
var F64_0_9 = 4604480259023595469;

# f64 40.0: 0x4044000000000000
var F64_40 = 4630826316843712512;

# f64 60.0: 0x404E000000000000
var F64_60 = 4636175958903619584;

# ================================================================
# Entropy analysis
# ================================================================

# Shannon entropy of a byte buffer (bits per byte, 0.0 .. 8.0)
# data = address of bytes, len = byte count
# Returns f64 as i64 bit pattern
fn shannon_entropy(data, len) {
    if (len == 0) { return F64_ZERO; }

    # Build frequency table: 256 entries
    var freq = alloc(256 * 8);
    for (var i = 0; i < 256; i = i + 1) {
        store64(freq + i * 8, 0);
    }
    for (var i = 0; i < len; i = i + 1) {
        var b = load8(data + i);
        var idx = b * 8;
        var old = load64(freq + idx);
        store64(freq + idx, old + 1);
    }

    var flen = f64_from_int(len);
    var entropy = F64_ZERO;

    for (var i = 0; i < 256; i = i + 1) {
        var count = load64(freq + i * 8);
        if (count > 0) {
            var fc = f64_from_int(count);
            var p = f64_div(fc, flen);
            var log2p = f64_log2(p);
            var term = f64_mul(p, log2p);
            entropy = f64_sub(entropy, term);
        }
    }

    return entropy;
}

# Compute entropy for successive blocks of block_size bytes
# Returns a Vec of f64 bit patterns
fn entropy_profile(data, len, block_size) {
    var result = vec_new();
    if (len == 0) { return result; }
    if (block_size == 0) { return result; }

    var offset = 0;
    while (offset < len) {
        var remaining = len - offset;
        var chunk_size = block_size;
        if (remaining < chunk_size) { chunk_size = remaining; }
        var ent = shannon_entropy(data + offset, chunk_size);
        vec_push(result, ent);
        offset = offset + chunk_size;
    }
    return result;
}

# Heuristic: entropy > 7.5 bits/byte is suspicious
fn is_suspicious_entropy(entropy_f64) {
    return f64_gt(entropy_f64, F64_7_5);
}

# Chi-squared statistic for byte distribution
fn chi_squared(data, len) {
    if (len == 0) { return F64_ZERO; }

    var freq = alloc(256 * 8);
    for (var i = 0; i < 256; i = i + 1) {
        store64(freq + i * 8, 0);
    }
    for (var i = 0; i < len; i = i + 1) {
        var b = load8(data + i);
        var idx = b * 8;
        var old = load64(freq + idx);
        store64(freq + idx, old + 1);
    }

    var expected = f64_div(f64_from_int(len), F64_256);
    var chi2 = F64_ZERO;

    for (var i = 0; i < 256; i = i + 1) {
        var count = load64(freq + i * 8);
        var fc = f64_from_int(count);
        var diff = f64_sub(fc, expected);
        var diff2 = f64_mul(diff, diff);
        chi2 = f64_add(chi2, f64_div(diff2, expected));
    }

    return chi2;
}

# Classify data randomness based on chi-squared value
fn classify_randomness(chi2) {
    if (!f64_gt(chi2, F64_512)) { return RANDOMNESS_ENCRYPTED; }
    if (!f64_gt(chi2, F64_4096)) { return RANDOMNESS_COMPRESSED; }
    return RANDOMNESS_NORMAL;
}

# ================================================================
# File type detection (magic bytes)
# ================================================================

fn detect_file_type(data, len) {
    if (len < 2) { return FILETYPE_UNKNOWN; }

    # ELF: 7f 45 4c 46
    if (len >= 4) {
        if (load8(data) == 127) {
            if (load8(data + 1) == 69) {
                if (load8(data + 2) == 76) {
                    if (load8(data + 3) == 70) {
                        return FILETYPE_ELF;
                    }
                }
            }
        }
    }

    # PE (DOS MZ header): 4d 5a
    if (load8(data) == 77) {
        if (load8(data + 1) == 90) {
            return FILETYPE_PE;
        }
    }

    # Mach-O: feedface/feedfacf and reversed
    if (len >= 4) {
        var b0 = load8(data);
        var b1 = load8(data + 1);
        var b2 = load8(data + 2);
        var b3 = load8(data + 3);

        # feedface (32-bit BE)
        if (b0 == 254) { if (b1 == 237) { if (b2 == 250) {
            if (b3 == 206) { return FILETYPE_MACHO; }
            if (b3 == 207) { return FILETYPE_MACHO; }
        } } }
        # cefaedfe / cffaedfe (reversed)
        if (b0 == 206) { if (b1 == 250) { if (b2 == 237) { if (b3 == 254) { return FILETYPE_MACHO; } } } }
        if (b0 == 207) { if (b1 == 250) { if (b2 == 237) { if (b3 == 254) { return FILETYPE_MACHO; } } } }
    }

    # PDF: 25 50 44 46
    if (len >= 4) {
        if (load8(data) == 37) { if (load8(data + 1) == 80) { if (load8(data + 2) == 68) { if (load8(data + 3) == 70) {
            return FILETYPE_PDF;
        } } } }
    }

    # PNG: 89 50 4e 47
    if (len >= 4) {
        if (load8(data) == 137) { if (load8(data + 1) == 80) { if (load8(data + 2) == 78) { if (load8(data + 3) == 71) {
            return FILETYPE_PNG;
        } } } }
    }

    # JPEG: ff d8 ff
    if (len >= 3) {
        if (load8(data) == 255) { if (load8(data + 1) == 216) { if (load8(data + 2) == 255) {
            return FILETYPE_JPEG;
        } } }
    }

    # ZIP: 50 4b 03 04
    if (len >= 4) {
        if (load8(data) == 80) { if (load8(data + 1) == 75) { if (load8(data + 2) == 3) { if (load8(data + 3) == 4) {
            return FILETYPE_ZIP;
        } } } }
    }

    # GZIP: 1f 8b
    if (load8(data) == 31) {
        if (load8(data + 1) == 139) {
            return FILETYPE_GZIP;
        }
    }

    # Script: #!
    if (load8(data) == 35) {
        if (load8(data + 1) == 33) {
            return FILETYPE_SCRIPT;
        }
    }

    return FILETYPE_UNKNOWN;
}

# Detect polyglot files — returns a Vec of FileType constants
fn detect_polyglot(data, len) {
    var types = vec_new();
    var primary = detect_file_type(data, len);
    if (primary != FILETYPE_UNKNOWN) {
        vec_push(types, primary);
    }

    # Embedded signature patterns (search after first 4 bytes)
    if (len > 8) {
        var search_start = data + 4;
        var search_len = len - 4;

        # ELF: 7f 45 4c 46
        if (primary != FILETYPE_ELF) {
            var sig_elf = alloc(4);
            store8(sig_elf, 127); store8(sig_elf + 1, 69); store8(sig_elf + 2, 76); store8(sig_elf + 3, 70);
            if (memmem(search_start, search_len, sig_elf, 4) >= 0) {
                vec_push(types, FILETYPE_ELF);
            }
        }
        # PE: 4d 5a
        if (primary != FILETYPE_PE) {
            var sig_pe = alloc(2);
            store8(sig_pe, 77); store8(sig_pe + 1, 90);
            if (memmem(search_start, search_len, sig_pe, 2) >= 0) {
                vec_push(types, FILETYPE_PE);
            }
        }
        # PDF: 25 50 44 46
        if (primary != FILETYPE_PDF) {
            var sig_pdf = alloc(4);
            store8(sig_pdf, 37); store8(sig_pdf + 1, 80); store8(sig_pdf + 2, 68); store8(sig_pdf + 3, 70);
            if (memmem(search_start, search_len, sig_pdf, 4) >= 0) {
                vec_push(types, FILETYPE_PDF);
            }
        }
        # ZIP: 50 4b 03 04
        if (primary != FILETYPE_ZIP) {
            var sig_zip = alloc(4);
            store8(sig_zip, 80); store8(sig_zip + 1, 75); store8(sig_zip + 2, 3); store8(sig_zip + 3, 4);
            if (memmem(search_start, search_len, sig_zip, 4) >= 0) {
                vec_push(types, FILETYPE_ZIP);
            }
        }
    }

    return types;
}

# ================================================================
# SHA-256 (via sigil extern)
# ================================================================

# Compute SHA-256 hash of data, returned as lowercase hex Str
fn file_sha256(data, len) {
    var hash_str = sigil_sha256(data, len);
    return hash_str;
}

# ================================================================
# Binary analysis
# ================================================================

fn analyze(data, len) {
    var a = BinaryAnalysis {};
    a.file_type = detect_file_type(data, len);
    a.entropy = shannon_entropy(data, len);
    a.size = len;
    a.sha256 = file_sha256(data, len);
    return a;
}

# Produce threat findings from a pre-computed analysis
# Returns Vec of ThreatFinding ptrs
fn findings_from_analysis(data, len, analysis, target) {
    var findings = vec_new();

    # High entropy check
    if (is_suspicious_entropy(analysis.entropy)) {
        var ent_str = str_from("high_entropy");
        var desc = str_cat(str_from("High entropy detected (threshold: 7.5)"), str_from(""));
        var f = finding_new(target, CATEGORY_SUSPICIOUS, SEVERITY_MEDIUM, ent_str, desc);
        map_set(f.metadata, str_from("sha256"), analysis.sha256);
        vec_push(findings, f);
    }

    # Polyglot check
    var poly = detect_polyglot(data, len);
    if (vec_len(poly) > 1) {
        var poly_desc = str_from("Polyglot file detected");
        var f = finding_new(target, CATEGORY_EMBEDDED_PAYLOAD, SEVERITY_HIGH,
                           str_from("polyglot_file"), poly_desc);
        vec_push(findings, f);
    }

    return findings;
}

# Convenience wrapper
fn analyze_findings(data, len, target) {
    var analysis = analyze(data, len);
    return findings_from_analysis(data, len, analysis, target);
}

# ================================================================
# Severity escalation
# ================================================================

fn escalate_severity(findings, analysis) {
    var flen = vec_len(findings);
    if (flen == 0) { return; }

    var has_high_entropy = 0;
    var has_polyglot = 0;
    var is_exec = filetype_is_executable(analysis.file_type);

    for (var i = 0; i < flen; i = i + 1) {
        var f = vec_get(findings, i);
        if (str_eq(f.rule_name, str_from("high_entropy"))) { has_high_entropy = 1; }
        if (str_eq(f.rule_name, str_from("polyglot_file"))) { has_polyglot = 1; }
    }

    # High entropy + polyglot = critical
    if (has_high_entropy & has_polyglot) {
        for (var i = 0; i < flen; i = i + 1) {
            var f = vec_get(findings, i);
            if (str_eq(f.rule_name, str_from("polyglot_file"))) {
                f.severity = SEVERITY_CRITICAL;
                map_set(f.metadata, str_from("escalated_polyglot"),
                       str_from("high_entropy+polyglot"));
            }
        }
    }

    # Executable file type escalates Medium -> High
    if (is_exec) {
        for (var i = 0; i < flen; i = i + 1) {
            var f = vec_get(findings, i);
            if (f.severity == SEVERITY_MEDIUM) {
                f.severity = SEVERITY_HIGH;
                map_set(f.metadata, str_from("escalated_executable"),
                       str_from("executable_file_type"));
            }
        }
    }

    # Multiple Medium+ findings = escalate highest
    var medium_plus = 0;
    for (var i = 0; i < flen; i = i + 1) {
        var f = vec_get(findings, i);
        if (severity_gte(f.severity, SEVERITY_MEDIUM)) {
            medium_plus = medium_plus + 1;
        }
    }
    if (medium_plus >= 2) {
        var best_idx = 0;
        var best_sev = SEVERITY_INFO;
        for (var i = 0; i < flen; i = i + 1) {
            var f = vec_get(findings, i);
            if (severity_gt(f.severity, best_sev)) {
                best_sev = f.severity;
                best_idx = i;
            }
        }
        var highest = vec_get(findings, best_idx);
        if (highest.severity == SEVERITY_HIGH) {
            highest.severity = SEVERITY_CRITICAL;
            map_set(highest.metadata, str_from("escalated_signals"),
                   str_from("multiple_signals"));
        }
    }
}

# ================================================================
# Section entropy analysis
# ================================================================

var CODE_SECTION_ENTROPY_THRESHOLD = F64_7_0;

# Generate findings from per-section entropy analysis
# sections = Vec of SectionEntropy ptrs, target = ScanTarget ptr
fn section_entropy_findings(sections, target) {
    var findings = vec_new();
    var slen = vec_len(sections);
    for (var i = 0; i < slen; i = i + 1) {
        var sec = vec_get(sections, i);
        var threshold = F64_7_5;
        if (sec.executable) { threshold = CODE_SECTION_ENTROPY_THRESHOLD; }

        if (f64_gt(sec.entropy, threshold)) {
            var sev = SEVERITY_MEDIUM;
            if (sec.executable) { sev = SEVERITY_HIGH; }
            var desc = str_cat(str_from("Section has high entropy: "), sec.name);
            var f = finding_new(target, CATEGORY_SUSPICIOUS, sev,
                               str_from("high_section_entropy"), desc);
            map_set(f.metadata, str_from("section"), sec.name);
            map_set(f.metadata, str_from("executable"),
                   sec.executable ? str_from("true") : str_from("false"));
            vec_push(findings, f);
        }
    }
    return findings;
}

# ================================================================
# Overlay detection
# ================================================================

# Generate findings from PE overlay analysis
fn overlay_findings(overlay, target) {
    var findings = vec_new();
    var sev = SEVERITY_LOW;
    if (is_suspicious_entropy(overlay.entropy)) {
        sev = SEVERITY_HIGH;
    }
    var desc = str_from("PE overlay detected");
    var f = finding_new(target, CATEGORY_SUSPICIOUS, sev,
                       str_from("pe_overlay"), desc);
    map_set(f.metadata, str_from("overlay_size"),
           str_from_int(overlay.size));
    vec_push(findings, f);
    return findings;
}

# ================================================================
# Packing heuristics
# ================================================================

# Known packer section names
fn is_packer_section(name) {
    if (str_eq(name, str_from("UPX0")))     { return 1; }
    if (str_eq(name, str_from("UPX1")))     { return 1; }
    if (str_eq(name, str_from("UPX2")))     { return 1; }
    if (str_eq(name, str_from("UPX!")))     { return 1; }
    if (str_eq(name, str_from(".aspack")))   { return 1; }
    if (str_eq(name, str_from(".adata")))    { return 1; }
    if (str_eq(name, str_from(".vmp0")))     { return 1; }
    if (str_eq(name, str_from(".vmp1")))     { return 1; }
    if (str_eq(name, str_from(".vmp2")))     { return 1; }
    if (str_eq(name, str_from(".themida")))  { return 1; }
    if (str_eq(name, str_from(".petite")))   { return 1; }
    if (str_eq(name, str_from(".nsp0")))     { return 1; }
    if (str_eq(name, str_from(".nsp1")))     { return 1; }
    if (str_eq(name, str_from(".nsp2")))     { return 1; }
    if (str_eq(name, str_from(".packed")))   { return 1; }
    if (str_eq(name, str_from(".mpress1")))  { return 1; }
    if (str_eq(name, str_from(".mpress2")))  { return 1; }
    return 0;
}

# Generate findings from packing analysis
fn packing_findings(signals, target) {
    var count = packing_signal_count(signals);
    if (count == 0) { return vec_new(); }

    var sev = SEVERITY_LOW;
    if (count == 2) { sev = SEVERITY_MEDIUM; }
    if (count >= 3) { sev = SEVERITY_HIGH; }

    var desc = str_from("Packed/encrypted binary detected");
    var f = finding_new(target, CATEGORY_SUSPICIOUS, sev,
                       str_from("packed_binary"), desc);
    map_set(f.metadata, str_from("signal_count"), str_from_int(count));
    var findings = vec_new();
    vec_push(findings, f);
    return findings;
}

# ================================================================
# String extraction (strings.rs)
# ================================================================

var DEFAULT_MIN_STRING_LENGTH = 4;

# Whether a byte is printable ASCII (0x20..0x7E) or tab/newline/CR
fn is_printable_ascii(b) {
    if (b >= 32) { if (b <= 126) { return 1; } }
    if (b == 9)  { return 1; }  # tab
    if (b == 10) { return 1; }  # newline
    if (b == 13) { return 1; }  # CR
    return 0;
}

# Extract printable ASCII strings from binary data
# data = address, len = byte count, min_length = minimum chars
# Returns Vec of ExtractedString ptrs
fn extract_ascii(data, len, min_length) {
    var results = vec_new();
    var run_start = 0;
    var in_run = 0;

    for (var i = 0; i < len; i = i + 1) {
        var b = load8(data + i);
        if (is_printable_ascii(b)) {
            if (!in_run) {
                run_start = i;
                in_run = 1;
            }
        } else {
            if (in_run) {
                var run_len = i - run_start;
                if (run_len >= min_length) {
                    var es = ExtractedString {};
                    es.value = str_from_raw(data + run_start, run_len);
                    es.offset = run_start;
                    es.encoding = STRING_ENCODING_ASCII;
                    vec_push(results, es);
                }
                in_run = 0;
            }
        }
    }

    # Handle string at end of data
    if (in_run) {
        var run_len = len - run_start;
        if (run_len >= min_length) {
            var es = ExtractedString {};
            es.value = str_from_raw(data + run_start, run_len);
            es.offset = run_start;
            es.encoding = STRING_ENCODING_ASCII;
            vec_push(results, es);
        }
    }

    return results;
}

# Extract UTF-16 LE strings from binary data
# Looks for printable ASCII bytes interleaved with null bytes
fn extract_utf16le(data, len, min_length) {
    var results = vec_new();
    var run_start = 0;
    var char_count = 0;
    var in_run = 0;

    var i = 0;
    while (i + 1 < len) {
        var lo = load8(data + i);
        var hi = load8(data + i + 1);

        if (is_printable_ascii(lo) & (hi == 0)) {
            if (!in_run) {
                run_start = i;
                char_count = 0;
                in_run = 1;
            }
            char_count = char_count + 1;
        } else {
            if (in_run & (char_count >= min_length)) {
                # Extract ASCII bytes from every other position
                var buf = alloc(char_count + 1);
                for (var j = 0; j < char_count; j = j + 1) {
                    store8(buf + j, load8(data + run_start + j * 2));
                }
                store8(buf + char_count, 0);
                var es = ExtractedString {};
                es.value = str_from_raw(buf, char_count);
                es.offset = run_start;
                es.encoding = STRING_ENCODING_UTF16LE;
                vec_push(results, es);
            }
            in_run = 0;
        }
        i = i + 2;
    }

    # Handle trailing run
    if (in_run & (char_count >= min_length)) {
        var buf = alloc(char_count + 1);
        for (var j = 0; j < char_count; j = j + 1) {
            store8(buf + j, load8(data + run_start + j * 2));
        }
        store8(buf + char_count, 0);
        var es = ExtractedString {};
        es.value = str_from_raw(buf, char_count);
        es.offset = run_start;
        es.encoding = STRING_ENCODING_UTF16LE;
        vec_push(results, es);
    }

    return results;
}

# Extract all strings (ASCII + UTF-16 LE), sorted by offset
fn extract_strings(data, len, min_length) {
    var ascii_strs = extract_ascii(data, len, min_length);
    var utf16_strs = extract_utf16le(data, len, min_length);

    # Merge into one vec
    var all = vec_new();
    var alen = vec_len(ascii_strs);
    var ulen = vec_len(utf16_strs);
    for (var i = 0; i < alen; i = i + 1) {
        vec_push(all, vec_get(ascii_strs, i));
    }
    for (var i = 0; i < ulen; i = i + 1) {
        vec_push(all, vec_get(utf16_strs, i));
    }

    # Insertion sort by offset (typically small N)
    var total = vec_len(all);
    for (var i = 1; i < total; i = i + 1) {
        var key = vec_get(all, i);
        var key_off = key.offset;
        var j = i - 1;
        while (j >= 0) {
            var cur = vec_get(all, j);
            if (cur.offset <= key_off) {
                j = -1;  # break
            } else {
                vec_set(all, j + 1, cur);
                j = j - 1;
            }
        }
        if (j == -1) {
            vec_set(all, 0, key);
        } else {
            vec_set(all, j + 1, key);
        }
    }

    return all;
}

# ================================================================
# Script classification (script.rs)
# ================================================================

# Count how many indicator strings appear in text
fn count_indicators(text, indicators, num_indicators) {
    var count = 0;
    for (var i = 0; i < num_indicators; i = i + 1) {
        var ind = vec_get(indicators, i);
        if (str_contains(text, ind)) {
            count = count + 1;
        }
    }
    return count;
}

fn classify_script(data, len) {
    # Check shebang first
    if (len >= 2) {
        if (load8(data) == 35) {   # '#'
            if (load8(data + 1) == 33) {  # '!'
                # Find end of first line
                var line_end = len;
                for (var i = 0; i < len; i = i + 1) {
                    if (load8(data + i) == 10) {
                        line_end = i;
                        i = len;  # break
                    }
                }
                var shebang = str_from_raw(data, line_end);
                if (str_contains(shebang, str_from("python")))     { return SCRIPT_PYTHON; }
                if (str_contains(shebang, str_from("bash")))       { return SCRIPT_SHELL; }
                if (str_contains(shebang, str_from("/sh")))        { return SCRIPT_SHELL; }
                if (str_contains(shebang, str_from("zsh")))        { return SCRIPT_SHELL; }
                if (str_contains(shebang, str_from("node")))       { return SCRIPT_JAVASCRIPT; }
                if (str_contains(shebang, str_from("pwsh")))       { return SCRIPT_POWERSHELL; }
                if (str_contains(shebang, str_from("powershell"))) { return SCRIPT_POWERSHELL; }
            }
        }
    }

    # Content-based classification on the first 8KB
    var sample_len = len;
    if (sample_len > 8192) { sample_len = 8192; }
    var text = str_from_raw(data, sample_len);
    # Note: Cyrius str_from_raw does not lowercase; we do case-insensitive
    # matching by including lowercase indicators. The original Rust lowercases
    # the text first. We approximate by checking common patterns.
    var lower = str_lower(text);

    # PowerShell indicators
    var ps_inds = vec_new();
    vec_push(ps_inds, str_from("$env:"));
    vec_push(ps_inds, str_from("get-"));
    vec_push(ps_inds, str_from("set-"));
    vec_push(ps_inds, str_from("invoke-"));
    vec_push(ps_inds, str_from("new-object"));
    vec_push(ps_inds, str_from("write-host"));
    vec_push(ps_inds, str_from("[system."));
    vec_push(ps_inds, str_from("[convert]::"));
    vec_push(ps_inds, str_from("param("));
    vec_push(ps_inds, str_from("-executionpolicy"));
    vec_push(ps_inds, str_from("import-module"));
    vec_push(ps_inds, str_from("add-type"));
    vec_push(ps_inds, str_from("[reflection."));
    var ps_score = count_indicators(lower, ps_inds, 13);

    # VBScript indicators
    var vbs_inds = vec_new();
    vec_push(vbs_inds, str_from("dim "));
    vec_push(vbs_inds, str_from("sub "));
    vec_push(vbs_inds, str_from("function "));
    vec_push(vbs_inds, str_from("wscript."));
    vec_push(vbs_inds, str_from("createobject("));
    vec_push(vbs_inds, str_from("msgbox"));
    vec_push(vbs_inds, str_from("on error resume"));
    vec_push(vbs_inds, str_from("chr("));
    vec_push(vbs_inds, str_from("cstr("));
    vec_push(vbs_inds, str_from("set "));
    var vbs_score = count_indicators(lower, vbs_inds, 10);

    # JavaScript indicators
    var js_inds = vec_new();
    vec_push(js_inds, str_from("var "));
    vec_push(js_inds, str_from("let "));
    vec_push(js_inds, str_from("const "));
    vec_push(js_inds, str_from("function "));
    vec_push(js_inds, str_from("=>"));
    vec_push(js_inds, str_from("document."));
    vec_push(js_inds, str_from("window."));
    vec_push(js_inds, str_from("require("));
    vec_push(js_inds, str_from("module.exports"));
    vec_push(js_inds, str_from("console.log"));
    vec_push(js_inds, str_from("settimeout"));
    vec_push(js_inds, str_from("addeventlistener"));
    vec_push(js_inds, str_from("json.parse"));
    var js_score = count_indicators(lower, js_inds, 13);

    # Python indicators
    var py_inds = vec_new();
    vec_push(py_inds, str_from("import "));
    vec_push(py_inds, str_from("from "));
    vec_push(py_inds, str_from("def "));
    vec_push(py_inds, str_from("class "));
    vec_push(py_inds, str_from("print("));
    vec_push(py_inds, str_from("if __name__"));
    vec_push(py_inds, str_from("self."));
    vec_push(py_inds, str_from("elif "));
    vec_push(py_inds, str_from("except:"));
    vec_push(py_inds, str_from("with open("));
    var py_score = count_indicators(lower, py_inds, 10);

    # Batch indicators
    var bat_inds = vec_new();
    vec_push(bat_inds, str_from("@echo"));
    vec_push(bat_inds, str_from("echo "));
    vec_push(bat_inds, str_from("set "));
    vec_push(bat_inds, str_from("goto "));
    vec_push(bat_inds, str_from("if exist"));
    vec_push(bat_inds, str_from("%~"));
    vec_push(bat_inds, str_from("errorlevel"));
    vec_push(bat_inds, str_from("call "));
    vec_push(bat_inds, str_from("rem "));
    vec_push(bat_inds, str_from("pause"));
    var bat_score = count_indicators(lower, bat_inds, 10);

    # Shell indicators
    var sh_inds = vec_new();
    vec_push(sh_inds, str_from("#!/"));
    vec_push(sh_inds, str_from("fi\n"));
    vec_push(sh_inds, str_from("done\n"));
    vec_push(sh_inds, str_from("esac"));
    vec_push(sh_inds, str_from("elif "));
    vec_push(sh_inds, str_from("then\n"));
    vec_push(sh_inds, str_from("export "));
    vec_push(sh_inds, str_from("alias "));
    vec_push(sh_inds, str_from("source "));
    var sh_score = count_indicators(lower, sh_inds, 9);

    # Find the best match (minimum 2 indicators)
    var best_lang = SCRIPT_UNKNOWN;
    var best_score = 1;  # threshold: must be >= 2

    if (ps_score > best_score)  { best_score = ps_score;  best_lang = SCRIPT_POWERSHELL; }
    if (vbs_score > best_score) { best_score = vbs_score; best_lang = SCRIPT_VBSCRIPT; }
    if (js_score > best_score)  { best_score = js_score;  best_lang = SCRIPT_JAVASCRIPT; }
    if (py_score > best_score)  { best_score = py_score;  best_lang = SCRIPT_PYTHON; }
    if (bat_score > best_score) { best_score = bat_score; best_lang = SCRIPT_BATCH; }
    if (sh_score > best_score)  { best_score = sh_score;  best_lang = SCRIPT_SHELL; }

    return best_lang;
}

# ================================================================
# Obfuscation detection (script.rs)
# ================================================================

fn is_base64_like(s) {
    var slen = str_len(s);
    if (slen == 0) { return 0; }
    var sdata = str_data(s);
    var b64_count = 0;
    for (var i = 0; i < slen; i = i + 1) {
        var b = load8(sdata + i);
        # A-Z: 65-90, a-z: 97-122, 0-9: 48-57, +: 43, /: 47, =: 61
        if (b >= 65) { if (b <= 90)  { b64_count = b64_count + 1; } }
        if (b >= 97) { if (b <= 122) { b64_count = b64_count + 1; } }
        if (b >= 48) { if (b <= 57)  { b64_count = b64_count + 1; } }
        if (b == 43) { b64_count = b64_count + 1; }
        if (b == 47) { b64_count = b64_count + 1; }
        if (b == 61) { b64_count = b64_count + 1; }
    }
    return (b64_count * 100 / slen) > 90;
}

fn detect_obfuscation(data, len, language) {
    var signals = obfuscation_signals_new();
    var text = str_from_raw(data, len);
    var lower = str_lower(text);

    # Per-line entropy analysis
    # Split text by newline and analyze each line
    var tdata = str_data(text);
    var tlen = str_len(text);
    var line_start = 0;
    var line_count = 0;
    var high_ent_lines = 0;

    for (var i = 0; i <= tlen; i = i + 1) {
        var is_end = (i == tlen);
        if (!is_end) { is_end = (load8(tdata + i) == 10); }

        if (is_end) {
            var line_len = i - line_start;
            line_count = line_count + 1;

            # Skip leading whitespace for trimmed length check
            var trim_start = line_start;
            while (trim_start < i) {
                var c = load8(tdata + trim_start);
                if (c != 32 & c != 9) {
                    trim_start = i;  # done trimming; break
                } else {
                    trim_start = trim_start + 1;
                }
            }
            # Re-derive trimmed length from original approach
            var trimmed_len = i - line_start;
            if (trimmed_len > 40) {
                var ent = shannon_entropy(tdata + line_start, line_len);
                if (f64_gt(ent, F64_5_5)) {
                    high_ent_lines = high_ent_lines + 1;
                }
            }

            line_start = i + 1;
        }
    }

    signals.total_lines = line_count;
    signals.high_entropy_lines = high_ent_lines;

    if (line_count > 5) {
        if (high_ent_lines * 3 > line_count) {
            vec_push(signals.patterns, str_from("high per-line entropy (>33% of lines)"));
            signals.score = signals.score + 2;
        }
    }

    # Base64 decode function references
    if (str_contains(lower, str_from("base64"))) {
        vec_push(signals.patterns, str_from("base64 decode function"));
        signals.score = signals.score + 1;
    } elif (str_contains(lower, str_from("frombase64"))) {
        vec_push(signals.patterns, str_from("base64 decode function"));
        signals.score = signals.score + 1;
    } elif (str_contains(lower, str_from("atob("))) {
        vec_push(signals.patterns, str_from("base64 decode function"));
        signals.score = signals.score + 1;
    }

    # Long base64-like strings (check each line)
    line_start = 0;
    var found_b64_block = 0;
    for (var i = 0; i <= tlen; i = i + 1) {
        var is_end = (i == tlen);
        if (!is_end) { is_end = (load8(tdata + i) == 10); }
        if (is_end & !found_b64_block) {
            var ll = i - line_start;
            if (ll >= 60) {
                var line_str = str_from_raw(tdata + line_start, ll);
                if (is_base64_like(line_str)) {
                    vec_push(signals.patterns, str_from("long base64-like string detected"));
                    signals.score = signals.score + 2;
                    found_b64_block = 1;
                }
            }
            line_start = i + 1;
        }
    }

    # Language-specific obfuscation patterns
    if (language == SCRIPT_POWERSHELL) {
        detect_powershell_obfuscation(lower, signals);
    } elif (language == SCRIPT_VBSCRIPT) {
        detect_vbscript_obfuscation(lower, signals);
    } elif (language == SCRIPT_JAVASCRIPT) {
        detect_javascript_obfuscation(lower, signals);
    }

    # Excessive string concatenation (generic)
    var concat_count = str_count(text, str_from("+")) + str_count(text, str_from("&"));
    if (line_count > 0) {
        if (concat_count > line_count * 3) {
            vec_push(signals.patterns, str_from("excessive string concatenation"));
            signals.score = signals.score + 1;
        }
    }

    return signals;
}

fn detect_powershell_obfuscation(lower, signals) {
    # [char] casting chains
    if (str_count(lower, str_from("[char]")) >= 3) {
        vec_push(signals.patterns, str_from("PowerShell [char] casting chain"));
        signals.score = signals.score + 2;
    }
    # Invoke-Expression / IEX
    if (str_contains(lower, str_from("invoke-expression"))) {
        vec_push(signals.patterns, str_from("PowerShell Invoke-Expression/IEX"));
        signals.score = signals.score + 1;
    } elif (str_contains(lower, str_from("iex ")) | str_contains(lower, str_from("iex("))) {
        vec_push(signals.patterns, str_from("PowerShell Invoke-Expression/IEX"));
        signals.score = signals.score + 1;
    }
    # -EncodedCommand
    if (str_contains(lower, str_from("-encodedcommand")) | str_contains(lower, str_from("-enc "))) {
        vec_push(signals.patterns, str_from("PowerShell -EncodedCommand"));
        signals.score = signals.score + 2;
    }
    # Excessive -replace chains
    if (str_count(lower, str_from("-replace")) >= 3) {
        vec_push(signals.patterns, str_from("PowerShell excessive -replace chains"));
        signals.score = signals.score + 1;
    }
    # Hidden window
    if (str_contains(lower, str_from("-windowstyle hidden"))) {
        vec_push(signals.patterns, str_from("PowerShell hidden window"));
        signals.score = signals.score + 1;
    }
}

fn detect_vbscript_obfuscation(lower, signals) {
    # Chr() concatenation chains
    if (str_count(lower, str_from("chr(")) >= 5) {
        vec_push(signals.patterns, str_from("VBScript Chr() concatenation chain"));
        signals.score = signals.score + 2;
    }
    # Execute/ExecuteGlobal
    if (str_contains(lower, str_from("execute(")) | str_contains(lower, str_from("executeglobal"))) {
        vec_push(signals.patterns, str_from("VBScript Execute/ExecuteGlobal"));
        signals.score = signals.score + 1;
    }
    # WScript.Shell
    if (str_contains(lower, str_from("wscript.shell"))) {
        vec_push(signals.patterns, str_from("VBScript WScript.Shell"));
        signals.score = signals.score + 1;
    }
}

fn detect_javascript_obfuscation(lower, signals) {
    # eval() usage
    if (str_contains(lower, str_from("eval("))) {
        vec_push(signals.patterns, str_from("JavaScript eval()"));
        signals.score = signals.score + 1;
    }
    # String.fromCharCode chains
    if (str_count(lower, str_from("fromcharcode")) >= 2) {
        vec_push(signals.patterns, str_from("JavaScript fromCharCode chain"));
        signals.score = signals.score + 2;
    }
    # document.write + unescape
    if (str_contains(lower, str_from("document.write")) & str_contains(lower, str_from("unescape"))) {
        vec_push(signals.patterns, str_from("JavaScript document.write+unescape"));
        signals.score = signals.score + 2;
    }
    # Hex escape sequences
    if (str_count(lower, str_from("\\x")) >= 10) {
        vec_push(signals.patterns, str_from("JavaScript excessive hex escapes"));
        signals.score = signals.score + 1;
    }
}

# Generate findings from script analysis
fn script_findings(language, obfuscation, target) {
    if (obfuscation.score == 0) { return vec_new(); }

    var sev = SEVERITY_HIGH;
    if (obfuscation.score == 1)                     { sev = SEVERITY_LOW; }
    if (obfuscation.score >= 2 & obfuscation.score <= 3) { sev = SEVERITY_MEDIUM; }

    var desc = str_cat(str_from("Obfuscated "),
               str_cat(script_language_name(language), str_from(" script detected")));
    var f = finding_new(target, CATEGORY_SUSPICIOUS, sev,
                       str_from("script_obfuscation"), desc);
    map_set(f.metadata, str_from("script_language"), script_language_name(language));
    map_set(f.metadata, str_from("obfuscation_score"), str_from_int(obfuscation.score));
    map_set(f.metadata, str_from("high_entropy_lines"), str_from_int(obfuscation.high_entropy_lines));

    var findings = vec_new();
    vec_push(findings, f);
    return findings;
}

# ================================================================
# ssdeep — Context-Triggered Piecewise Hashing (CTPH)
# ================================================================

var ROLLING_WINDOW  = 7;
var MIN_BLOCK_SIZE  = 3;
var SPAMSUM_LENGTH  = 64;
var HASH_INIT       = 671088487;     # 0x28021967
var HASH_PRIME      = 16777619;      # 0x01000193

# Base64 alphabet (stored as a 64-byte raw buffer)
fn base64_char(idx) {
    # ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/
    if (idx < 26) { return 65 + idx; }      # A-Z
    if (idx < 52) { return 97 + idx - 26; } # a-z
    if (idx < 62) { return 48 + idx - 52; } # 0-9
    if (idx == 62) { return 43; }            # +
    return 47;                                # /
}

# Rolling hash state — stored as raw memory block
# Layout: window (7 bytes at +0), pos (i64 at +8), h1 (i64 at +16),
#         h2 (i64 at +24), h3 (i64 at +32)
var ROLL_WINDOW_OFF = 0;
var ROLL_POS_OFF    = 8;
var ROLL_H1_OFF     = 16;
var ROLL_H2_OFF     = 24;
var ROLL_H3_OFF     = 32;
var ROLL_SIZE       = 40;

fn rolling_new() {
    var r = alloc(ROLL_SIZE);
    for (var i = 0; i < ROLLING_WINDOW; i = i + 1) {
        store8(r + ROLL_WINDOW_OFF + i, 0);
    }
    store64(r + ROLL_POS_OFF, 0);
    store64(r + ROLL_H1_OFF, 0);
    store64(r + ROLL_H2_OFF, 0);
    store64(r + ROLL_H3_OFF, 0);
    return r;
}

# Update rolling hash with a byte, return combined hash (masked to u32)
fn rolling_update(r, byte) {
    var pos = load64(r + ROLL_POS_OFF);
    var old = load8(r + ROLL_WINDOW_OFF + pos);
    store8(r + ROLL_WINDOW_OFF + pos, byte);
    var new_pos = pos + 1;
    if (new_pos >= ROLLING_WINDOW) { new_pos = 0; }
    store64(r + ROLL_POS_OFF, new_pos);

    var h1 = load64(r + ROLL_H1_OFF);
    var h2 = load64(r + ROLL_H2_OFF);
    var h3 = load64(r + ROLL_H3_OFF);

    h1 = (h1 + byte - old) & 4294967295;
    h2 = (h2 + h1 - ROLLING_WINDOW * old) & 4294967295;
    h3 = (((h3 << 5) + byte) ^ byte) & 4294967295;

    store64(r + ROLL_H1_OFF, h1);
    store64(r + ROLL_H2_OFF, h2);
    store64(r + ROLL_H3_OFF, h3);

    return (h1 + h2 + h3) & 4294967295;
}

# FNV-1 style hash update (masked to u32)
fn fnv_update(h, byte) {
    return ((h * HASH_PRIME) ^ byte) & 4294967295;
}

# Select initial block size based on data length
fn select_block_size(data_len) {
    var bs = MIN_BLOCK_SIZE;
    while (bs * SPAMSUM_LENGTH < data_len) {
        bs = bs * 2;
    }
    return bs;
}

# Compute both hash components for a given block size
# Returns: stores hash1 Str at out_h1_ptr, hash2 Str at out_h2_ptr
fn compute_ssdeep_hashes(data, len, block_size, out_h1_ptr, out_h2_ptr) {
    var rolling = rolling_new();
    var fnv1 = HASH_INIT;
    var fnv2 = HASH_INIT;

    # Build hash strings using byte buffers
    var h1_buf = alloc(SPAMSUM_LENGTH + 1);
    var h2_buf = alloc(SPAMSUM_LENGTH + 1);
    var h1_len = 0;
    var h2_len = 0;

    var bs = block_size;
    var bs2 = bs * 2;

    for (var i = 0; i < len; i = i + 1) {
        var byte = load8(data + i);
        var roll = rolling_update(rolling, byte);
        fnv1 = fnv_update(fnv1, byte);
        fnv2 = fnv_update(fnv2, byte);

        # Block boundary for block_size
        if (roll & 4294967295) {
            if ((roll % bs) == (bs - 1)) {
                store8(h1_buf + h1_len, base64_char(fnv1 & 63));
                h1_len = h1_len + 1;
                fnv1 = HASH_INIT;
            }
        }

        # Block boundary for block_size * 2
        if ((roll % bs2) == (bs2 - 1)) {
            store8(h2_buf + h2_len, base64_char(fnv2 & 63));
            h2_len = h2_len + 1;
            fnv2 = HASH_INIT;
        }
    }

    # Finalize trailing partial blocks
    if (fnv1 != HASH_INIT | h1_len == 0) {
        store8(h1_buf + h1_len, base64_char(fnv1 & 63));
        h1_len = h1_len + 1;
    }
    if (fnv2 != HASH_INIT | h2_len == 0) {
        store8(h2_buf + h2_len, base64_char(fnv2 & 63));
        h2_len = h2_len + 1;
    }

    store8(h1_buf + h1_len, 0);
    store8(h2_buf + h2_len, 0);

    store64(out_h1_ptr, str_from_raw(h1_buf, h1_len));
    store64(out_h2_ptr, str_from_raw(h2_buf, h2_len));
}

# Compute the ssdeep hash of a byte slice
# Returns SsdeepHash ptr, or 0 if data is empty
fn ssdeep_hash(data, len) {
    if (len == 0) { return 0; }

    var block_size = select_block_size(len);

    # Allocate space for output string pointers
    var h1_ptr = alloc(8);
    var h2_ptr = alloc(8);

    while (1) {
        compute_ssdeep_hashes(data, len, block_size, h1_ptr, h2_ptr);
        var h1 = load64(h1_ptr);
        var h2 = load64(h2_ptr);

        var h1_len = str_len(h1);
        var h2_len = str_len(h2);

        # If hash1 fits or we are at minimum block size, done
        if (h1_len <= SPAMSUM_LENGTH | block_size <= MIN_BLOCK_SIZE) {
            # Truncate if needed
            var h1_trunc = h1;
            if (h1_len > SPAMSUM_LENGTH) {
                h1_trunc = str_substr(h1, 0, SPAMSUM_LENGTH);
            }
            var h2_max = SPAMSUM_LENGTH / 2;
            var h2_trunc = h2;
            if (h2_len > h2_max) {
                h2_trunc = str_substr(h2, 0, h2_max);
            }

            # Build digest: "block_size:hash1:hash2"
            var digest = str_cat(str_from_int(block_size),
                         str_cat(str_from(":"),
                         str_cat(h1_trunc,
                         str_cat(str_from(":"), h2_trunc))));

            var result = SsdeepHash {};
            result.digest = digest;
            result.block_size = block_size;
            return result;
        }

        # Hash too long, double block size and retry
        block_size = block_size * 2;
    }
    return 0;  # unreachable
}

# Eliminate runs of 3+ identical characters (reduce to 3)
fn eliminate_sequences(s) {
    var slen = str_len(s);
    var sdata = str_data(s);
    var out = alloc(slen + 1);
    var out_len = 0;
    var run = 0;
    var prev = -1;

    for (var i = 0; i < slen; i = i + 1) {
        var b = load8(sdata + i);
        if (b == prev) {
            run = run + 1;
        } else {
            run = 1;
            prev = b;
        }
        if (run <= 3) {
            store8(out + out_len, b);
            out_len = out_len + 1;
        }
    }
    store8(out + out_len, 0);
    return str_from_raw(out, out_len);
}

# Levenshtein edit distance between two raw byte buffers
fn edit_distance(a, alen, b, blen) {
    if (alen == 0) { return blen; }
    if (blen == 0) { return alen; }

    # Single-row DP
    var prev = alloc((blen + 1) * 8);
    var curr = alloc((blen + 1) * 8);

    for (var j = 0; j <= blen; j = j + 1) {
        store64(prev + j * 8, j);
    }

    for (var i = 1; i <= alen; i = i + 1) {
        store64(curr, i);
        for (var j = 1; j <= blen; j = j + 1) {
            var cost = 1;
            if (load8(a + i - 1) == load8(b + j - 1)) { cost = 0; }
            var del = load64(prev + j * 8) + 1;
            var ins = load64(curr + (j - 1) * 8) + 1;
            var sub = load64(prev + (j - 1) * 8) + cost;
            var best = del;
            if (ins < best) { best = ins; }
            if (sub < best) { best = sub; }
            store64(curr + j * 8, best);
        }
        # Swap prev and curr
        var tmp = prev;
        prev = curr;
        curr = tmp;
    }

    return load64(prev + blen * 8);
}

# Parse an ssdeep digest into (block_size, hash1, hash2)
# Stores results at bs_ptr, h1_ptr, h2_ptr. Returns 1 on success, 0 on failure.
fn parse_ssdeep_digest(digest, bs_ptr, h1_ptr, h2_ptr) {
    var ddata = str_data(digest);
    var dlen = str_len(digest);

    # Find first ':'
    var colon1 = -1;
    for (var i = 0; i < dlen; i = i + 1) {
        if (load8(ddata + i) == 58) { colon1 = i; i = dlen; }
    }
    if (colon1 < 0) { return 0; }

    # Find second ':'
    var colon2 = -1;
    for (var i = colon1 + 1; i < dlen; i = i + 1) {
        if (load8(ddata + i) == 58) { colon2 = i; i = dlen; }
    }
    if (colon2 < 0) { return 0; }

    # Parse block size
    var bs = 0;
    for (var i = 0; i < colon1; i = i + 1) {
        var d = load8(ddata + i) - 48;
        if (d < 0 | d > 9) { return 0; }
        bs = bs * 10 + d;
    }

    store64(bs_ptr, bs);
    store64(h1_ptr, str_substr(digest, colon1 + 1, colon2 - colon1 - 1));
    store64(h2_ptr, str_substr(digest, colon2 + 1, dlen - colon2 - 1));
    return 1;
}

# Score two hash strings using weighted edit distance
fn score_strings(a, b, block_size) {
    if (str_len(a) == 0 | str_len(b) == 0) { return 0; }

    var ae = eliminate_sequences(a);
    var be = eliminate_sequences(b);

    if (str_len(ae) == 0 | str_len(be) == 0) { return 0; }

    var dist = edit_distance(str_data(ae), str_len(ae), str_data(be), str_len(be));
    var max_len = str_len(ae);
    if (str_len(be) > max_len) { max_len = str_len(be); }

    if (dist >= max_len) { return 0; }

    var score = (max_len - dist) * 100 / max_len;

    # Adjust by block size (log2 approximation)
    var bs_log = 0;
    var tmp_bs = block_size;
    while (tmp_bs > 1) {
        bs_log = bs_log + 1;
        tmp_bs = tmp_bs >> 1;
    }
    if (bs_log < 1) { bs_log = 1; }
    if (bs_log > score) { bs_log = score; }
    score = score - bs_log;
    if (score > 100) { score = 100; }

    return score;
}

# Compare two ssdeep hashes and return a similarity score (0-100)
# Returns -1 if block sizes are incompatible
fn ssdeep_compare(a, b) {
    var a_bs_ptr = alloc(8);
    var a_h1_ptr = alloc(8);
    var a_h2_ptr = alloc(8);
    var b_bs_ptr = alloc(8);
    var b_h1_ptr = alloc(8);
    var b_h2_ptr = alloc(8);

    if (!parse_ssdeep_digest(a.digest, a_bs_ptr, a_h1_ptr, a_h2_ptr)) { return -1; }
    if (!parse_ssdeep_digest(b.digest, b_bs_ptr, b_h1_ptr, b_h2_ptr)) { return -1; }

    var a_bs = load64(a_bs_ptr);
    var a_h1 = load64(a_h1_ptr);
    var a_h2 = load64(a_h2_ptr);
    var b_bs = load64(b_bs_ptr);
    var b_h1 = load64(b_h1_ptr);
    var b_h2 = load64(b_h2_ptr);

    if (a_bs == b_bs) {
        var s1 = score_strings(a_h1, b_h1, a_bs);
        var s2 = score_strings(a_h2, b_h2, a_bs * 2);
        if (s1 > s2) { return s1; }
        return s2;
    } elif (a_bs == b_bs * 2) {
        return score_strings(a_h2, b_h1, a_bs);
    } elif (b_bs == a_bs * 2) {
        return score_strings(b_h2, a_h1, b_bs);
    }

    return -1;  # incompatible block sizes
}

# ================================================================
# TLSH — Trend Micro Locality Sensitive Hash
# ================================================================

var TLSH_NUM_BUCKETS = 256;
var TLSH_WINDOW_SIZE = 5;
var TLSH_MIN_DATA_LEN = 50;

# Pearson hash table (random permutation of 0..255)
# Stored as a 256-byte raw buffer, allocated once
var PEARSON_TABLE_PTR = 0;

fn init_pearson_table() {
    PEARSON_TABLE_PTR = alloc(256);
    var t = PEARSON_TABLE_PTR;
    # The exact values from the Rust source
    store8(t + 0, 1);     store8(t + 1, 87);    store8(t + 2, 49);    store8(t + 3, 12);
    store8(t + 4, 176);   store8(t + 5, 178);   store8(t + 6, 102);   store8(t + 7, 166);
    store8(t + 8, 121);   store8(t + 9, 193);   store8(t + 10, 6);    store8(t + 11, 84);
    store8(t + 12, 249);  store8(t + 13, 230);  store8(t + 14, 44);   store8(t + 15, 163);
    store8(t + 16, 14);   store8(t + 17, 197);  store8(t + 18, 213);  store8(t + 19, 181);
    store8(t + 20, 161);  store8(t + 21, 85);   store8(t + 22, 218);  store8(t + 23, 80);
    store8(t + 24, 64);   store8(t + 25, 239);  store8(t + 26, 24);   store8(t + 27, 226);
    store8(t + 28, 236);  store8(t + 29, 142);  store8(t + 30, 38);   store8(t + 31, 200);
    store8(t + 32, 110);  store8(t + 33, 177);  store8(t + 34, 104);  store8(t + 35, 103);
    store8(t + 36, 141);  store8(t + 37, 253);  store8(t + 38, 255);  store8(t + 39, 50);
    store8(t + 40, 77);   store8(t + 41, 101);  store8(t + 42, 81);   store8(t + 43, 18);
    store8(t + 44, 45);   store8(t + 45, 96);   store8(t + 46, 31);   store8(t + 47, 156);
    store8(t + 48, 11);   store8(t + 49, 26);   store8(t + 50, 17);   store8(t + 51, 201);
    store8(t + 52, 185);  store8(t + 53, 232);  store8(t + 54, 135);  store8(t + 55, 98);
    store8(t + 56, 89);   store8(t + 57, 131);  store8(t + 58, 122);  store8(t + 59, 211);
    store8(t + 60, 46);   store8(t + 61, 206);  store8(t + 62, 52);   store8(t + 63, 188);
    store8(t + 64, 57);   store8(t + 65, 83);   store8(t + 66, 53);   store8(t + 67, 241);
    store8(t + 68, 144);  store8(t + 69, 172);  store8(t + 70, 115);  store8(t + 71, 55);
    store8(t + 72, 70);   store8(t + 73, 118);  store8(t + 74, 71);   store8(t + 75, 240);
    store8(t + 76, 228);  store8(t + 77, 234);  store8(t + 78, 97);   store8(t + 79, 137);
    store8(t + 80, 9);    store8(t + 81, 125);  store8(t + 82, 207);  store8(t + 83, 109);
    store8(t + 84, 237);  store8(t + 85, 0);    store8(t + 86, 60);   store8(t + 87, 247);
    store8(t + 88, 220);  store8(t + 89, 136);  store8(t + 90, 233);  store8(t + 91, 58);
    store8(t + 92, 40);   store8(t + 93, 127);  store8(t + 94, 119);  store8(t + 95, 195);
    store8(t + 96, 243);  store8(t + 97, 153);  store8(t + 98, 37);   store8(t + 99, 155);
    store8(t + 100, 32);  store8(t + 101, 246); store8(t + 102, 245); store8(t + 103, 165);
    store8(t + 104, 254); store8(t + 105, 61);  store8(t + 106, 138); store8(t + 107, 124);
    store8(t + 108, 221); store8(t + 109, 147); store8(t + 110, 132); store8(t + 111, 4);
    store8(t + 112, 2);   store8(t + 113, 34);  store8(t + 114, 116); store8(t + 115, 190);
    store8(t + 116, 170); store8(t + 117, 105); store8(t + 118, 90);  store8(t + 119, 100);
    store8(t + 120, 205); store8(t + 121, 202); store8(t + 122, 117); store8(t + 123, 95);
    store8(t + 124, 54);  store8(t + 125, 93);  store8(t + 126, 16);  store8(t + 127, 76);
    store8(t + 128, 92);  store8(t + 129, 248); store8(t + 130, 123); store8(t + 131, 111);
    store8(t + 132, 219); store8(t + 133, 146); store8(t + 134, 27);  store8(t + 135, 15);
    store8(t + 136, 171); store8(t + 137, 244); store8(t + 138, 183); store8(t + 139, 222);
    store8(t + 140, 157); store8(t + 141, 187); store8(t + 142, 175); store8(t + 143, 250);
    store8(t + 144, 214); store8(t + 145, 198); store8(t + 146, 73);  store8(t + 147, 160);
    store8(t + 148, 59);  store8(t + 149, 78);  store8(t + 150, 174); store8(t + 151, 203);
    store8(t + 152, 99);  store8(t + 153, 143); store8(t + 154, 215); store8(t + 155, 108);
    store8(t + 156, 189); store8(t + 157, 180); store8(t + 158, 79);  store8(t + 159, 196);
    store8(t + 160, 204); store8(t + 161, 112); store8(t + 162, 120); store8(t + 163, 167);
    store8(t + 164, 199); store8(t + 165, 139); store8(t + 166, 162); store8(t + 167, 47);
    store8(t + 168, 148); store8(t + 169, 152); store8(t + 170, 33);  store8(t + 171, 3);
    store8(t + 172, 5);   store8(t + 173, 128); store8(t + 174, 154); store8(t + 175, 10);
    store8(t + 176, 22);  store8(t + 177, 39);  store8(t + 178, 56);  store8(t + 179, 75);
    store8(t + 180, 223); store8(t + 181, 62);  store8(t + 182, 36);  store8(t + 183, 106);
    store8(t + 184, 67);  store8(t + 185, 91);  store8(t + 186, 191); store8(t + 187, 126);
    store8(t + 188, 113); store8(t + 189, 13);  store8(t + 190, 216); store8(t + 191, 238);
    store8(t + 192, 7);   store8(t + 193, 169); store8(t + 194, 68);  store8(t + 195, 145);
    store8(t + 196, 184); store8(t + 197, 186); store8(t + 198, 43);  store8(t + 199, 114);
    store8(t + 200, 242); store8(t + 201, 235); store8(t + 202, 251); store8(t + 203, 23);
    store8(t + 204, 28);  store8(t + 205, 130); store8(t + 206, 133); store8(t + 207, 168);
    store8(t + 208, 150); store8(t + 209, 66);  store8(t + 210, 158); store8(t + 211, 48);
    store8(t + 212, 173); store8(t + 213, 133); store8(t + 214, 107); store8(t + 215, 164);
    store8(t + 216, 182); store8(t + 217, 149); store8(t + 218, 30);  store8(t + 219, 41);
    store8(t + 220, 82);  store8(t + 221, 35);  store8(t + 222, 63);  store8(t + 223, 225);
    store8(t + 224, 252); store8(t + 225, 74);  store8(t + 226, 227); store8(t + 227, 208);
    store8(t + 228, 140); store8(t + 229, 65);  store8(t + 230, 229); store8(t + 231, 69);
    store8(t + 232, 8);   store8(t + 233, 129); store8(t + 234, 94);  store8(t + 235, 134);
    store8(t + 236, 231); store8(t + 237, 86);  store8(t + 238, 21);  store8(t + 239, 42);
    store8(t + 240, 25);  store8(t + 241, 20);  store8(t + 242, 159); store8(t + 243, 51);
    store8(t + 244, 88);  store8(t + 245, 179); store8(t + 246, 194); store8(t + 247, 29);
    store8(t + 248, 19);  store8(t + 249, 192); store8(t + 250, 72);  store8(t + 251, 217);
    store8(t + 252, 210); store8(t + 253, 151); store8(t + 254, 209); store8(t + 255, 0);
}

fn pearson_lookup(idx) {
    return load8(PEARSON_TABLE_PTR + (idx & 255));
}

# Pearson hash of 3 values: table[table[a ^ b] ^ c]
fn pearson_hash2(a, b, c) {
    return pearson_lookup(pearson_lookup(a ^ b) ^ c);
}

# Log-based length encoding to 8 bits
fn tlsh_length_encode(len) {
    if (len == 0) { return 0; }
    # Approximate log2(len) * 8 using integer arithmetic
    var log2 = 0;
    var tmp = len;
    while (tmp > 1) {
        log2 = log2 + 1;
        tmp = tmp >> 1;
    }
    # Fractional part approximation: use f64
    var flen = f64_from_int(len);
    var flog = f64_log2(flen);
    var result = f64_to_int(f64_mul(flog, f64_from_int(8)));
    if (result > 255) { result = 255; }
    if (result < 0) { result = 0; }
    return result;
}

fn tlsh_diff_byte(a, b) {
    var d = a - b;
    if (d < 0) { d = 0 - d; }
    return d;
}

fn tlsh_diff_nibble(a, b) {
    var lo_a = a & 15;
    var lo_b = b & 15;
    var hi_a = (a >> 4) & 15;
    var hi_b = (b >> 4) & 15;
    var lo_diff = lo_a - lo_b;
    if (lo_diff < 0) { lo_diff = 0 - lo_diff; }
    var hi_diff = hi_a - hi_b;
    if (hi_diff < 0) { hi_diff = 0 - hi_diff; }
    return lo_diff + hi_diff;
}

# Compute the TLSH hash of a byte slice
# Returns TlshHash ptr, or 0 if data is too short or insufficient variance
fn tlsh_hash(data, len) {
    if (len < TLSH_MIN_DATA_LEN) { return 0; }

    # Ensure Pearson table is initialized
    if (PEARSON_TABLE_PTR == 0) { init_pearson_table(); }

    # Step 1: Fill buckets using sliding window Pearson hash
    var buckets = alloc(TLSH_NUM_BUCKETS * 8);
    for (var i = 0; i < TLSH_NUM_BUCKETS; i = i + 1) {
        store64(buckets + i * 8, 0);
    }
    var checksum = 0;

    if (len >= TLSH_WINDOW_SIZE) {
        for (var i = TLSH_WINDOW_SIZE - 1; i < len; i = i + 1) {
            # Window: data[i+1-WINDOW_SIZE .. i]
            var w0 = load8(data + i + 1 - TLSH_WINDOW_SIZE);
            var w1 = load8(data + i + 2 - TLSH_WINDOW_SIZE);
            var w2 = load8(data + i + 3 - TLSH_WINDOW_SIZE);
            var w3 = load8(data + i + 4 - TLSH_WINDOW_SIZE);
            var w4 = load8(data + i);

            # Update checksum
            checksum = pearson_lookup(checksum ^ w0);

            # Hash triplets into bucket indices
            var h1 = pearson_hash2(w0, w1, w2);
            var h2 = pearson_hash2(w0, w1, w3);
            var h3 = pearson_hash2(w0, w2, w3);
            var h4 = pearson_hash2(w0, w1, w4);
            var h5 = pearson_hash2(w0, w2, w4);
            var h6 = pearson_hash2(w0, w3, w4);

            store64(buckets + h1 * 8, load64(buckets + h1 * 8) + 1);
            store64(buckets + h2 * 8, load64(buckets + h2 * 8) + 1);
            store64(buckets + h3 * 8, load64(buckets + h3 * 8) + 1);
            store64(buckets + h4 * 8, load64(buckets + h4 * 8) + 1);
            store64(buckets + h5 * 8, load64(buckets + h5 * 8) + 1);
            store64(buckets + h6 * 8, load64(buckets + h6 * 8) + 1);
        }
    }

    # Step 2: Compute quartile boundaries
    # Collect non-zero bucket values and sort
    var sorted = vec_new();
    for (var i = 0; i < TLSH_NUM_BUCKETS; i = i + 1) {
        var val = load64(buckets + i * 8);
        if (val > 0) { vec_push(sorted, val); }
    }
    var slen = vec_len(sorted);
    if (slen < 4) { return 0; }  # insufficient variance

    # Insertion sort (N <= 256, fast enough)
    for (var i = 1; i < slen; i = i + 1) {
        var key = vec_get(sorted, i);
        var j = i - 1;
        while (j >= 0) {
            if (vec_get(sorted, j) <= key) {
                j = -1;  # break
            } else {
                vec_set(sorted, j + 1, vec_get(sorted, j));
                j = j - 1;
            }
        }
        if (j == -1) {
            vec_set(sorted, 0, key);
        } else {
            vec_set(sorted, j + 1, key);
        }
    }

    var q1 = vec_get(sorted, slen / 4);
    var q2 = vec_get(sorted, slen / 2);
    var q3 = vec_get(sorted, slen * 3 / 4);

    # Step 3: Encode buckets as 2-bit quartile values (4 buckets per byte)
    var body_len = TLSH_NUM_BUCKETS / 4;  # 64 bytes
    var body = alloc(body_len);
    for (var i = 0; i < body_len; i = i + 1) {
        store8(body + i, 0);
    }

    for (var i = 0; i < TLSH_NUM_BUCKETS; i = i + 1) {
        var bval = load64(buckets + i * 8);
        var code = 0;
        if (bval > q1) { code = 1; }
        if (bval > q2) { code = 2; }
        if (bval > q3) { code = 3; }
        var byte_idx = i / 4;
        var bit_shift = (i & 3) * 2;
        var old_byte = load8(body + byte_idx);
        store8(body + byte_idx, old_byte | (code << bit_shift));
    }

    # Step 4: Encode header
    var lvalue = tlsh_length_encode(len);
    var q1_ratio = 0;
    if (q2 > 0) { q1_ratio = (q1 * 100) / q2; }
    if (q1_ratio > 15) { q1_ratio = 15; }
    var q2_ratio = 0;
    if (q3 > 0) { q2_ratio = (q2 * 100) / q3; }
    if (q2_ratio > 15) { q2_ratio = 15; }

    # Step 5: Build hex digest: "T1" + checksum(2) + length(2) + qratios(2) + body(128)
    # Total: 2 + 2 + 2 + 2 + 128 = 136 chars
    var dlen_total = 2 + 2 + 2 + 2 + body_len * 2;
    var dbuf = alloc(dlen_total + 1);
    store8(dbuf, 84);       # 'T'
    store8(dbuf + 1, 49);   # '1'
    var pos = 2;

    # Checksum (2 hex chars)
    store8(dbuf + pos, hex_nibble((checksum >> 4) & 15));
    store8(dbuf + pos + 1, hex_nibble(checksum & 15));
    pos = pos + 2;

    # Length (2 hex chars)
    store8(dbuf + pos, hex_nibble((lvalue >> 4) & 15));
    store8(dbuf + pos + 1, hex_nibble(lvalue & 15));
    pos = pos + 2;

    # Q-ratios (1 hex nibble each = 2 chars)
    store8(dbuf + pos, hex_nibble(q1_ratio & 15));
    store8(dbuf + pos + 1, hex_nibble(q2_ratio & 15));
    pos = pos + 2;

    # Body (64 bytes = 128 hex chars)
    for (var i = 0; i < body_len; i = i + 1) {
        var b = load8(body + i);
        store8(dbuf + pos, hex_nibble((b >> 4) & 15));
        store8(dbuf + pos + 1, hex_nibble(b & 15));
        pos = pos + 2;
    }

    store8(dbuf + pos, 0);  # null terminator

    var result = TlshHash {};
    result.digest = str_from_raw(dbuf, pos);
    return result;
}

# Compute the TLSH distance between two hashes (lower = more similar)
# Returns -1 if either hash is invalid
fn tlsh_distance(a, b) {
    var a_dig = a.digest;
    var b_dig = b.digest;
    var a_len = str_len(a_dig);
    var b_len = str_len(b_dig);

    if (a_len != b_len) { return -1; }

    # Check T1 prefix
    var a_data = str_data(a_dig);
    var b_data = str_data(b_dig);
    if (load8(a_data) != 84 | load8(a_data + 1) != 49) { return -1; }
    if (load8(b_data) != 84 | load8(b_data + 1) != 49) { return -1; }

    # Decode hex bytes after "T1" prefix
    var hex_a = str_substr(a_dig, 2, a_len - 2);
    var hex_b = str_substr(b_dig, 2, b_len - 2);
    var alen_ptr = alloc(8);
    var blen_ptr = alloc(8);
    var a_bytes = hex_decode(hex_a, alen_ptr);
    var b_bytes = hex_decode(hex_b, blen_ptr);
    if (a_bytes == 0 | b_bytes == 0) { return -1; }
    var ablen = load64(alen_ptr);
    var bblen = load64(blen_ptr);
    if (ablen != bblen | ablen < 3) { return -1; }

    var dist = 0;

    # Header distance
    dist = dist + tlsh_diff_byte(load8(a_bytes), load8(b_bytes));           # checksum
    dist = dist + tlsh_diff_byte(load8(a_bytes + 1), load8(b_bytes + 1));   # length
    dist = dist + tlsh_diff_nibble(load8(a_bytes + 2), load8(b_bytes + 2)); # q-ratio

    # Body distance (hamming-like on quartile codes)
    for (var i = 3; i < ablen; i = i + 1) {
        var ab = load8(a_bytes + i);
        var bb = load8(b_bytes + i);
        for (var shift = 0; shift < 8; shift = shift + 2) {
            var qa = (ab >> shift) & 3;
            var qb = (bb >> shift) & 3;
            var d = qa - qb;
            if (d < 0) { d = 0 - d; }
            if (d == 3) { d = 6; }
            dist = dist + d;
        }
    }

    return dist;
}

# ================================================================
# Initialization helper
# ================================================================

fn phylax_init() {
    alloc_init();
    init_pearson_table();
}

# ================================================================
# ================================================================
#
#   PART 2 — PE Parser, ELF Parser, YARA Engine
#
# ================================================================
# ================================================================


# ================================================================
# PE Parser — Constants
# ================================================================

var PE_MAGIC_MZ = 0x5A4D;  # "MZ"

# Machine types
var PE_MACHINE_UNKNOWN = 0;
var PE_MACHINE_I386    = 0x014c;
var PE_MACHINE_AMD64   = 0x8664;
var PE_MACHINE_ARM     = 0x01c0;
var PE_MACHINE_ARM64   = 0xAA64;
var PE_MACHINE_IA64    = 0x0200;
var PE_MACHINE_RISCV32 = 0x5032;
var PE_MACHINE_RISCV64 = 0x5064;

# Optional header magic
var PE_OPT_MAGIC_32  = 0x10b;
var PE_OPT_MAGIC_64  = 0x20b;

# Section characteristics flags
var PE_SCN_CNT_CODE            = 0x00000020;
var PE_SCN_MEM_EXECUTE         = 0x20000000;
var PE_SCN_MEM_READ            = 0x40000000;
var PE_SCN_MEM_WRITE           = 0x80000000;

# Data directory indices
var PE_DIR_EXPORT    = 0;
var PE_DIR_IMPORT    = 1;
var PE_DIR_RESOURCE  = 2;
var PE_DIR_SECURITY  = 4;
var PE_DIR_DEBUG     = 6;
var PE_DIR_TLS       = 9;

# DLL characteristics
var PE_IMAGE_DLL = 0x2000;

# Limits
var PE_MAX_SECTIONS = 96;
var PE_MAX_IMPORTS  = 256;
var PE_MAX_EXPORTS  = 1024;

# Rich header sentinel
var PE_RICH_SIGNATURE = 0x68636952;  # "Rich"
var PE_DANS_SIGNATURE = 0x536E6144;  # "DanS"

# Debug types
var PE_DEBUG_TYPE_CODEVIEW = 2;
var PE_CODEVIEW_RSDS       = 0x53445352;  # "RSDS"

# ================================================================
# PE Parser — Read helpers
# ================================================================

# Read little-endian u16 from raw byte buffer
fn read_u16_le(data, offset) {
    return load8(data + offset) | (load8(data + offset + 1) << 8);
}

# Read little-endian u32 from raw byte buffer
fn read_u32_le(data, offset) {
    return load8(data + offset)
         | (load8(data + offset + 1) << 8)
         | (load8(data + offset + 2) << 16)
         | (load8(data + offset + 3) << 24);
}

# Read little-endian u64 from raw byte buffer
fn read_u64_le(data, offset) {
    var lo = read_u32_le(data, offset);
    var hi = read_u32_le(data, offset + 4);
    return lo | (hi << 32);
}

# Read null-terminated ASCII string, up to max_len bytes
fn read_ascii(data, offset, max_len) {
    var buf = alloc(max_len + 1);
    var i = 0;
    while (i < max_len) {
        var ch = load8(data + offset + i);
        if (ch == 0) { i = max_len; }  # break
        else {
            store8(buf + i, ch);
            i = i + 1;
        }
    }
    # Re-scan for actual length (since we jump i on break)
    var len = 0;
    while (len < max_len) {
        if (load8(data + offset + len) == 0) { len = max_len + 1; }  # break
        else { len = len + 1; }
    }
    if (len > max_len) { len = len - max_len - 1 + max_len; }
    # Simpler: just count from buf
    var actual = 0;
    while (actual < max_len) {
        if (load8(data + offset + actual) == 0) {
            return str_from_raw(buf, actual);
        }
        store8(buf + actual, load8(data + offset + actual));
        actual = actual + 1;
    }
    return str_from_raw(buf, max_len);
}

# Read a fixed-length ASCII string (e.g. section name, 8 bytes)
fn read_fixed_ascii(data, offset, len) {
    var buf = alloc(len + 1);
    var actual = 0;
    for (var i = 0; i < len; i = i + 1) {
        var ch = load8(data + offset + i);
        if (ch == 0) { i = len; }  # break
        else {
            store8(buf + actual, ch);
            actual = actual + 1;
        }
    }
    return str_from_raw(buf, actual);
}

# ================================================================
# PE Parser — Structs
# ================================================================

struct PeSection {
    name;             # Str
    virtual_size;     # i64
    virtual_address;  # i64
    raw_data_size;    # i64
    raw_data_offset;  # i64
    characteristics;  # i64
}

fn pe_section_new() {
    var s = PeSection {};
    s.name = str_from("");
    s.virtual_size = 0;
    s.virtual_address = 0;
    s.raw_data_size = 0;
    s.raw_data_offset = 0;
    s.characteristics = 0;
    return s;
}

fn pe_section_is_executable(sec) {
    return (sec.characteristics & PE_SCN_MEM_EXECUTE) != 0;
}

fn pe_section_is_writable(sec) {
    return (sec.characteristics & PE_SCN_MEM_WRITE) != 0;
}

fn pe_section_contains_code(sec) {
    return (sec.characteristics & PE_SCN_CNT_CODE) != 0;
}

struct PeImport {
    dll;       # Str — DLL name
    function;  # Str — function name
}

fn pe_import_new(dll, func) {
    var imp = PeImport {};
    imp.dll = dll;
    imp.function = func;
    return imp;
}

struct PeRichEntry {
    comp_id;    # i64 — compiler/tool ID
    build_id;   # i64 — build number
    use_count;  # i64 — usage count
}

fn pe_rich_entry_new(comp_id, build_id, use_count) {
    var e = PeRichEntry {};
    e.comp_id = comp_id;
    e.build_id = build_id;
    e.use_count = use_count;
    return e;
}

struct PeResource {
    res_type; # i64 — resource type ID
    name;     # Str
    size;     # i64
    offset;   # i64
}

fn pe_resource_new() {
    var r = PeResource {};
    r.res_type = 0;
    r.name = str_from("");
    r.size = 0;
    r.offset = 0;
    return r;
}

struct PeCertificate {
    present;  # i64 (0/1)
    offset;   # i64
    size;     # i64
}

fn pe_certificate_new() {
    var c = PeCertificate {};
    c.present = 0;
    c.offset = 0;
    c.size = 0;
    return c;
}

struct PeInfo {
    machine;           # i64 — machine type
    num_sections;      # i64
    timestamp;         # i64
    is_dll;            # i64 (0/1)
    is_64bit;          # i64 (0/1)
    entry_point;       # i64 — address of entry point
    image_base;        # i64
    sections;          # Vec of PeSection
    imports;           # Vec of PeImport (dll-level)
    import_functions;  # Vec of PeImport (function-level)
    exports;           # Vec of Str
    has_tls_callbacks; # i64 (0/1)
    pdb_path;          # Str or 0
    rich_entries;      # Vec of PeRichEntry
    resources;         # Vec of PeResource
    certificate;       # PeCertificate
    opt_offset;        # i64 — offset of optional header
    size_of_opt;       # i64 — size of optional header
}

fn pe_info_new() {
    var p = PeInfo {};
    p.machine = 0;
    p.num_sections = 0;
    p.timestamp = 0;
    p.is_dll = 0;
    p.is_64bit = 0;
    p.entry_point = 0;
    p.image_base = 0;
    p.sections = vec_new();
    p.imports = vec_new();
    p.import_functions = vec_new();
    p.exports = vec_new();
    p.has_tls_callbacks = 0;
    p.pdb_path = 0;
    p.rich_entries = vec_new();
    p.resources = vec_new();
    p.certificate = pe_certificate_new();
    p.opt_offset = 0;
    p.size_of_opt = 0;
    return p;
}

# ================================================================
# PE Parser — Machine name
# ================================================================

fn pe_machine_name(machine) {
    if (machine == PE_MACHINE_I386)    { return str_from("i386"); }
    if (machine == PE_MACHINE_AMD64)   { return str_from("AMD64"); }
    if (machine == PE_MACHINE_ARM)     { return str_from("ARM"); }
    if (machine == PE_MACHINE_ARM64)   { return str_from("ARM64"); }
    if (machine == PE_MACHINE_IA64)    { return str_from("IA64"); }
    if (machine == PE_MACHINE_RISCV32) { return str_from("RISC-V 32"); }
    if (machine == PE_MACHINE_RISCV64) { return str_from("RISC-V 64"); }
    return str_from("Unknown");
}

# ================================================================
# PE Parser — RVA to file offset
# ================================================================

# Convert a Relative Virtual Address to a raw file offset
# Uses the section table to find which section contains the RVA
fn rva_to_offset(pe, rva) {
    var nsec = vec_len(pe.sections);
    for (var i = 0; i < nsec; i = i + 1) {
        var sec = vec_get(pe.sections, i);
        var va = sec.virtual_address;
        var vs = sec.virtual_size;
        if (vs == 0) { vs = sec.raw_data_size; }
        if (rva >= va) {
            if (rva < va + vs) {
                return sec.raw_data_offset + (rva - va);
            }
        }
    }
    return -1;  # not found
}

# RVA to offset using raw data and section parsing (before PeInfo is built)
fn rva_to_offset_raw(data, data_len, pe_offset, num_sections, sec_table_offset, rva) {
    for (var i = 0; i < num_sections; i = i + 1) {
        var soff = sec_table_offset + i * 40;
        if (soff + 40 > data_len) { return -1; }
        var va = read_u32_le(data, soff + 12);
        var vs = read_u32_le(data, soff + 8);
        var raw_off = read_u32_le(data, soff + 20);
        if (vs == 0) { vs = read_u32_le(data, soff + 16); }
        if (rva >= va) {
            if (rva < va + vs) {
                return raw_off + (rva - va);
            }
        }
    }
    return -1;
}

# ================================================================
# PE Parser — Rich header
# ================================================================

fn parse_rich_header(data, data_len, pe_offset) {
    var entries = vec_new();
    # Rich header sits between DOS stub and PE signature
    # Search backward from pe_offset for "Rich" signature
    if (pe_offset < 16) { return entries; }

    var rich_pos = -1;
    var search_start = 128;  # Skip DOS header
    if (search_start > pe_offset - 8) { search_start = pe_offset - 8; }
    for (var i = pe_offset - 8; i >= search_start; i = i - 4) {
        if (read_u32_le(data, i) == PE_RICH_SIGNATURE) {
            rich_pos = i;
            i = search_start - 1;  # break
        }
    }
    if (rich_pos < 0) { return entries; }

    # XOR key is the dword right after "Rich"
    var xor_key = read_u32_le(data, rich_pos + 4);

    # Find "DanS" marker by decrypting backward
    var dans_pos = -1;
    for (var i = rich_pos - 4; i >= 0; i = i - 4) {
        var decrypted = read_u32_le(data, i) ^ xor_key;
        if (decrypted == PE_DANS_SIGNATURE) {
            dans_pos = i;
            i = -1;  # break
        }
    }
    if (dans_pos < 0) { return entries; }

    # Entries start after DanS + 3 padding dwords (all XOR key)
    var entry_start = dans_pos + 16;
    var pos = entry_start;
    while (pos + 8 <= rich_pos) {
        var raw1 = read_u32_le(data, pos) ^ xor_key;
        var raw2 = read_u32_le(data, pos + 4) ^ xor_key;
        var comp_id = (raw1 >> 16) & 0xFFFF;
        var build_id = raw1 & 0xFFFF;
        var use_count = raw2;
        if (comp_id != 0 | build_id != 0) {
            vec_push(entries, pe_rich_entry_new(comp_id, build_id, use_count));
        }
        pos = pos + 8;
    }
    return entries;
}

# ================================================================
# PE Parser — Import parsing
# ================================================================

fn parse_pe_imports(data, data_len, pe) {
    var imports = vec_new();
    var import_funcs = vec_new();

    # Locate import directory from optional header
    var opt_off = pe.opt_offset;
    var is_64 = pe.is_64bit;

    # Data directories start at different offsets for PE32 vs PE32+
    var dd_offset = 0;
    if (is_64) {
        dd_offset = opt_off + 112;  # PE32+: data dirs at offset 112
    } else {
        dd_offset = opt_off + 96;   # PE32: data dirs at offset 96
    }

    # Import directory is entry 1 (index 1)
    var import_dir_off = dd_offset + PE_DIR_IMPORT * 8;
    if (import_dir_off + 8 > data_len) { return imports; }
    var import_rva = read_u32_le(data, import_dir_off);
    var import_size = read_u32_le(data, import_dir_off + 4);
    if (import_rva == 0 | import_size == 0) { return imports; }

    var import_file_off = rva_to_offset(pe, import_rva);
    if (import_file_off < 0) { return imports; }

    # Each import descriptor is 20 bytes
    var count = 0;
    var pos = import_file_off;
    while (count < PE_MAX_IMPORTS) {
        if (pos + 20 > data_len) { count = PE_MAX_IMPORTS; }
        else {
            var ilt_rva  = read_u32_le(data, pos);       # Import Lookup Table RVA
            var name_rva = read_u32_le(data, pos + 12);   # DLL name RVA
            # Null descriptor terminates
            if (ilt_rva == 0) { if (name_rva == 0) { count = PE_MAX_IMPORTS; } }
            if (count < PE_MAX_IMPORTS) {
                if (name_rva != 0) {
                    var name_off = rva_to_offset(pe, name_rva);
                    var dll_name = str_from("unknown");
                    if (name_off >= 0) {
                        if (name_off < data_len) {
                            dll_name = read_ascii(data, name_off, 256);
                        }
                    }
                    vec_push(imports, pe_import_new(dll_name, str_from("")));

                    # Parse the Import Lookup Table for function names
                    if (ilt_rva != 0) {
                        var ilt_off = rva_to_offset(pe, ilt_rva);
                        if (ilt_off >= 0) {
                            var fcount = 0;
                            var fpos = ilt_off;
                            var entry_size = 4;
                            if (is_64) { entry_size = 8; }
                            while (fcount < 512) {
                                if (fpos + entry_size > data_len) { fcount = 512; }
                                else {
                                    var entry = 0;
                                    if (is_64) { entry = read_u64_le(data, fpos); }
                                    else { entry = read_u32_le(data, fpos); }
                                    if (entry == 0) { fcount = 512; }  # end
                                    else {
                                        # Check ordinal flag (high bit)
                                        var ordinal_flag = 0;
                                        if (is_64) { ordinal_flag = (entry >> 63) & 1; }
                                        else { ordinal_flag = (entry >> 31) & 1; }
                                        if (ordinal_flag == 0) {
                                            # Hint/Name entry
                                            var hint_rva = entry & 0x7FFFFFFF;
                                            var hint_off = rva_to_offset(pe, hint_rva);
                                            if (hint_off >= 0) {
                                                if (hint_off + 2 < data_len) {
                                                    var func_name = read_ascii(data, hint_off + 2, 256);
                                                    vec_push(import_funcs,
                                                        pe_import_new(dll_name, func_name));
                                                }
                                            }
                                        } else {
                                            # Ordinal import
                                            var ord = entry & 0xFFFF;
                                            var ord_name = str_cat(str_from("ord:"),
                                                           str_from_int(ord));
                                            vec_push(import_funcs,
                                                pe_import_new(dll_name, ord_name));
                                        }
                                        fcount = fcount + 1;
                                        fpos = fpos + entry_size;
                                    }
                                }
                            }
                        }
                    }
                }
                count = count + 1;
                pos = pos + 20;
            }
        }
    }

    # Store results into PeInfo
    pe.imports = imports;
    pe.import_functions = import_funcs;
    return imports;
}

# ================================================================
# PE Parser — Export parsing
# ================================================================

fn parse_pe_exports(data, data_len, pe) {
    var exports = vec_new();
    var opt_off = pe.opt_offset;
    var is_64 = pe.is_64bit;

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var export_dir_off = dd_offset + PE_DIR_EXPORT * 8;
    if (export_dir_off + 8 > data_len) { return exports; }
    var export_rva = read_u32_le(data, export_dir_off);
    var export_size = read_u32_le(data, export_dir_off + 4);
    if (export_rva == 0 | export_size == 0) { return exports; }

    var export_file_off = rva_to_offset(pe, export_rva);
    if (export_file_off < 0) { return exports; }
    if (export_file_off + 40 > data_len) { return exports; }

    # Export directory table
    var num_names = read_u32_le(data, export_file_off + 24);
    var name_ptr_rva = read_u32_le(data, export_file_off + 32);
    var name_ptr_off = rva_to_offset(pe, name_ptr_rva);
    if (name_ptr_off < 0) { return exports; }

    var limit = num_names;
    if (limit > PE_MAX_EXPORTS) { limit = PE_MAX_EXPORTS; }

    for (var i = 0; i < limit; i = i + 1) {
        var noff = name_ptr_off + i * 4;
        if (noff + 4 <= data_len) {
            var nrva = read_u32_le(data, noff);
            var str_off = rva_to_offset(pe, nrva);
            if (str_off >= 0) {
                if (str_off < data_len) {
                    var name = read_ascii(data, str_off, 256);
                    vec_push(exports, name);
                }
            }
        }
    }

    pe.exports = exports;
    return exports;
}

# ================================================================
# PE Parser — TLS callback detection
# ================================================================

fn detect_tls_callbacks(data, data_len, pe) {
    var opt_off = pe.opt_offset;
    var is_64 = pe.is_64bit;

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var tls_dir_off = dd_offset + PE_DIR_TLS * 8;
    if (tls_dir_off + 8 > data_len) { return 0; }
    var tls_rva = read_u32_le(data, tls_dir_off);
    if (tls_rva == 0) { return 0; }

    var tls_off = rva_to_offset(pe, tls_rva);
    if (tls_off < 0) { return 0; }

    # TLS directory: callbacks pointer is at offset 12 (PE32) or 24 (PE32+)
    var cb_va = 0;
    if (is_64) {
        if (tls_off + 32 > data_len) { return 0; }
        cb_va = read_u64_le(data, tls_off + 24);
    } else {
        if (tls_off + 16 > data_len) { return 0; }
        cb_va = read_u32_le(data, tls_off + 12);
    }

    if (cb_va != 0) {
        # Convert VA to RVA by subtracting image base
        var cb_rva = cb_va - pe.image_base;
        var cb_off = rva_to_offset(pe, cb_rva);
        if (cb_off >= 0) {
            if (cb_off + 4 <= data_len) {
                # Check if at least one callback pointer is non-zero
                var first = 0;
                if (is_64) { first = read_u64_le(data, cb_off); }
                else { first = read_u32_le(data, cb_off); }
                if (first != 0) {
                    pe.has_tls_callbacks = 1;
                    return 1;
                }
            }
        }
    }
    return 0;
}

# ================================================================
# PE Parser — Debug directory (PDB path extraction)
# ================================================================

fn parse_debug_directory(data, data_len, pe) {
    var opt_off = pe.opt_offset;
    var is_64 = pe.is_64bit;

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var debug_dir_off = dd_offset + PE_DIR_DEBUG * 8;
    if (debug_dir_off + 8 > data_len) { return 0; }
    var debug_rva = read_u32_le(data, debug_dir_off);
    var debug_size = read_u32_le(data, debug_dir_off + 4);
    if (debug_rva == 0 | debug_size == 0) { return 0; }

    var debug_off = rva_to_offset(pe, debug_rva);
    if (debug_off < 0) { return 0; }

    # Each debug directory entry is 28 bytes
    var num_entries = debug_size / 28;
    for (var i = 0; i < num_entries; i = i + 1) {
        var eoff = debug_off + i * 28;
        if (eoff + 28 > data_len) { return 0; }
        var dtype = read_u32_le(data, eoff + 12);
        if (dtype == PE_DEBUG_TYPE_CODEVIEW) {
            var dsize = read_u32_le(data, eoff + 16);
            var daddr = read_u32_le(data, eoff + 24);   # pointer to raw data
            if (daddr > 0) {
                if (daddr + 24 < data_len) {
                    var sig = read_u32_le(data, daddr);
                    if (sig == PE_CODEVIEW_RSDS) {
                        # RSDS: 4 sig + 16 GUID + 4 age = 24 bytes header
                        var pdb_off = daddr + 24;
                        if (pdb_off < data_len) {
                            var pdb = read_ascii(data, pdb_off, 260);
                            pe.pdb_path = pdb;
                            return 1;
                        }
                    }
                }
            }
        }
    }
    return 0;
}

# ================================================================
# PE Parser — Certificate / Authenticode
# ================================================================

fn parse_pe_certificate(data, data_len, pe) {
    var opt_off = pe.opt_offset;
    var is_64 = pe.is_64bit;

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var cert_dir_off = dd_offset + PE_DIR_SECURITY * 8;
    if (cert_dir_off + 8 > data_len) { return; }
    var cert_offset = read_u32_le(data, cert_dir_off);
    var cert_size = read_u32_le(data, cert_dir_off + 4);
    if (cert_offset > 0) {
        if (cert_size > 0) {
            pe.certificate.present = 1;
            pe.certificate.offset = cert_offset;
            pe.certificate.size = cert_size;
        }
    }
}

# ================================================================
# PE Parser — Sections
# ================================================================

fn parse_pe_sections(data, data_len, sec_table_offset, num_sections) {
    var sections = vec_new();
    var limit = num_sections;
    if (limit > PE_MAX_SECTIONS) { limit = PE_MAX_SECTIONS; }

    for (var i = 0; i < limit; i = i + 1) {
        var soff = sec_table_offset + i * 40;
        if (soff + 40 > data_len) { return sections; }

        var sec = pe_section_new();
        sec.name = read_fixed_ascii(data, soff, 8);
        sec.virtual_size = read_u32_le(data, soff + 8);
        sec.virtual_address = read_u32_le(data, soff + 12);
        sec.raw_data_size = read_u32_le(data, soff + 16);
        sec.raw_data_offset = read_u32_le(data, soff + 20);
        sec.characteristics = read_u32_le(data, soff + 36);
        vec_push(sections, sec);
    }
    return sections;
}

# ================================================================
# PE Parser — Import hash (imphash)
# ================================================================

# Compute MD5-based import hash (simplified — uses Pearson-like hash)
# Real imphash: lowercase "dll.function" concatenated, then MD5.
# We approximate with our string hashing since we lack MD5 in stdlib.
fn compute_imphash(import_funcs) {
    var n = vec_len(import_funcs);
    if (n == 0) { return str_from(""); }

    # Build the canonical import string: "dll.func,dll.func,..."
    var result = str_from("");
    for (var i = 0; i < n; i = i + 1) {
        var imp = vec_get(import_funcs, i);
        var dll = str_lower(imp.dll);
        var func = str_lower(imp.function);

        # Strip .dll extension if present
        var dlen = str_len(dll);
        if (dlen > 4) {
            var ddata = str_data(dll);
            if (load8(ddata + dlen - 4) == 46) {   # '.'
                if (load8(ddata + dlen - 3) == 100) {  # 'd'
                    if (load8(ddata + dlen - 2) == 108) {  # 'l'
                        if (load8(ddata + dlen - 1) == 108) {  # 'l'
                            dll = str_substr(dll, 0, dlen - 4);
                        }
                    }
                }
            }
        }

        var entry = str_cat(dll, str_cat(str_from("."), func));
        if (i > 0) {
            result = str_cat(result, str_cat(str_from(","), entry));
        } else {
            result = entry;
        }
    }

    # Hash the result string with our Pearson hash, encode as hex
    var rdata = str_data(result);
    var rlen = str_len(result);
    var hash_buf = alloc(16);  # 128-bit hash
    for (var h = 0; h < 16; h = h + 1) {
        var hval = h;
        for (var j = 0; j < rlen; j = j + 1) {
            var idx = (hval ^ load8(rdata + j)) & 0xFF;
            hval = pearson_lookup(idx);
        }
        store8(hash_buf + h, hval & 0xFF);
    }
    return hex_encode(hash_buf, 16);
}

# ================================================================
# PE Parser — Main parse function
# ================================================================

fn parse_pe(data, data_len) {
    # Validate minimum size and MZ signature
    if (data_len < 64) { return 0; }
    var mz = read_u16_le(data, 0);
    if (mz != PE_MAGIC_MZ) { return 0; }

    # e_lfanew: offset to PE signature at offset 0x3C
    var pe_offset = read_u32_le(data, 0x3C);
    if (pe_offset + 4 > data_len) { return 0; }

    # Verify PE\0\0 signature
    if (load8(data + pe_offset) != 80) { return 0; }      # 'P'
    if (load8(data + pe_offset + 1) != 69) { return 0; }  # 'E'
    if (load8(data + pe_offset + 2) != 0) { return 0; }
    if (load8(data + pe_offset + 3) != 0) { return 0; }

    var coff_offset = pe_offset + 4;
    if (coff_offset + 20 > data_len) { return 0; }

    var pe = pe_info_new();

    # COFF header fields
    pe.machine = read_u16_le(data, coff_offset);
    pe.num_sections = read_u16_le(data, coff_offset + 2);
    pe.timestamp = read_u32_le(data, coff_offset + 4);
    var size_of_opt_hdr = read_u16_le(data, coff_offset + 16);
    var characteristics = read_u16_le(data, coff_offset + 18);

    pe.is_dll = 0;
    if (characteristics & PE_IMAGE_DLL) { pe.is_dll = 1; }

    # Optional header
    var opt_offset = coff_offset + 20;
    pe.opt_offset = opt_offset;
    pe.size_of_opt = size_of_opt_hdr;
    if (opt_offset + 2 > data_len) { return 0; }
    var opt_magic = read_u16_le(data, opt_offset);

    if (opt_magic == PE_OPT_MAGIC_64) {
        pe.is_64bit = 1;
        if (opt_offset + 24 > data_len) { return 0; }
        pe.entry_point = read_u32_le(data, opt_offset + 16);
        pe.image_base = read_u64_le(data, opt_offset + 24);
    } else {
        if (opt_magic == PE_OPT_MAGIC_32) {
            pe.is_64bit = 0;
            if (opt_offset + 28 > data_len) { return 0; }
            pe.entry_point = read_u32_le(data, opt_offset + 16);
            pe.image_base = read_u32_le(data, opt_offset + 28);
        } else {
            return 0;  # Unknown optional header magic
        }
    }

    # Section table follows optional header
    var sec_table_offset = opt_offset + size_of_opt_hdr;
    pe.sections = parse_pe_sections(data, data_len, sec_table_offset, pe.num_sections);

    # Rich header (between DOS stub and PE signature)
    pe.rich_entries = parse_rich_header(data, data_len, pe_offset);

    # Imports, exports, TLS, debug, certificate
    parse_pe_imports(data, data_len, pe);
    parse_pe_exports(data, data_len, pe);
    detect_tls_callbacks(data, data_len, pe);
    parse_debug_directory(data, data_len, pe);
    parse_pe_certificate(data, data_len, pe);

    return pe;
}


# ================================================================
# ================================================================
# ELF Parser
# ================================================================
# ================================================================

# ================================================================
# ELF Parser — Constants
# ================================================================

# ELF magic: 0x7F 'E' 'L' 'F'
var ELF_MAGIC_0 = 0x7F;
var ELF_MAGIC_1 = 69;   # 'E'
var ELF_MAGIC_2 = 76;   # 'L'
var ELF_MAGIC_3 = 70;   # 'F'

# EI_CLASS
var ELF_CLASS_NONE = 0;
var ELF_CLASS_32   = 1;
var ELF_CLASS_64   = 2;

# EI_DATA (endianness)
var ELF_DATA_NONE = 0;
var ELF_DATA_LSB  = 1;  # little-endian
var ELF_DATA_MSB  = 2;  # big-endian

# EI_OSABI
var ELF_OSABI_NONE    = 0;
var ELF_OSABI_LINUX   = 3;
var ELF_OSABI_FREEBSD = 9;

# e_type
var ELF_ET_NONE = 0;
var ELF_ET_REL  = 1;
var ELF_ET_EXEC = 2;
var ELF_ET_DYN  = 3;
var ELF_ET_CORE = 4;

# e_machine
var ELF_EM_NONE    = 0;
var ELF_EM_386     = 3;
var ELF_EM_ARM     = 40;
var ELF_EM_X86_64  = 62;
var ELF_EM_AARCH64 = 183;
var ELF_EM_RISCV   = 243;

# Section types
var ELF_SHT_NULL     = 0;
var ELF_SHT_PROGBITS = 1;
var ELF_SHT_SYMTAB   = 2;
var ELF_SHT_STRTAB   = 3;
var ELF_SHT_DYNAMIC  = 6;
var ELF_SHT_NOTE     = 7;
var ELF_SHT_NOBITS   = 8;
var ELF_SHT_DYNSYM   = 11;

# Section flags
var ELF_SHF_WRITE     = 0x1;
var ELF_SHF_ALLOC     = 0x2;
var ELF_SHF_EXECINSTR = 0x4;

# Segment types
var ELF_PT_NULL    = 0;
var ELF_PT_LOAD    = 1;
var ELF_PT_DYNAMIC = 2;
var ELF_PT_INTERP  = 3;
var ELF_PT_NOTE    = 4;
var ELF_PT_PHDR    = 6;
var ELF_PT_GNU_EH_FRAME = 0x6474e550;
var ELF_PT_GNU_STACK    = 0x6474e551;
var ELF_PT_GNU_RELRO    = 0x6474e552;

# Segment flags
var ELF_PF_X = 0x1;  # Execute
var ELF_PF_W = 0x2;  # Write
var ELF_PF_R = 0x4;  # Read

# Dynamic tags
var ELF_DT_NULL   = 0;
var ELF_DT_NEEDED = 1;
var ELF_DT_STRTAB = 5;
var ELF_DT_STRSZ  = 10;

# Limits
var ELF_MAX_SECTIONS = 1024;
var ELF_MAX_SYMBOLS  = 4096;

# ================================================================
# ELF Parser — Endian-aware read helpers
# ================================================================

# Read u16 from data at offset, respecting endianness
# little_endian: 1 = LE, 0 = BE
fn elf_read_u16(data, offset, little_endian) {
    if (little_endian) {
        return load8(data + offset) | (load8(data + offset + 1) << 8);
    }
    return (load8(data + offset) << 8) | load8(data + offset + 1);
}

fn elf_read_u32(data, offset, little_endian) {
    if (little_endian) {
        return load8(data + offset)
             | (load8(data + offset + 1) << 8)
             | (load8(data + offset + 2) << 16)
             | (load8(data + offset + 3) << 24);
    }
    return (load8(data + offset) << 24)
         | (load8(data + offset + 1) << 16)
         | (load8(data + offset + 2) << 8)
         | load8(data + offset + 3);
}

fn elf_read_u64(data, offset, little_endian) {
    if (little_endian) {
        var lo = elf_read_u32(data, offset, 1);
        var hi = elf_read_u32(data, offset + 4, 1);
        return lo | (hi << 32);
    }
    var hi = elf_read_u32(data, offset, 0);
    var lo = elf_read_u32(data, offset + 4, 0);
    return (hi << 32) | lo;
}

# ================================================================
# ELF Parser — String table lookup
# ================================================================

# Read a null-terminated string from the string table
fn read_strtab_entry(data, data_len, strtab_offset, name_index) {
    var off = strtab_offset + name_index;
    if (off >= data_len) { return str_from(""); }
    var max = 256;
    if (off + max > data_len) { max = data_len - off; }
    return read_ascii(data, off, max);
}

# ================================================================
# ELF Parser — Structs
# ================================================================

struct ElfSection {
    name;          # Str
    section_type;  # i64
    flags;         # i64
    addr;          # i64
    offset;        # i64
    size;          # i64
}

fn elf_section_new() {
    var s = ElfSection {};
    s.name = str_from("");
    s.section_type = 0;
    s.flags = 0;
    s.addr = 0;
    s.offset = 0;
    s.size = 0;
    return s;
}

fn elf_section_is_executable(sec) {
    return (sec.flags & ELF_SHF_EXECINSTR) != 0;
}

fn elf_section_is_writable(sec) {
    return (sec.flags & ELF_SHF_WRITE) != 0;
}

struct ElfSegment {
    seg_type;   # i64
    flags;      # i64
    vaddr;      # i64
    offset;     # i64
    file_size;  # i64
    mem_size;   # i64
}

fn elf_segment_new() {
    var s = ElfSegment {};
    s.seg_type = 0;
    s.flags = 0;
    s.vaddr = 0;
    s.offset = 0;
    s.file_size = 0;
    s.mem_size = 0;
    return s;
}

struct ElfSecurity {
    has_relro;         # i64 (0/1)
    has_rwx_segment;   # i64 (0/1) — dangerous: read+write+execute
    is_static;         # i64 (0/1)
    executable_stack;  # i64 (0/1)
}

fn elf_security_new() {
    var s = ElfSecurity {};
    s.has_relro = 0;
    s.has_rwx_segment = 0;
    s.is_static = 1;  # assume static until we find PT_DYNAMIC
    s.executable_stack = 0;
    return s;
}

struct ElfInfo {
    class;         # i64 — ELF_CLASS_32 or ELF_CLASS_64
    endian;        # i64 — ELF_DATA_LSB or ELF_DATA_MSB
    os_abi;        # i64
    file_type;     # i64 — ET_EXEC, ET_DYN, etc.
    machine;       # i64
    entry_point;   # i64
    sections;      # Vec of ElfSection
    needed_libs;   # Vec of Str
    symbols;       # Vec of Str
    segments;      # Vec of ElfSegment
    interpreter;   # Str or 0
    security;      # ElfSecurity
}

fn elf_info_new() {
    var e = ElfInfo {};
    e.class = 0;
    e.endian = 0;
    e.os_abi = 0;
    e.file_type = 0;
    e.machine = 0;
    e.entry_point = 0;
    e.sections = vec_new();
    e.needed_libs = vec_new();
    e.symbols = vec_new();
    e.segments = vec_new();
    e.interpreter = 0;
    e.security = elf_security_new();
    return e;
}

# ================================================================
# ELF Parser — Machine name
# ================================================================

fn elf_machine_name(machine) {
    if (machine == ELF_EM_386)     { return str_from("i386"); }
    if (machine == ELF_EM_X86_64)  { return str_from("x86_64"); }
    if (machine == ELF_EM_ARM)     { return str_from("ARM"); }
    if (machine == ELF_EM_AARCH64) { return str_from("AArch64"); }
    if (machine == ELF_EM_RISCV)   { return str_from("RISC-V"); }
    return str_from("Unknown");
}

fn elf_type_name(t) {
    if (t == ELF_ET_REL)  { return str_from("Relocatable"); }
    if (t == ELF_ET_EXEC) { return str_from("Executable"); }
    if (t == ELF_ET_DYN)  { return str_from("Shared object"); }
    if (t == ELF_ET_CORE) { return str_from("Core dump"); }
    return str_from("Unknown");
}

# ================================================================
# ELF Parser — Program headers (segments)
# ================================================================

fn parse_program_headers(data, data_len, elf, ph_offset, ph_entry_size, ph_num) {
    var is64 = elf.class == ELF_CLASS_64;
    var le = elf.endian == ELF_DATA_LSB;

    for (var i = 0; i < ph_num; i = i + 1) {
        var off = ph_offset + i * ph_entry_size;
        if (off + ph_entry_size > data_len) { return; }

        var seg = elf_segment_new();
        seg.seg_type = elf_read_u32(data, off, le);

        if (is64) {
            seg.flags     = elf_read_u32(data, off + 4, le);
            seg.offset    = elf_read_u64(data, off + 8, le);
            seg.vaddr     = elf_read_u64(data, off + 16, le);
            seg.file_size = elf_read_u64(data, off + 32, le);
            seg.mem_size  = elf_read_u64(data, off + 40, le);
        } else {
            seg.offset    = elf_read_u32(data, off + 4, le);
            seg.vaddr     = elf_read_u32(data, off + 8, le);
            seg.file_size = elf_read_u32(data, off + 16, le);
            seg.mem_size  = elf_read_u32(data, off + 20, le);
            seg.flags     = elf_read_u32(data, off + 24, le);
        }

        vec_push(elf.segments, seg);

        # Extract interpreter string from PT_INTERP segment
        if (seg.seg_type == ELF_PT_INTERP) {
            if (seg.offset + seg.file_size <= data_len) {
                if (seg.file_size > 0) {
                    var interp_len = seg.file_size;
                    if (interp_len > 256) { interp_len = 256; }
                    elf.interpreter = read_ascii(data, seg.offset, interp_len);
                }
            }
        }

        # Security: detect GNU_RELRO
        if (seg.seg_type == ELF_PT_GNU_RELRO) {
            elf.security.has_relro = 1;
        }

        # Security: detect executable stack
        if (seg.seg_type == ELF_PT_GNU_STACK) {
            if (seg.flags & ELF_PF_X) {
                elf.security.executable_stack = 1;
            }
        }

        # Security: detect PT_DYNAMIC => not static
        if (seg.seg_type == ELF_PT_DYNAMIC) {
            elf.security.is_static = 0;
        }

        # Security: detect RWX segments
        if (seg.seg_type == ELF_PT_LOAD) {
            var rwx = ELF_PF_R | ELF_PF_W | ELF_PF_X;
            if ((seg.flags & rwx) == rwx) {
                elf.security.has_rwx_segment = 1;
            }
        }
    }
}

# ================================================================
# ELF Parser — Section headers
# ================================================================

fn parse_elf_sections(data, data_len, elf, sh_offset, sh_entry_size, sh_num, shstrndx) {
    var is64 = elf.class == ELF_CLASS_64;
    var le = elf.endian == ELF_DATA_LSB;

    # First, find the section header string table offset
    var shstrtab_offset = 0;
    if (shstrndx > 0) {
        if (shstrndx < sh_num) {
            var strtab_hdr = sh_offset + shstrndx * sh_entry_size;
            if (strtab_hdr + sh_entry_size <= data_len) {
                if (is64) {
                    shstrtab_offset = elf_read_u64(data, strtab_hdr + 24, le);
                } else {
                    shstrtab_offset = elf_read_u32(data, strtab_hdr + 16, le);
                }
            }
        }
    }

    var limit = sh_num;
    if (limit > ELF_MAX_SECTIONS) { limit = ELF_MAX_SECTIONS; }

    for (var i = 0; i < limit; i = i + 1) {
        var off = sh_offset + i * sh_entry_size;
        if (off + sh_entry_size > data_len) { return; }

        var sec = elf_section_new();
        var name_idx = elf_read_u32(data, off, le);
        sec.section_type = elf_read_u32(data, off + 4, le);

        if (is64) {
            sec.flags  = elf_read_u64(data, off + 8, le);
            sec.addr   = elf_read_u64(data, off + 16, le);
            sec.offset = elf_read_u64(data, off + 24, le);
            sec.size   = elf_read_u64(data, off + 32, le);
        } else {
            sec.flags  = elf_read_u32(data, off + 8, le);
            sec.addr   = elf_read_u32(data, off + 12, le);
            sec.offset = elf_read_u32(data, off + 16, le);
            sec.size   = elf_read_u32(data, off + 20, le);
        }

        # Resolve section name from string table
        if (shstrtab_offset > 0) {
            sec.name = read_strtab_entry(data, data_len, shstrtab_offset, name_idx);
        }

        vec_push(elf.sections, sec);
    }
}

# ================================================================
# ELF Parser — Dynamic section (DT_NEEDED libs)
# ================================================================

fn extract_needed_libs(data, data_len, elf) {
    var is64 = elf.class == ELF_CLASS_64;
    var le = elf.endian == ELF_DATA_LSB;

    # Find the .dynamic section (or PT_DYNAMIC segment)
    var dyn_offset = 0;
    var dyn_size = 0;

    # Try sections first
    var nsec = vec_len(elf.sections);
    for (var i = 0; i < nsec; i = i + 1) {
        var sec = vec_get(elf.sections, i);
        if (sec.section_type == ELF_SHT_DYNAMIC) {
            dyn_offset = sec.offset;
            dyn_size = sec.size;
            i = nsec;  # break
        }
    }

    # Fall back to segments if no .dynamic section
    if (dyn_offset == 0) {
        var nseg = vec_len(elf.segments);
        for (var i = 0; i < nseg; i = i + 1) {
            var seg = vec_get(elf.segments, i);
            if (seg.seg_type == ELF_PT_DYNAMIC) {
                dyn_offset = seg.offset;
                dyn_size = seg.file_size;
                i = nseg;  # break
            }
        }
    }

    if (dyn_offset == 0 | dyn_size == 0) { return; }

    # Find the dynamic string table (DT_STRTAB)
    var dynstr_offset = 0;
    var entry_size = 8;
    if (is64) { entry_size = 16; }

    # First pass: find DT_STRTAB
    var pos = dyn_offset;
    var end = dyn_offset + dyn_size;
    if (end > data_len) { end = data_len; }

    while (pos + entry_size <= end) {
        var tag = 0;
        var val = 0;
        if (is64) {
            tag = elf_read_u64(data, pos, le);
            val = elf_read_u64(data, pos + 8, le);
        } else {
            tag = elf_read_u32(data, pos, le);
            val = elf_read_u32(data, pos + 4, le);
        }
        if (tag == ELF_DT_NULL) { pos = end; }  # break
        else {
            if (tag == ELF_DT_STRTAB) {
                # val is a virtual address; try to find it in loaded sections
                # For files, try matching against section offsets
                var nsec2 = vec_len(elf.sections);
                for (var i = 0; i < nsec2; i = i + 1) {
                    var sec = vec_get(elf.sections, i);
                    if (sec.addr == val) {
                        dynstr_offset = sec.offset;
                        i = nsec2;  # break
                    }
                }
                # If that failed, try segments for VA-to-offset mapping
                if (dynstr_offset == 0) {
                    var nseg2 = vec_len(elf.segments);
                    for (var i = 0; i < nseg2; i = i + 1) {
                        var seg = vec_get(elf.segments, i);
                        if (seg.seg_type == ELF_PT_LOAD) {
                            if (val >= seg.vaddr) {
                                if (val < seg.vaddr + seg.file_size) {
                                    dynstr_offset = seg.offset + (val - seg.vaddr);
                                    i = nseg2;  # break
                                }
                            }
                        }
                    }
                }
                pos = end;  # break, we found strtab
            } else {
                pos = pos + entry_size;
            }
        }
    }

    if (dynstr_offset == 0) { return; }

    # Second pass: collect DT_NEEDED entries
    pos = dyn_offset;
    while (pos + entry_size <= end) {
        var tag = 0;
        var val = 0;
        if (is64) {
            tag = elf_read_u64(data, pos, le);
            val = elf_read_u64(data, pos + 8, le);
        } else {
            tag = elf_read_u32(data, pos, le);
            val = elf_read_u32(data, pos + 4, le);
        }
        if (tag == ELF_DT_NULL) { pos = end; }  # break
        else {
            if (tag == ELF_DT_NEEDED) {
                var lib_name = read_strtab_entry(data, data_len, dynstr_offset, val);
                vec_push(elf.needed_libs, lib_name);
            }
            pos = pos + entry_size;
        }
    }
}

# ================================================================
# ELF Parser — Symbol extraction
# ================================================================

fn extract_elf_symbols(data, data_len, elf) {
    var is64 = elf.class == ELF_CLASS_64;
    var le = elf.endian == ELF_DATA_LSB;

    # Find .dynsym and its linked string table
    var nsec = vec_len(elf.sections);
    for (var i = 0; i < nsec; i = i + 1) {
        var sec = vec_get(elf.sections, i);
        if (sec.section_type == ELF_SHT_DYNSYM | sec.section_type == ELF_SHT_SYMTAB) {
            # The linked string table index is stored in sh_link
            # We need to re-read sh_link from the raw section header
            # For simplicity, look for SHT_STRTAB sections
            var strtab_off = 0;
            for (var j = 0; j < nsec; j = j + 1) {
                var strsec = vec_get(elf.sections, j);
                if (strsec.section_type == ELF_SHT_STRTAB) {
                    if (j != 0) {  # Skip null section
                        # Use the first STRTAB that is not .shstrtab
                        if (!str_eq(strsec.name, str_from(".shstrtab"))) {
                            strtab_off = strsec.offset;
                            j = nsec;  # break
                        }
                    }
                }
            }
            if (strtab_off == 0) { return; }

            var entry_size = 16;  # ELF32 sym entry
            if (is64) { entry_size = 24; }  # ELF64 sym entry

            var num_syms = sec.size / entry_size;
            if (num_syms > ELF_MAX_SYMBOLS) { num_syms = ELF_MAX_SYMBOLS; }

            var sym_off = sec.offset;
            for (var k = 1; k < num_syms; k = k + 1) {  # skip index 0
                var soff = sym_off + k * entry_size;
                if (soff + entry_size > data_len) { k = num_syms; }  # break
                else {
                    var name_idx = elf_read_u32(data, soff, le);
                    if (name_idx > 0) {
                        var sym_name = read_strtab_entry(data, data_len, strtab_off, name_idx);
                        if (str_len(sym_name) > 0) {
                            vec_push(elf.symbols, sym_name);
                        }
                    }
                }
            }
            return;  # done after first symbol table
        }
    }
}

# ================================================================
# ELF Parser — Main parse function
# ================================================================

fn parse_elf(data, data_len) {
    # Validate minimum size and magic
    if (data_len < 52) { return 0; }  # Minimum ELF32 header
    if (load8(data) != ELF_MAGIC_0) { return 0; }
    if (load8(data + 1) != ELF_MAGIC_1) { return 0; }
    if (load8(data + 2) != ELF_MAGIC_2) { return 0; }
    if (load8(data + 3) != ELF_MAGIC_3) { return 0; }

    var elf = elf_info_new();

    # ELF identification
    elf.class  = load8(data + 4);
    elf.endian = load8(data + 5);
    elf.os_abi = load8(data + 7);

    var is64 = elf.class == ELF_CLASS_64;
    var le = elf.endian == ELF_DATA_LSB;

    if (is64) {
        if (data_len < 64) { return 0; }  # Minimum ELF64 header
    }

    # Header fields
    elf.file_type = elf_read_u16(data, 16, le);
    elf.machine   = elf_read_u16(data, 18, le);

    if (is64) {
        elf.entry_point = elf_read_u64(data, 24, le);
        var ph_offset     = elf_read_u64(data, 32, le);
        var sh_offset     = elf_read_u64(data, 40, le);
        var ph_entry_size = elf_read_u16(data, 54, le);
        var ph_num        = elf_read_u16(data, 56, le);
        var sh_entry_size = elf_read_u16(data, 58, le);
        var sh_num        = elf_read_u16(data, 60, le);
        var shstrndx      = elf_read_u16(data, 62, le);

        # Parse program headers (segments)
        if (ph_offset > 0) {
            if (ph_num > 0) {
                parse_program_headers(data, data_len, elf, ph_offset, ph_entry_size, ph_num);
            }
        }

        # Parse section headers
        if (sh_offset > 0) {
            if (sh_num > 0) {
                parse_elf_sections(data, data_len, elf, sh_offset, sh_entry_size, sh_num, shstrndx);
            }
        }
    } else {
        elf.entry_point = elf_read_u32(data, 24, le);
        var ph_offset     = elf_read_u32(data, 28, le);
        var sh_offset     = elf_read_u32(data, 32, le);
        var ph_entry_size = elf_read_u16(data, 42, le);
        var ph_num        = elf_read_u16(data, 44, le);
        var sh_entry_size = elf_read_u16(data, 46, le);
        var sh_num        = elf_read_u16(data, 48, le);
        var shstrndx      = elf_read_u16(data, 50, le);

        if (ph_offset > 0) {
            if (ph_num > 0) {
                parse_program_headers(data, data_len, elf, ph_offset, ph_entry_size, ph_num);
            }
        }

        if (sh_offset > 0) {
            if (sh_num > 0) {
                parse_elf_sections(data, data_len, elf, sh_offset, sh_entry_size, sh_num, shstrndx);
            }
        }
    }

    # Extract dynamic libraries and symbols
    extract_needed_libs(data, data_len, elf);
    extract_elf_symbols(data, data_len, elf);

    return elf;
}


# ================================================================
# ================================================================
# YARA Engine
# ================================================================
# ================================================================

# ================================================================
# YARA Engine — Constants
# ================================================================

# Pattern types
var YARA_PAT_LITERAL = 0;  # Literal byte sequence
var YARA_PAT_HEX     = 1;  # Hex byte string (e.g. { 4D 5A })
var YARA_PAT_REGEX   = 2;  # Simplified regex (literal search)
var YARA_PAT_STRING  = 3;  # ASCII string match

# Condition types
var YARA_COND_ALL        = 0;  # All patterns must match
var YARA_COND_ANY        = 1;  # Any pattern matches
var YARA_COND_AT_LEAST   = 2;  # At least N patterns match
var YARA_COND_EXPRESSION = 3;  # Complex boolean expression

# Expression node types (for condition tree)
var YARA_EXPR_AND       = 0;
var YARA_EXPR_OR        = 1;
var YARA_EXPR_NOT       = 2;
var YARA_EXPR_PAT_MATCH = 3;   # Pattern ID matched
var YARA_EXPR_PAT_AT    = 4;   # Pattern at specific offset
var YARA_EXPR_PAT_COUNT = 5;   # #pattern comparison
var YARA_EXPR_FILESIZE  = 6;   # filesize comparison
var YARA_EXPR_TRUE      = 7;
var YARA_EXPR_FALSE     = 8;
var YARA_EXPR_ALL_OF    = 9;   # all of them
var YARA_EXPR_ANY_OF    = 10;  # any of them
var YARA_EXPR_N_OF      = 11;  # N of them

# Comparison operators
var YARA_CMP_LT = 0;
var YARA_CMP_LE = 1;
var YARA_CMP_GT = 2;
var YARA_CMP_GE = 3;
var YARA_CMP_EQ = 4;
var YARA_CMP_NE = 5;

# Match limits
var YARA_MAX_MATCH_OFFSETS = 4096;

# ================================================================
# YARA Engine — Hex string parsing
# ================================================================

# Parse a hex string like "4D5A90" into a byte buffer
# Returns: ptr to bytes, sets *out_len
fn parse_hex_pattern(hex_str, out_len_ptr) {
    var sdata = str_data(hex_str);
    var slen = str_len(hex_str);

    # First pass: count non-space hex chars
    var hex_chars = 0;
    for (var i = 0; i < slen; i = i + 1) {
        var ch = load8(sdata + i);
        if (ch != 32) {  # skip spaces
            if (ch != 123) {  # skip '{'
                if (ch != 125) {  # skip '}'
                    hex_chars = hex_chars + 1;
                }
            }
        }
    }

    if (hex_chars == 0 | (hex_chars & 1) != 0) {
        store64(out_len_ptr, 0);
        return 0;
    }

    var byte_count = hex_chars / 2;
    var buf = alloc(byte_count);
    var bi = 0;
    var hi_nibble = -1;

    for (var i = 0; i < slen; i = i + 1) {
        var ch = load8(sdata + i);
        if (ch != 32) {
            if (ch != 123) {
                if (ch != 125) {
                    var val = hex_digit_value(ch);
                    if (val < 0) {
                        # Wildcard '?' — treat as 0
                        if (ch == 63) { val = 0; }
                        else {
                            store64(out_len_ptr, 0);
                            return 0;
                        }
                    }
                    if (hi_nibble < 0) {
                        hi_nibble = val;
                    } else {
                        store8(buf + bi, (hi_nibble << 4) | val);
                        bi = bi + 1;
                        hi_nibble = -1;
                    }
                }
            }
        }
    }

    store64(out_len_ptr, byte_count);
    return buf;
}

# ================================================================
# YARA Engine — Pattern struct
# ================================================================

struct YaraPattern {
    id;         # Str — pattern identifier ($a, $b, etc.)
    pat_type;   # i64 — YARA_PAT_*
    data;       # ptr to byte pattern (for literal/hex)
    data_len;   # i64
    text;       # Str — original text (for string patterns)
    nocase;     # i64 (0/1) — case-insensitive
}

fn yara_pattern_new(id, pat_type) {
    var p = YaraPattern {};
    p.id = id;
    p.pat_type = pat_type;
    p.data = 0;
    p.data_len = 0;
    p.text = str_from("");
    p.nocase = 0;
    return p;
}

# Create a pattern from a hex string like "4D 5A"
fn yara_pattern_from_hex(id, hex_str) {
    var p = yara_pattern_new(id, YARA_PAT_HEX);
    var len_ptr = alloc(8);
    var bytes = parse_hex_pattern(hex_str, len_ptr);
    p.data = bytes;
    p.data_len = load64(len_ptr);
    p.text = hex_str;
    return p;
}

# Create a pattern from an ASCII string
fn yara_pattern_from_string(id, text) {
    var p = yara_pattern_new(id, YARA_PAT_STRING);
    var sdata = str_data(text);
    var slen = str_len(text);
    var buf = alloc(slen);
    for (var i = 0; i < slen; i = i + 1) {
        store8(buf + i, load8(sdata + i));
    }
    p.data = buf;
    p.data_len = slen;
    p.text = text;
    return p;
}

# Create a pattern from raw bytes
fn yara_pattern_from_bytes(id, bytes, blen) {
    var p = yara_pattern_new(id, YARA_PAT_LITERAL);
    p.data = bytes;
    p.data_len = blen;
    return p;
}

# ================================================================
# YARA Engine — Pattern matching
# ================================================================

# Check if pattern matches anywhere in data
fn yara_pattern_matches(pat, data, data_len) {
    if (pat.data == 0 | pat.data_len == 0) { return 0; }
    if (pat.data_len > data_len) { return 0; }

    if (pat.nocase) {
        # Case-insensitive search
        var plen = pat.data_len;
        var limit = data_len - plen;
        for (var i = 0; i <= limit; i = i + 1) {
            var match = 1;
            for (var j = 0; j < plen; j = j + 1) {
                var a = load8(data + i + j);
                var b = load8(pat.data + j);
                # Lowercase both
                if (a >= 65) { if (a <= 90) { a = a + 32; } }
                if (b >= 65) { if (b <= 90) { b = b + 32; } }
                if (a != b) {
                    match = 0;
                    j = plen;  # break
                }
            }
            if (match) { return 1; }
        }
        return 0;
    }

    return memmem(data, data_len, pat.data, pat.data_len) >= 0;
}

# Find all offsets where pattern matches, capped at YARA_MAX_MATCH_OFFSETS
# Returns a vec of i64 offsets
fn yara_pattern_find_offsets(pat, data, data_len) {
    var offsets = vec_new();
    if (pat.data == 0 | pat.data_len == 0) { return offsets; }
    if (pat.data_len > data_len) { return offsets; }

    var plen = pat.data_len;
    var pos = 0;
    var count = 0;

    while (pos + plen <= data_len) {
        if (count >= YARA_MAX_MATCH_OFFSETS) { return offsets; }

        var found = -1;
        if (pat.nocase) {
            # Case-insensitive scan from pos
            var limit = data_len - plen;
            for (var i = pos; i <= limit; i = i + 1) {
                var match = 1;
                for (var j = 0; j < plen; j = j + 1) {
                    var a = load8(data + i + j);
                    var b = load8(pat.data + j);
                    if (a >= 65) { if (a <= 90) { a = a + 32; } }
                    if (b >= 65) { if (b <= 90) { b = b + 32; } }
                    if (a != b) {
                        match = 0;
                        j = plen;  # break
                    }
                }
                if (match) {
                    found = i;
                    i = limit + 1;  # break
                }
            }
        } else {
            var result = memmem(data + pos, data_len - pos, pat.data, plen);
            if (result >= 0) {
                found = pos + result;
            }
        }

        if (found < 0) { return offsets; }
        vec_push(offsets, found);
        count = count + 1;
        pos = found + 1;
    }
    return offsets;
}

# ================================================================
# YARA Engine — Condition expression tree
# ================================================================

# ConditionExpr — a node in the expression tree
# We use a flat struct; the "left" and "right" fields are pointers
# to other ConditionExpr nodes (or 0 for leaf nodes).
struct ConditionExpr {
    node_type;  # i64 — YARA_EXPR_*
    left;       # ptr to ConditionExpr (or 0)
    right;      # ptr to ConditionExpr (or 0)
    pat_index;  # i64 — pattern index (for PAT_MATCH)
    cmp_op;     # i64 — YARA_CMP_* (for FILESIZE, PAT_COUNT)
    cmp_value;  # i64 — comparison value
    n_count;    # i64 — for N_OF
}

fn cond_expr_new(node_type) {
    var e = ConditionExpr {};
    e.node_type = node_type;
    e.left = 0;
    e.right = 0;
    e.pat_index = 0;
    e.cmp_op = YARA_CMP_EQ;
    e.cmp_value = 0;
    e.n_count = 0;
    return e;
}

fn cond_expr_pat(pat_index) {
    var e = cond_expr_new(YARA_EXPR_PAT_MATCH);
    e.pat_index = pat_index;
    return e;
}

fn cond_expr_and(left, right) {
    var e = cond_expr_new(YARA_EXPR_AND);
    e.left = left;
    e.right = right;
    return e;
}

fn cond_expr_or(left, right) {
    var e = cond_expr_new(YARA_EXPR_OR);
    e.left = left;
    e.right = right;
    return e;
}

fn cond_expr_not(child) {
    var e = cond_expr_new(YARA_EXPR_NOT);
    e.left = child;
    return e;
}

fn cond_expr_filesize(cmp_op, value) {
    var e = cond_expr_new(YARA_EXPR_FILESIZE);
    e.cmp_op = cmp_op;
    e.cmp_value = value;
    return e;
}

fn cond_expr_all_of() {
    return cond_expr_new(YARA_EXPR_ALL_OF);
}

fn cond_expr_any_of() {
    return cond_expr_new(YARA_EXPR_ANY_OF);
}

fn cond_expr_n_of(n) {
    var e = cond_expr_new(YARA_EXPR_N_OF);
    e.n_count = n;
    return e;
}

# ================================================================
# YARA Engine — Condition evaluation
# ================================================================

# match_info: vec of i64 (0/1) indicating which patterns matched
# data_len: file size for filesize comparisons
fn eval_condition(expr, match_info, data_len) {
    if (expr == 0) { return 0; }

    var t = expr.node_type;

    if (t == YARA_EXPR_TRUE)  { return 1; }
    if (t == YARA_EXPR_FALSE) { return 0; }

    if (t == YARA_EXPR_PAT_MATCH) {
        var idx = expr.pat_index;
        if (idx >= 0) {
            if (idx < vec_len(match_info)) {
                return vec_get(match_info, idx);
            }
        }
        return 0;
    }

    if (t == YARA_EXPR_AND) {
        if (!eval_condition(expr.left, match_info, data_len)) { return 0; }
        return eval_condition(expr.right, match_info, data_len);
    }

    if (t == YARA_EXPR_OR) {
        if (eval_condition(expr.left, match_info, data_len)) { return 1; }
        return eval_condition(expr.right, match_info, data_len);
    }

    if (t == YARA_EXPR_NOT) {
        return !eval_condition(expr.left, match_info, data_len);
    }

    if (t == YARA_EXPR_FILESIZE) {
        return cmp_eval(expr.cmp_op, data_len, expr.cmp_value);
    }

    if (t == YARA_EXPR_ALL_OF) {
        var n = vec_len(match_info);
        for (var i = 0; i < n; i = i + 1) {
            if (!vec_get(match_info, i)) { return 0; }
        }
        return 1;
    }

    if (t == YARA_EXPR_ANY_OF) {
        var n = vec_len(match_info);
        for (var i = 0; i < n; i = i + 1) {
            if (vec_get(match_info, i)) { return 1; }
        }
        return 0;
    }

    if (t == YARA_EXPR_N_OF) {
        var matched = 0;
        var n = vec_len(match_info);
        for (var i = 0; i < n; i = i + 1) {
            if (vec_get(match_info, i)) { matched = matched + 1; }
        }
        return matched >= expr.n_count;
    }

    if (t == YARA_EXPR_PAT_COUNT) {
        # Compare count of pattern matches
        var idx = expr.pat_index;
        var count = 0;
        if (idx >= 0) {
            if (idx < vec_len(match_info)) {
                count = vec_get(match_info, idx);
            }
        }
        return cmp_eval(expr.cmp_op, count, expr.cmp_value);
    }

    return 0;
}

# Generic comparison evaluator
fn cmp_eval(op, lhs, rhs) {
    if (op == YARA_CMP_LT) { return lhs < rhs; }
    if (op == YARA_CMP_LE) { return lhs <= rhs; }
    if (op == YARA_CMP_GT) { return lhs > rhs; }
    if (op == YARA_CMP_GE) { return lhs >= rhs; }
    if (op == YARA_CMP_EQ) { return lhs == rhs; }
    if (op == YARA_CMP_NE) { return lhs != rhs; }
    return 0;
}

# ================================================================
# YARA Engine — Rule struct
# ================================================================

struct YaraConstraints {
    min_file_size; # i64 (0 = no constraint)
    max_file_size; # i64 (0 = no constraint)
    at_offset;     # i64 (-1 = no constraint)
}

fn yara_constraints_new() {
    var c = YaraConstraints {};
    c.min_file_size = 0;
    c.max_file_size = 0;
    c.at_offset = -1;
    return c;
}

struct YaraRule {
    name;         # Str — rule name
    description;  # Str
    severity;     # i64 — SEVERITY_*
    tags;         # Vec of Str
    patterns;     # Vec of YaraPattern
    cond_type;    # i64 — YARA_COND_*
    cond_expr;    # ConditionExpr ptr (for EXPRESSION type)
    cond_count;   # i64 — for AT_LEAST
    constraints;  # YaraConstraints
}

fn yara_rule_new(name) {
    var r = YaraRule {};
    r.name = name;
    r.description = str_from("");
    r.severity = SEVERITY_MEDIUM;
    r.tags = vec_new();
    r.patterns = vec_new();
    r.cond_type = YARA_COND_ALL;
    r.cond_expr = 0;
    r.cond_count = 0;
    r.constraints = yara_constraints_new();
    return r;
}

# ================================================================
# YARA Engine — Rule matching
# ================================================================

# Check if a single rule matches against data
# Returns: 1 if rule fires, 0 otherwise
fn yara_rule_matches(rule, data, data_len) {
    # Check constraints first
    var c = rule.constraints;
    if (c.min_file_size > 0) {
        if (data_len < c.min_file_size) { return 0; }
    }
    if (c.max_file_size > 0) {
        if (data_len > c.max_file_size) { return 0; }
    }

    var npats = vec_len(rule.patterns);
    if (npats == 0) {
        # No patterns — condition might be filesize-only
        if (rule.cond_type == YARA_COND_EXPRESSION) {
            if (rule.cond_expr != 0) {
                var empty_info = vec_new();
                return eval_condition(rule.cond_expr, empty_info, data_len);
            }
        }
        return 0;
    }

    # Build match info — which patterns matched
    var match_info = vec_new();
    var total_matched = 0;
    for (var i = 0; i < npats; i = i + 1) {
        var pat = vec_get(rule.patterns, i);
        var matched = 0;

        if (c.at_offset >= 0) {
            # Pattern must match at specific offset
            if (c.at_offset + pat.data_len <= data_len) {
                if (pat.data != 0) {
                    var m = 1;
                    for (var j = 0; j < pat.data_len; j = j + 1) {
                        if (load8(data + c.at_offset + j) != load8(pat.data + j)) {
                            m = 0;
                            j = pat.data_len;  # break
                        }
                    }
                    matched = m;
                }
            }
        } else {
            matched = yara_pattern_matches(pat, data, data_len);
        }

        vec_push(match_info, matched);
        if (matched) { total_matched = total_matched + 1; }
    }

    # Evaluate condition
    if (rule.cond_type == YARA_COND_ALL) {
        return total_matched == npats;
    }
    if (rule.cond_type == YARA_COND_ANY) {
        return total_matched > 0;
    }
    if (rule.cond_type == YARA_COND_AT_LEAST) {
        return total_matched >= rule.cond_count;
    }
    if (rule.cond_type == YARA_COND_EXPRESSION) {
        if (rule.cond_expr != 0) {
            return eval_condition(rule.cond_expr, match_info, data_len);
        }
    }

    return 0;
}

# ================================================================
# YARA Engine — Finding from rule match
# ================================================================

struct YaraFinding {
    rule_name;   # Str
    description; # Str
    severity;    # i64
    tags;        # Vec of Str
    offsets;     # Vec of i64 — where patterns matched
}

fn yara_finding_new(rule) {
    var f = YaraFinding {};
    f.rule_name = rule.name;
    f.description = rule.description;
    f.severity = rule.severity;
    f.tags = rule.tags;
    f.offsets = vec_new();
    return f;
}

# ================================================================
# YARA Engine — Engine struct
# ================================================================

struct YaraEngine {
    rules;  # Vec of YaraRule
}

fn yara_engine_new() {
    var e = YaraEngine {};
    e.rules = vec_new();
    return e;
}

fn yara_engine_add_rule(engine, rule) {
    vec_push(engine.rules, rule);
}

fn yara_engine_rule_count(engine) {
    return vec_len(engine.rules);
}

# Scan data against all loaded rules
# Returns a vec of YaraFinding
fn yara_engine_scan(engine, data, data_len) {
    var findings = vec_new();
    var nrules = vec_len(engine.rules);

    for (var i = 0; i < nrules; i = i + 1) {
        var rule = vec_get(engine.rules, i);
        if (yara_rule_matches(rule, data, data_len)) {
            var finding = yara_finding_new(rule);

            # Collect match offsets for the first matching pattern
            var npats = vec_len(rule.patterns);
            for (var j = 0; j < npats; j = j + 1) {
                var pat = vec_get(rule.patterns, j);
                if (yara_pattern_matches(pat, data, data_len)) {
                    var offsets = yara_pattern_find_offsets(pat, data, data_len);
                    finding.offsets = offsets;
                    j = npats;  # break — use first matching pattern's offsets
                }
            }

            vec_push(findings, finding);
        }
    }
    return findings;
}

# ================================================================
# YARA Engine — TOML rule loading
# ================================================================

# Load rules from a TOML string
# Expected format:
#   [[rules]]
#   name = "SuspiciousMZ"
#   description = "Detects MZ header"
#   severity = "high"
#   tags = ["pe", "executable"]
#   condition = "all"
#
#   [[rules.patterns]]
#   id = "$mz"
#   type = "hex"
#   value = "4D 5A"
fn yara_engine_load_rules_toml(engine, toml_str) {
    var doc = toml_parse(toml_str);
    if (doc == 0) { return Err(ERR_RULE_PARSE); }

    var rules_arr = toml_get_array(doc, str_from("rules"));
    if (rules_arr == 0) { return Err(ERR_RULE_PARSE); }

    var nrules = toml_array_len(rules_arr);
    for (var i = 0; i < nrules; i = i + 1) {
        var tbl = toml_array_get(rules_arr, i);
        if (tbl != 0) {
            var name = toml_get_string(tbl, str_from("name"));
            if (name == 0) { name = str_from("unnamed"); }

            var rule = yara_rule_new(name);

            var desc = toml_get_string(tbl, str_from("description"));
            if (desc != 0) { rule.description = desc; }

            # Parse severity
            var sev_str = toml_get_string(tbl, str_from("severity"));
            if (sev_str != 0) {
                rule.severity = parse_severity_str(sev_str);
            }

            # Parse tags
            var tags_arr = toml_get_array(tbl, str_from("tags"));
            if (tags_arr != 0) {
                var ntags = toml_array_len(tags_arr);
                for (var t = 0; t < ntags; t = t + 1) {
                    var tag = toml_array_get_string(tags_arr, t);
                    if (tag != 0) { vec_push(rule.tags, tag); }
                }
            }

            # Parse condition
            var cond_str = toml_get_string(tbl, str_from("condition"));
            if (cond_str != 0) {
                if (str_eq(cond_str, str_from("all"))) {
                    rule.cond_type = YARA_COND_ALL;
                } else {
                    if (str_eq(cond_str, str_from("any"))) {
                        rule.cond_type = YARA_COND_ANY;
                    }
                }
            }

            var cond_count = toml_get_int(tbl, str_from("condition_count"));
            if (cond_count > 0) {
                rule.cond_type = YARA_COND_AT_LEAST;
                rule.cond_count = cond_count;
            }

            # Parse constraints
            var min_size = toml_get_int(tbl, str_from("min_file_size"));
            if (min_size > 0) { rule.constraints.min_file_size = min_size; }
            var max_size = toml_get_int(tbl, str_from("max_file_size"));
            if (max_size > 0) { rule.constraints.max_file_size = max_size; }
            var at_off = toml_get_int(tbl, str_from("at_offset"));
            if (at_off >= 0) { rule.constraints.at_offset = at_off; }

            # Parse patterns
            var pats_arr = toml_get_array(tbl, str_from("patterns"));
            if (pats_arr != 0) {
                var npats = toml_array_len(pats_arr);
                for (var p = 0; p < npats; p = p + 1) {
                    var ptbl = toml_array_get(pats_arr, p);
                    if (ptbl != 0) {
                        var pid = toml_get_string(ptbl, str_from("id"));
                        if (pid == 0) { pid = str_cat(str_from("$p"), str_from_int(p)); }
                        var ptype = toml_get_string(ptbl, str_from("type"));
                        var pval = toml_get_string(ptbl, str_from("value"));
                        if (pval != 0) {
                            var pat = 0;
                            if (ptype != 0) {
                                if (str_eq(ptype, str_from("hex"))) {
                                    pat = yara_pattern_from_hex(pid, pval);
                                } else {
                                    if (str_eq(ptype, str_from("string"))) {
                                        pat = yara_pattern_from_string(pid, pval);
                                    } else {
                                        # Default to string
                                        pat = yara_pattern_from_string(pid, pval);
                                    }
                                }
                            } else {
                                pat = yara_pattern_from_string(pid, pval);
                            }

                            # Check nocase flag
                            var nocase = toml_get_int(ptbl, str_from("nocase"));
                            if (nocase) { pat.nocase = 1; }

                            vec_push(rule.patterns, pat);
                        }
                    }
                }
            }

            yara_engine_add_rule(engine, rule);
        }
    }
    return Ok(nrules);
}

# Helper: parse severity string to constant
fn parse_severity_str(s) {
    if (str_eq(s, str_from("critical"))) { return SEVERITY_CRITICAL; }
    if (str_eq(s, str_from("CRITICAL"))) { return SEVERITY_CRITICAL; }
    if (str_eq(s, str_from("high")))     { return SEVERITY_HIGH; }
    if (str_eq(s, str_from("HIGH")))     { return SEVERITY_HIGH; }
    if (str_eq(s, str_from("medium")))   { return SEVERITY_MEDIUM; }
    if (str_eq(s, str_from("MEDIUM")))   { return SEVERITY_MEDIUM; }
    if (str_eq(s, str_from("low")))      { return SEVERITY_LOW; }
    if (str_eq(s, str_from("LOW")))      { return SEVERITY_LOW; }
    if (str_eq(s, str_from("info")))     { return SEVERITY_INFO; }
    if (str_eq(s, str_from("INFO")))     { return SEVERITY_INFO; }
    return SEVERITY_MEDIUM;
}

# ================================================================
# YARA Parser — .yar syntax lexer
# ================================================================

# Token types
var YAR_TOK_EOF        = 0;
var YAR_TOK_RULE       = 1;   # "rule" keyword
var YAR_TOK_STRINGS    = 2;   # "strings:" keyword
var YAR_TOK_CONDITION  = 3;   # "condition:" keyword
var YAR_TOK_IMPORT     = 4;   # "import" keyword
var YAR_TOK_LBRACE     = 5;   # {
var YAR_TOK_RBRACE     = 6;   # }
var YAR_TOK_LPAREN     = 7;   # (
var YAR_TOK_RPAREN     = 8;   # )
var YAR_TOK_EQ         = 9;   # =
var YAR_TOK_COLON      = 10;  # :
var YAR_TOK_DOLLAR     = 11;  # $identifier
var YAR_TOK_STRING_LIT = 12;  # "..."
var YAR_TOK_HEX_BLOCK  = 13;  # { 4D 5A ... }
var YAR_TOK_IDENT      = 14;  # identifier
var YAR_TOK_NUMBER     = 15;  # integer literal
var YAR_TOK_AND        = 16;  # "and"
var YAR_TOK_OR         = 17;  # "or"
var YAR_TOK_NOT        = 18;  # "not"
var YAR_TOK_ALL        = 19;  # "all"
var YAR_TOK_ANY        = 20;  # "any"
var YAR_TOK_OF         = 21;  # "of"
var YAR_TOK_THEM       = 22;  # "them"
var YAR_TOK_FILESIZE   = 23;  # "filesize"
var YAR_TOK_LT         = 24;  # <
var YAR_TOK_GT         = 25;  # >
var YAR_TOK_LE         = 26;  # <=
var YAR_TOK_GE         = 27;  # >=
var YAR_TOK_EQEQ       = 28;  # ==
var YAR_TOK_NE         = 29;  # !=
var YAR_TOK_META       = 30;  # "meta:" keyword
var YAR_TOK_TRUE       = 31;  # "true"
var YAR_TOK_FALSE      = 32;  # "false"
var YAR_TOK_AT         = 33;  # "at"

# Lexer state
struct YarLexer {
    src;    # Str — source text
    pos;    # i64 — current position
    len;    # i64 — source length
    sdata;  # ptr — raw source bytes
}

fn yar_lexer_new(src) {
    var l = YarLexer {};
    l.src = src;
    l.pos = 0;
    l.len = str_len(src);
    l.sdata = str_data(src);
    return l;
}

# Skip whitespace and comments
fn yar_skip_ws(lex) {
    while (lex.pos < lex.len) {
        var ch = load8(lex.sdata + lex.pos);
        if (ch == 32 | ch == 9 | ch == 10 | ch == 13) {
            lex.pos = lex.pos + 1;
        } else {
            if (ch == 47) {  # '/'
                if (lex.pos + 1 < lex.len) {
                    var next = load8(lex.sdata + lex.pos + 1);
                    if (next == 47) {
                        # // line comment
                        lex.pos = lex.pos + 2;
                        while (lex.pos < lex.len) {
                            if (load8(lex.sdata + lex.pos) == 10) {
                                lex.pos = lex.pos + 1;
                                lex.pos = lex.pos;  # continue outer
                                return yar_skip_ws(lex);  # restart
                            }
                            lex.pos = lex.pos + 1;
                        }
                    } else {
                        if (next == 42) {
                            # /* block comment */
                            lex.pos = lex.pos + 2;
                            while (lex.pos + 1 < lex.len) {
                                if (load8(lex.sdata + lex.pos) == 42) {
                                    if (load8(lex.sdata + lex.pos + 1) == 47) {
                                        lex.pos = lex.pos + 2;
                                        return yar_skip_ws(lex);  # restart
                                    }
                                }
                                lex.pos = lex.pos + 1;
                            }
                        } else {
                            return;  # not a comment
                        }
                    }
                } else {
                    return;
                }
            } else {
                return;
            }
        }
    }
}

# Token struct
struct YarToken {
    tok_type;  # i64 — YAR_TOK_*
    value;     # Str — text value
    num_val;   # i64 — numeric value (for NUMBER)
}

fn yar_token_new(tok_type, value) {
    var t = YarToken {};
    t.tok_type = tok_type;
    t.value = value;
    t.num_val = 0;
    return t;
}

fn yar_is_alpha(ch) {
    if (ch >= 65) { if (ch <= 90)  { return 1; } }
    if (ch >= 97) { if (ch <= 122) { return 1; } }
    if (ch == 95) { return 1; }  # '_'
    return 0;
}

fn yar_is_alnum(ch) {
    if (yar_is_alpha(ch)) { return 1; }
    if (ch >= 48) { if (ch <= 57) { return 1; } }
    return 0;
}

fn yar_is_digit(ch) {
    if (ch >= 48) { if (ch <= 57) { return 1; } }
    return 0;
}

# Read next token
fn yar_next_token(lex) {
    yar_skip_ws(lex);
    if (lex.pos >= lex.len) {
        return yar_token_new(YAR_TOK_EOF, str_from(""));
    }

    var ch = load8(lex.sdata + lex.pos);

    # Single-character tokens
    if (ch == 123) { lex.pos = lex.pos + 1; return yar_token_new(YAR_TOK_LBRACE, str_from("{")); }
    if (ch == 125) { lex.pos = lex.pos + 1; return yar_token_new(YAR_TOK_RBRACE, str_from("}")); }
    if (ch == 40)  { lex.pos = lex.pos + 1; return yar_token_new(YAR_TOK_LPAREN, str_from("(")); }
    if (ch == 41)  { lex.pos = lex.pos + 1; return yar_token_new(YAR_TOK_RPAREN, str_from(")")); }
    if (ch == 58)  { lex.pos = lex.pos + 1; return yar_token_new(YAR_TOK_COLON, str_from(":")); }

    # Two-char operators
    if (ch == 60) {  # '<'
        if (lex.pos + 1 < lex.len) {
            if (load8(lex.sdata + lex.pos + 1) == 61) {
                lex.pos = lex.pos + 2;
                return yar_token_new(YAR_TOK_LE, str_from("<="));
            }
        }
        lex.pos = lex.pos + 1;
        return yar_token_new(YAR_TOK_LT, str_from("<"));
    }
    if (ch == 62) {  # '>'
        if (lex.pos + 1 < lex.len) {
            if (load8(lex.sdata + lex.pos + 1) == 61) {
                lex.pos = lex.pos + 2;
                return yar_token_new(YAR_TOK_GE, str_from(">="));
            }
        }
        lex.pos = lex.pos + 1;
        return yar_token_new(YAR_TOK_GT, str_from(">"));
    }
    if (ch == 61) {  # '='
        if (lex.pos + 1 < lex.len) {
            if (load8(lex.sdata + lex.pos + 1) == 61) {
                lex.pos = lex.pos + 2;
                return yar_token_new(YAR_TOK_EQEQ, str_from("=="));
            }
        }
        lex.pos = lex.pos + 1;
        return yar_token_new(YAR_TOK_EQ, str_from("="));
    }
    if (ch == 33) {  # '!'
        if (lex.pos + 1 < lex.len) {
            if (load8(lex.sdata + lex.pos + 1) == 61) {
                lex.pos = lex.pos + 2;
                return yar_token_new(YAR_TOK_NE, str_from("!="));
            }
        }
        # standalone '!' is handled as NOT in parsing
        lex.pos = lex.pos + 1;
        return yar_token_new(YAR_TOK_NOT, str_from("!"));
    }

    # $ pattern identifier
    if (ch == 36) {  # '$'
        lex.pos = lex.pos + 1;
        var start = lex.pos;
        while (lex.pos < lex.len) {
            if (yar_is_alnum(load8(lex.sdata + lex.pos))) {
                lex.pos = lex.pos + 1;
            } else {
                lex.pos = lex.pos;  # stop
                var id_len = lex.pos - start;
                var id = str_from("$");
                if (id_len > 0) {
                    id = str_cat(str_from("$"), str_substr(lex.src, start, id_len));
                }
                return yar_token_new(YAR_TOK_DOLLAR, id);
            }
        }
        var id_len = lex.pos - start;
        var id = str_cat(str_from("$"), str_substr(lex.src, start, id_len));
        return yar_token_new(YAR_TOK_DOLLAR, id);
    }

    # String literal "..."
    if (ch == 34) {  # '"'
        lex.pos = lex.pos + 1;
        var start = lex.pos;
        while (lex.pos < lex.len) {
            var c = load8(lex.sdata + lex.pos);
            if (c == 34) {
                var sval = str_substr(lex.src, start, lex.pos - start);
                lex.pos = lex.pos + 1;  # skip closing quote
                return yar_token_new(YAR_TOK_STRING_LIT, sval);
            }
            if (c == 92) {  # backslash escape
                lex.pos = lex.pos + 2;
            } else {
                lex.pos = lex.pos + 1;
            }
        }
        # Unterminated string
        var sval = str_substr(lex.src, start, lex.pos - start);
        return yar_token_new(YAR_TOK_STRING_LIT, sval);
    }

    # Number literal
    if (yar_is_digit(ch)) {
        var start = lex.pos;
        var val = 0;
        # Check for hex prefix 0x
        if (ch == 48) {
            if (lex.pos + 1 < lex.len) {
                var nx = load8(lex.sdata + lex.pos + 1);
                if (nx == 120 | nx == 88) {  # 'x' or 'X'
                    lex.pos = lex.pos + 2;
                    while (lex.pos < lex.len) {
                        var d = hex_digit_value(load8(lex.sdata + lex.pos));
                        if (d < 0) { lex.pos = lex.pos; var dummy = 0; lex.pos = lex.pos; }
                        if (d < 0) {
                            var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(lex.src, start, lex.pos - start));
                            tok.num_val = val;
                            return tok;
                        }
                        val = (val << 4) | d;
                        lex.pos = lex.pos + 1;
                    }
                    var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(lex.src, start, lex.pos - start));
                    tok.num_val = val;
                    return tok;
                }
            }
        }
        while (lex.pos < lex.len) {
            var d = load8(lex.sdata + lex.pos);
            if (d >= 48) {
                if (d <= 57) {
                    val = val * 10 + (d - 48);
                    lex.pos = lex.pos + 1;
                } else {
                    var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(lex.src, start, lex.pos - start));
                    tok.num_val = val;
                    return tok;
                }
            } else {
                var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(lex.src, start, lex.pos - start));
                tok.num_val = val;
                return tok;
            }
        }
        # Handle suffix multipliers (KB, MB)
        var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(lex.src, start, lex.pos - start));
        tok.num_val = val;
        return tok;
    }

    # Identifier or keyword
    if (yar_is_alpha(ch)) {
        var start = lex.pos;
        while (lex.pos < lex.len) {
            if (yar_is_alnum(load8(lex.sdata + lex.pos))) {
                lex.pos = lex.pos + 1;
            } else {
                lex.pos = lex.pos;
                var word = str_substr(lex.src, start, lex.pos - start);
                return yar_classify_keyword(word);
            }
        }
        var word = str_substr(lex.src, start, lex.pos - start);
        return yar_classify_keyword(word);
    }

    # Unknown character — skip
    lex.pos = lex.pos + 1;
    return yar_token_new(YAR_TOK_IDENT, str_from("?"));
}

# Classify an identifier as a keyword or plain identifier
fn yar_classify_keyword(word) {
    if (str_eq(word, str_from("rule")))      { return yar_token_new(YAR_TOK_RULE, word); }
    if (str_eq(word, str_from("strings")))   { return yar_token_new(YAR_TOK_STRINGS, word); }
    if (str_eq(word, str_from("condition"))) { return yar_token_new(YAR_TOK_CONDITION, word); }
    if (str_eq(word, str_from("import")))    { return yar_token_new(YAR_TOK_IMPORT, word); }
    if (str_eq(word, str_from("meta")))      { return yar_token_new(YAR_TOK_META, word); }
    if (str_eq(word, str_from("and")))       { return yar_token_new(YAR_TOK_AND, word); }
    if (str_eq(word, str_from("or")))        { return yar_token_new(YAR_TOK_OR, word); }
    if (str_eq(word, str_from("not")))       { return yar_token_new(YAR_TOK_NOT, word); }
    if (str_eq(word, str_from("all")))       { return yar_token_new(YAR_TOK_ALL, word); }
    if (str_eq(word, str_from("any")))       { return yar_token_new(YAR_TOK_ANY, word); }
    if (str_eq(word, str_from("of")))        { return yar_token_new(YAR_TOK_OF, word); }
    if (str_eq(word, str_from("them")))      { return yar_token_new(YAR_TOK_THEM, word); }
    if (str_eq(word, str_from("filesize")))  { return yar_token_new(YAR_TOK_FILESIZE, word); }
    if (str_eq(word, str_from("true")))      { return yar_token_new(YAR_TOK_TRUE, word); }
    if (str_eq(word, str_from("false")))     { return yar_token_new(YAR_TOK_FALSE, word); }
    if (str_eq(word, str_from("at")))        { return yar_token_new(YAR_TOK_AT, word); }
    # Size suffixes
    if (str_eq(word, str_from("KB")))        { return yar_token_new(YAR_TOK_IDENT, word); }
    if (str_eq(word, str_from("MB")))        { return yar_token_new(YAR_TOK_IDENT, word); }
    return yar_token_new(YAR_TOK_IDENT, word);
}

# ================================================================
# YARA Parser — .yar syntax parser
# ================================================================

struct YarParser {
    lex;          # YarLexer
    current;      # YarToken — current lookahead token
    patterns;     # Vec of YaraPattern (current rule)
    pattern_map;  # map from pattern id str -> index
}

fn yar_parser_new(src) {
    var p = YarParser {};
    p.lex = yar_lexer_new(src);
    p.current = yar_next_token(p.lex);
    p.patterns = vec_new();
    p.pattern_map = map_new();
    return p;
}

fn yar_advance(parser) {
    parser.current = yar_next_token(parser.lex);
    return parser.current;
}

fn yar_expect(parser, tok_type) {
    if (parser.current.tok_type == tok_type) {
        var tok = parser.current;
        yar_advance(parser);
        return tok;
    }
    return 0;  # unexpected token
}

# Parse a size value with optional KB/MB suffix
fn yar_parse_size(parser) {
    var tok = parser.current;
    if (tok.tok_type != YAR_TOK_NUMBER) { return 0; }
    var val = tok.num_val;
    yar_advance(parser);
    # Check for KB/MB suffix
    if (parser.current.tok_type == YAR_TOK_IDENT) {
        if (str_eq(parser.current.value, str_from("KB"))) {
            val = val * 1024;
            yar_advance(parser);
        } else {
            if (str_eq(parser.current.value, str_from("MB"))) {
                val = val * 1024 * 1024;
                yar_advance(parser);
            }
        }
    }
    return val;
}

# Parse the strings section
fn yar_parse_strings(parser) {
    parser.patterns = vec_new();
    parser.pattern_map = map_new();

    # Expect "strings" ":"
    # "strings" was already consumed; expect ":"
    yar_expect(parser, YAR_TOK_COLON);

    var idx = 0;
    while (parser.current.tok_type == YAR_TOK_DOLLAR) {
        var pat_id = parser.current.value;
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_EQ);

        var pat = 0;
        if (parser.current.tok_type == YAR_TOK_STRING_LIT) {
            pat = yara_pattern_from_string(pat_id, parser.current.value);
            yar_advance(parser);
        } else {
            if (parser.current.tok_type == YAR_TOK_LBRACE) {
                # Hex block: { XX XX XX }
                yar_advance(parser);  # skip '{'
                var hex_str = str_from("");
                while (parser.current.tok_type != YAR_TOK_RBRACE) {
                    if (parser.current.tok_type == YAR_TOK_EOF) {
                        return;  # error
                    }
                    hex_str = str_cat(hex_str, parser.current.value);
                    if (parser.current.tok_type == YAR_TOK_NUMBER |
                        parser.current.tok_type == YAR_TOK_IDENT) {
                        hex_str = str_cat(hex_str, str_from(" "));
                    }
                    yar_advance(parser);
                }
                yar_advance(parser);  # skip '}'
                pat = yara_pattern_from_hex(pat_id, hex_str);
            } else {
                # Unknown pattern type — skip
                yar_advance(parser);
            }
        }

        if (pat != 0) {
            # Check for modifiers: nocase, ascii, wide
            while (parser.current.tok_type == YAR_TOK_IDENT) {
                if (str_eq(parser.current.value, str_from("nocase"))) {
                    pat.nocase = 1;
                    yar_advance(parser);
                } else {
                    if (str_eq(parser.current.value, str_from("ascii"))) {
                        yar_advance(parser);  # skip, default is ascii
                    } else {
                        if (str_eq(parser.current.value, str_from("wide"))) {
                            yar_advance(parser);  # acknowledged but not fully supported
                        } else {
                            parser.current = parser.current;  # stop modifier parsing
                            var dummy = 0;
                            dummy = 1;  # force break from while
                            return;
                        }
                    }
                }
            }

            vec_push(parser.patterns, pat);
            map_set(parser.pattern_map, pat_id, idx);
            idx = idx + 1;
        }
    }
}

# Parse condition expression (recursive descent)
fn yar_parse_condition(parser) {
    # Expect "condition" ":"
    yar_expect(parser, YAR_TOK_COLON);
    return yar_parse_or_expr(parser);
}

fn yar_parse_or_expr(parser) {
    var left = yar_parse_and_expr(parser);
    while (parser.current.tok_type == YAR_TOK_OR) {
        yar_advance(parser);
        var right = yar_parse_and_expr(parser);
        left = cond_expr_or(left, right);
    }
    return left;
}

fn yar_parse_and_expr(parser) {
    var left = yar_parse_not_expr(parser);
    while (parser.current.tok_type == YAR_TOK_AND) {
        yar_advance(parser);
        var right = yar_parse_not_expr(parser);
        left = cond_expr_and(left, right);
    }
    return left;
}

fn yar_parse_not_expr(parser) {
    if (parser.current.tok_type == YAR_TOK_NOT) {
        yar_advance(parser);
        var child = yar_parse_primary_expr(parser);
        return cond_expr_not(child);
    }
    return yar_parse_primary_expr(parser);
}

fn yar_parse_primary_expr(parser) {
    var tok = parser.current;

    # Pattern reference: $a
    if (tok.tok_type == YAR_TOK_DOLLAR) {
        var pat_id = tok.value;
        yar_advance(parser);
        var idx = map_get(parser.pattern_map, pat_id);
        if (idx != 0) {
            return cond_expr_pat(idx);
        }
        # Try index 0 explicitly (map_get returns 0 for both missing and index 0)
        var npats = vec_len(parser.patterns);
        if (npats > 0) {
            var first_pat = vec_get(parser.patterns, 0);
            if (str_eq(first_pat.id, pat_id)) {
                return cond_expr_pat(0);
            }
        }
        return cond_expr_new(YARA_EXPR_FALSE);
    }

    # "all of them"
    if (tok.tok_type == YAR_TOK_ALL) {
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_OF);
        yar_expect(parser, YAR_TOK_THEM);
        return cond_expr_all_of();
    }

    # "any of them"
    if (tok.tok_type == YAR_TOK_ANY) {
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_OF);
        yar_expect(parser, YAR_TOK_THEM);
        return cond_expr_any_of();
    }

    # N "of them"
    if (tok.tok_type == YAR_TOK_NUMBER) {
        var n = tok.num_val;
        yar_advance(parser);
        if (parser.current.tok_type == YAR_TOK_OF) {
            yar_advance(parser);
            yar_expect(parser, YAR_TOK_THEM);
            return cond_expr_n_of(n);
        }
        # Standalone number — used in comparisons after filesize etc.
        # This is actually part of a filesize comparison handled elsewhere
        var e = cond_expr_new(YARA_EXPR_TRUE);
        e.cmp_value = n;
        return e;
    }

    # "filesize" <op> <value>
    if (tok.tok_type == YAR_TOK_FILESIZE) {
        yar_advance(parser);
        var op = yar_parse_cmp_op(parser);
        var val = yar_parse_size(parser);
        return cond_expr_filesize(op, val);
    }

    # "true" / "false"
    if (tok.tok_type == YAR_TOK_TRUE) {
        yar_advance(parser);
        return cond_expr_new(YARA_EXPR_TRUE);
    }
    if (tok.tok_type == YAR_TOK_FALSE) {
        yar_advance(parser);
        return cond_expr_new(YARA_EXPR_FALSE);
    }

    # Parenthesized expression
    if (tok.tok_type == YAR_TOK_LPAREN) {
        yar_advance(parser);
        var expr = yar_parse_or_expr(parser);
        yar_expect(parser, YAR_TOK_RPAREN);
        return expr;
    }

    # Unknown — skip and return true
    yar_advance(parser);
    return cond_expr_new(YARA_EXPR_TRUE);
}

fn yar_parse_cmp_op(parser) {
    var tok = parser.current;
    if (tok.tok_type == YAR_TOK_LT) { yar_advance(parser); return YARA_CMP_LT; }
    if (tok.tok_type == YAR_TOK_LE) { yar_advance(parser); return YARA_CMP_LE; }
    if (tok.tok_type == YAR_TOK_GT) { yar_advance(parser); return YARA_CMP_GT; }
    if (tok.tok_type == YAR_TOK_GE) { yar_advance(parser); return YARA_CMP_GE; }
    if (tok.tok_type == YAR_TOK_EQEQ) { yar_advance(parser); return YARA_CMP_EQ; }
    if (tok.tok_type == YAR_TOK_NE) { yar_advance(parser); return YARA_CMP_NE; }
    return YARA_CMP_EQ;  # default
}

# ================================================================
# YARA Parser — Parse a complete .yar file
# ================================================================

# Parse .yar source text and return a vec of YaraRule
fn yara_parse_rules(src) {
    var parser = yar_parser_new(src);
    var rules = vec_new();

    while (parser.current.tok_type != YAR_TOK_EOF) {
        # Skip "import" statements silently
        if (parser.current.tok_type == YAR_TOK_IMPORT) {
            yar_advance(parser);
            # Skip the import target (string literal or identifier)
            if (parser.current.tok_type == YAR_TOK_STRING_LIT |
                parser.current.tok_type == YAR_TOK_IDENT) {
                yar_advance(parser);
            }
        } else {
            if (parser.current.tok_type == YAR_TOK_RULE) {
                var rule = yar_parse_one_rule(parser);
                if (rule != 0) {
                    vec_push(rules, rule);
                }
            } else {
                # Skip unknown tokens
                yar_advance(parser);
            }
        }
    }

    return rules;
}

# Parse a single rule: rule Name { ... }
fn yar_parse_one_rule(parser) {
    yar_advance(parser);  # skip "rule" keyword

    # Rule name
    if (parser.current.tok_type != YAR_TOK_IDENT) { return 0; }
    var name = parser.current.value;
    yar_advance(parser);

    # Optional tags: rule Name : tag1 tag2 { ... }
    var tags = vec_new();
    if (parser.current.tok_type == YAR_TOK_COLON) {
        yar_advance(parser);
        while (parser.current.tok_type == YAR_TOK_IDENT) {
            vec_push(tags, parser.current.value);
            yar_advance(parser);
        }
    }

    # Opening brace
    if (yar_expect(parser, YAR_TOK_LBRACE) == 0) { return 0; }

    var rule = yara_rule_new(name);
    rule.tags = tags;

    # Parse sections within the rule
    while (parser.current.tok_type != YAR_TOK_RBRACE) {
        if (parser.current.tok_type == YAR_TOK_EOF) { return rule; }

        if (parser.current.tok_type == YAR_TOK_META) {
            yar_advance(parser);
            yar_parse_meta(parser, rule);
        } else {
            if (parser.current.tok_type == YAR_TOK_STRINGS) {
                yar_advance(parser);
                yar_parse_strings(parser);
                rule.patterns = parser.patterns;
            } else {
                if (parser.current.tok_type == YAR_TOK_CONDITION) {
                    yar_advance(parser);
                    var expr = yar_parse_condition(parser);
                    rule.cond_type = YARA_COND_EXPRESSION;
                    rule.cond_expr = expr;
                } else {
                    yar_advance(parser);  # skip unknown
                }
            }
        }
    }

    yar_advance(parser);  # skip closing '}'
    return rule;
}

# Parse meta section
fn yar_parse_meta(parser, rule) {
    yar_expect(parser, YAR_TOK_COLON);
    while (parser.current.tok_type == YAR_TOK_IDENT) {
        var key = parser.current.value;
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_EQ);

        if (parser.current.tok_type == YAR_TOK_STRING_LIT) {
            var val = parser.current.value;
            yar_advance(parser);
            if (str_eq(key, str_from("description"))) {
                rule.description = val;
            }
            if (str_eq(key, str_from("severity"))) {
                rule.severity = parse_severity_str(val);
            }
        } else {
            if (parser.current.tok_type == YAR_TOK_NUMBER) {
                yar_advance(parser);
            } else {
                if (parser.current.tok_type == YAR_TOK_TRUE |
                    parser.current.tok_type == YAR_TOK_FALSE) {
                    yar_advance(parser);
                } else {
                    yar_advance(parser);
                }
            }
        }
    }
}

# ================================================================
# YARA Engine — Load .yar file into engine
# ================================================================

fn yara_engine_load_rules_yar(engine, yar_src) {
    var rules = yara_parse_rules(yar_src);
    var n = vec_len(rules);
    for (var i = 0; i < n; i = i + 1) {
        yara_engine_add_rule(engine, vec_get(rules, i));
    }
    return n;
}

# ================================================================
# YARA Engine — Built-in detection rules
# ================================================================

# Create standard detection rules for common threats
fn yara_engine_load_builtin_rules(engine) {
    # Rule: Detect MZ header (PE executable)
    var mz_rule = yara_rule_new(str_from("IsPE"));
    mz_rule.description = str_from("File contains PE executable header");
    mz_rule.severity = SEVERITY_INFO;
    vec_push(mz_rule.tags, str_from("pe"));
    vec_push(mz_rule.patterns, yara_pattern_from_hex(str_from("$mz"), str_from("4D 5A")));
    mz_rule.cond_type = YARA_COND_ALL;
    mz_rule.constraints.at_offset = 0;
    yara_engine_add_rule(engine, mz_rule);

    # Rule: Detect ELF header
    var elf_rule = yara_rule_new(str_from("IsELF"));
    elf_rule.description = str_from("File contains ELF executable header");
    elf_rule.severity = SEVERITY_INFO;
    vec_push(elf_rule.tags, str_from("elf"));
    vec_push(elf_rule.patterns, yara_pattern_from_hex(str_from("$elf"), str_from("7F 45 4C 46")));
    elf_rule.cond_type = YARA_COND_ALL;
    elf_rule.constraints.at_offset = 0;
    yara_engine_add_rule(engine, elf_rule);

    # Rule: Detect UPX-packed binaries
    var upx_rule = yara_rule_new(str_from("UPXPacked"));
    upx_rule.description = str_from("Binary is packed with UPX");
    upx_rule.severity = SEVERITY_MEDIUM;
    vec_push(upx_rule.tags, str_from("packer"));
    vec_push(upx_rule.tags, str_from("upx"));
    vec_push(upx_rule.patterns, yara_pattern_from_string(str_from("$upx0"), str_from("UPX0")));
    vec_push(upx_rule.patterns, yara_pattern_from_string(str_from("$upx1"), str_from("UPX1")));
    vec_push(upx_rule.patterns, yara_pattern_from_string(str_from("$upx2"), str_from("UPX!")));
    upx_rule.cond_type = YARA_COND_AT_LEAST;
    upx_rule.cond_count = 2;
    yara_engine_add_rule(engine, upx_rule);

    # Rule: Detect potential shellcode / NOP sled
    var nop_rule = yara_rule_new(str_from("NopSled"));
    nop_rule.description = str_from("Potential NOP sled detected (shellcode indicator)");
    nop_rule.severity = SEVERITY_HIGH;
    vec_push(nop_rule.tags, str_from("shellcode"));
    # 32 consecutive NOPs
    vec_push(nop_rule.patterns, yara_pattern_from_hex(str_from("$nop"),
        str_from("90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90")));
    nop_rule.cond_type = YARA_COND_ANY;
    yara_engine_add_rule(engine, nop_rule);

    # Rule: Detect suspicious API strings in PE
    var api_rule = yara_rule_new(str_from("SuspiciousAPIs"));
    api_rule.description = str_from("Contains suspicious Windows API references");
    api_rule.severity = SEVERITY_MEDIUM;
    vec_push(api_rule.tags, str_from("suspicious"));
    vec_push(api_rule.tags, str_from("api"));
    vec_push(api_rule.patterns, yara_pattern_from_string(str_from("$a1"), str_from("VirtualAllocEx")));
    vec_push(api_rule.patterns, yara_pattern_from_string(str_from("$a2"), str_from("WriteProcessMemory")));
    vec_push(api_rule.patterns, yara_pattern_from_string(str_from("$a3"), str_from("CreateRemoteThread")));
    vec_push(api_rule.patterns, yara_pattern_from_string(str_from("$a4"), str_from("NtUnmapViewOfSection")));
    api_rule.cond_type = YARA_COND_AT_LEAST;
    api_rule.cond_count = 2;
    yara_engine_add_rule(engine, api_rule);

    # Rule: Detect ransomware indicators
    var ransom_rule = yara_rule_new(str_from("RansomwareIndicators"));
    ransom_rule.description = str_from("Contains ransomware-related strings");
    ransom_rule.severity = SEVERITY_CRITICAL;
    vec_push(ransom_rule.tags, str_from("ransomware"));
    vec_push(ransom_rule.patterns, yara_pattern_from_string(str_from("$r1"), str_from("Your files have been encrypted")));
    vec_push(ransom_rule.patterns, yara_pattern_from_string(str_from("$r2"), str_from("bitcoin")));
    vec_push(ransom_rule.patterns, yara_pattern_from_string(str_from("$r3"), str_from("decrypt")));
    vec_push(ransom_rule.patterns, yara_pattern_from_string(str_from("$r4"), str_from("ransom")));
    ransom_rule.cond_type = YARA_COND_AT_LEAST;
    ransom_rule.cond_count = 2;
    ransom_rule.patterns = ransom_rule.patterns;  # ensure assignment
    yara_engine_add_rule(engine, ransom_rule);

    # Rule: Detect embedded PE in non-PE file
    var embedded_pe = yara_rule_new(str_from("EmbeddedPE"));
    embedded_pe.description = str_from("Contains an embedded PE executable");
    embedded_pe.severity = SEVERITY_HIGH;
    vec_push(embedded_pe.tags, str_from("embedded"));
    vec_push(embedded_pe.tags, str_from("pe"));
    vec_push(embedded_pe.patterns, yara_pattern_from_hex(str_from("$mz"), str_from("4D 5A")));
    vec_push(embedded_pe.patterns, yara_pattern_from_string(str_from("$pe"), str_from("This program cannot be run in DOS mode")));
    embedded_pe.cond_type = YARA_COND_ALL;
    embedded_pe.constraints.min_file_size = 512;
    yara_engine_add_rule(engine, embedded_pe);
}

# ================================================================
# ================================================================
#
#   PART 3 — Priority Queue, Quarantine, Report, Hoosh, Daimon,
#            AI Registration, CLI Entry Point
#
