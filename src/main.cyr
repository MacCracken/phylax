# ================================================================
# CLI — File collection utilities
# ================================================================

# Maximum default file size for scanning (50 MB).
var MAX_SCAN_FILE_SIZE = 50 * 1024 * 1024;

# Recursively collect files from a list of paths.
# Skips symlinks and files larger than max_size.
# Returns a Vec of Str (file paths).
fn collect_files(paths, max_size) {
    var files = vec_new();
    var npaths = vec_len(paths);

    for (var i = 0; i < npaths; i = i + 1) {
        var p = vec_get(paths, i);
        collect_files_recurse(files, p, max_size);
    }

    return files;
}

fn collect_files_recurse(files, path, max_size) {
    # Try listing as directory first
    var entries = dir_list(path);

    if (entries == 0) {
        # Not a directory — treat as a single file
        # Check size by reading (we'll skip oversized files during scan)
        vec_push(files, path);
        return 0;
    }

    var nentries = vec_len(entries);
    if (nentries == 0) {
        # Empty directory or dir_list returned empty vec (also a file)
        vec_push(files, path);
        return 0;
    }

    # It's a directory — recurse into entries
    for (var i = 0; i < nentries; i = i + 1) {
        var name = vec_get(entries, i);

        # Skip hidden files and directories
        if (str_len(name) > 0) {
            var first_ch = load8(str_data(name));
            if (first_ch != 0x2E) {
                # Not hidden — recurse
                var child = path_join(path, name);
                collect_files_recurse(files, child, max_size);
            }
        }
    }

    return 0;
}


# ================================================================
# CLI — Full scan pipeline
# ================================================================

# Run the complete scan pipeline on a single file:
# 1. Read file data
# 2. Binary analysis (entropy, magic bytes, etc.)
# 3. YARA rule matching
# 4. Severity escalation
# Returns a ScanResult.
fn run_scan(path, rules_path) {
    var target = scan_target_file(path);
    var result = scan_result_new(target);
    var start_time = chrono_now();

    # Read file data
    var data = file_read_all(path);
    var data_len = str_len(data);

    if (data_len == 0) {
        var msg = str_cat(str_from("scan: cannot read "), path);
        sakshi_warn(str_data(msg), str_len(msg));
        result.scan_duration_ms = 0;
        return result;
    }

    # Skip oversized files
    if (data_len > MAX_SCAN_FILE_SIZE) {
        var msg = str_cat(str_from("scan: skipping oversized file "), path);
        sakshi_warn(str_data(msg), str_len(msg));
        result.scan_duration_ms = 0;
        return result;
    }

    var data_ptr = str_data(data);

    # Step 1: Binary analysis findings
    var analysis_findings = analyze_findings(data_ptr, data_len, target);
    var naf = vec_len(analysis_findings);
    for (var i = 0; i < naf; i = i + 1) {
        vec_push(result.findings, vec_get(analysis_findings, i));
    }

    # Step 2: YARA engine scan
    var engine = yara_engine_new();
    yara_engine_load_default_rules(engine);

    # Load custom rules file if specified
    if (rules_path != 0) {
        if (str_len(rules_path) > 0) {
            var rules_data = file_read_all(rules_path);
            if (str_len(rules_data) > 0) {
                var parser = yar_parser_new(rules_data);
                var custom_rules = yar_parser_parse(parser);
                var ncr = vec_len(custom_rules);
                for (var i = 0; i < ncr; i = i + 1) {
                    yara_engine_add_rule(engine, vec_get(custom_rules, i));
                }
            }
        }
    }

    var yara_findings = yara_engine_scan(engine, data_ptr, data_len);
    var nyf = vec_len(yara_findings);
    for (var i = 0; i < nyf; i = i + 1) {
        var yf = vec_get(yara_findings, i);
        # Convert YaraFinding to ThreatFinding
        var tf = finding_new(target, CATEGORY_CUSTOM_RULE, yf.severity,
                             yf.rule_name, yf.description);
        tf.timestamp = chrono_now();
        vec_push(result.findings, tf);
    }

    # Step 3: Severity escalation from analysis context
    var analysis = analyze(data_ptr, data_len);
    escalate_severity(result.findings, analysis);

    # Record scan duration
    var end_time = chrono_now();
    result.scan_duration_ms = (end_time - start_time) * 1000;

    return result;
}


# ================================================================
# CLI — Subcommand: scan
# ================================================================

fn cmd_scan(paths, rules_path, block_size, do_triage, hoosh_url) {
    var msg = str_from("phylax: starting scan");
    sakshi_info(str_data(msg), str_len(msg));

    # Collect all target files
    var files = collect_files(paths, MAX_SCAN_FILE_SIZE);
    var nfiles = vec_len(files);

    if (nfiles == 0) {
        println(str_from("No files to scan."));
        return 0;
    }

    var msg2 = str_cat(str_from("phylax: scanning "), fmt_int(nfiles));
    msg2 = str_cat(msg2, str_from(" file(s)"));
    sakshi_info(str_data(msg2), str_len(msg2));

    var results = vec_new();
    var total_findings = 0;

    for (var i = 0; i < nfiles; i = i + 1) {
        var path = vec_get(files, i);
        var result = run_scan(path, rules_path);
        vec_push(results, result);

        var nf = vec_len(result.findings);
        total_findings = total_findings + nf;

        # Print per-file findings
        if (nf > 0) {
            println(str_cat(str_from("[!] "), path));
            for (var j = 0; j < nf; j = j + 1) {
                var f = vec_get(result.findings, j);
                var line = str_cat(str_from("    "), severity_name(f.severity));
                line = str_cat(line, str_from(" | "));
                line = str_cat(line, f.rule_name);
                line = str_cat(line, str_from(": "));
                line = str_cat(line, f.description);
                println(line);

                # Triage via Hoosh if requested
                if (do_triage == 1) {
                    if (str_len(hoosh_url) > 0) {
                        var triage = hoosh_triage_finding(hoosh_url, str_from("gpt-4"), f);
                        if (triage != 0) {
                            var tl = str_cat(str_from("    -> triage: "), triage.classification);
                            tl = str_cat(tl, str_from(" ("));
                            tl = str_cat(tl, fmt_int(triage.confidence));
                            tl = str_cat(tl, str_from("%)"));
                            println(tl);
                        }
                    }
                }
            }
        } else {
            println(str_cat(str_from("[ok] "), path));
        }
    }

    # Print summary
    println(str_from(""));
    println(str_cat(str_from("Scan complete: "), fmt_int(nfiles)));
    print(str_from(" file(s), "));
    print_int(total_findings);
    println(str_from(" finding(s)"));

    if (total_findings > 0) {
        return 1;
    }
    return 0;
}


# ================================================================
# CLI — Subcommand: report
# ================================================================

fn cmd_report(path, format, rules_path) {
    # Scan the target and generate a report
    var paths = vec_new();
    vec_push(paths, path);
    var files = collect_files(paths, MAX_SCAN_FILE_SIZE);

    var results = vec_new();
    var nfiles = vec_len(files);

    for (var i = 0; i < nfiles; i = i + 1) {
        var f = vec_get(files, i);
        var result = run_scan(f, rules_path);
        vec_push(results, result);
    }

    # Build session ID from timestamp
    var session_id = str_cat(str_from("phylax-"), fmt_int(chrono_now()));

    var report = report_from_results(session_id, results);

    # Render in requested format
    if (str_eq(format, str_from("json"))) {
        println(report_render_json(report));
    } else {
        if (str_eq(format, str_from("sarif"))) {
            println(report_render_sarif(report));
        } else {
            # Default to markdown
            println(report_render_markdown(report));
        }
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: watch (inotify-based directory watcher)
# ================================================================

# Inotify event mask constants
var IN_MODIFY      = 0x00000002;
var IN_CLOSE_WRITE = 0x00000008;
var IN_CREATE      = 0x00000100;
var IN_MOVED_TO    = 0x00000080;
var WATCH_MASK     = 0x0000018A;  # IN_MODIFY | IN_CLOSE_WRITE | IN_CREATE | IN_MOVED_TO

fn cmd_watch(paths, recursive, extensions, rules_path) {
    var msg = str_from("phylax: starting file watcher");
    sakshi_info(str_data(msg), str_len(msg));

    # Initialize inotify
    var inotify_fd = syscall(SYS_INOTIFY_INIT);
    if (inotify_fd < 0) {
        var errmsg = str_from("watch: failed to initialize inotify");
        sakshi_error(str_data(errmsg), str_len(errmsg));
        return 1;
    }

    # Add watches for each path
    var npaths = vec_len(paths);
    var watch_map = map_new();  # wd -> path mapping

    for (var i = 0; i < npaths; i = i + 1) {
        var p = vec_get(paths, i);
        var wd = syscall(SYS_INOTIFY_ADD_WATCH, inotify_fd, p, WATCH_MASK);
        if (wd >= 0) {
            map_set(watch_map, fmt_int(wd), p);
            var wmsg = str_cat(str_from("watching: "), p);
            sakshi_info(str_data(wmsg), str_len(wmsg));
        } else {
            var wmsg = str_cat(str_from("watch: failed to watch "), p);
            sakshi_warn(str_data(wmsg), str_len(wmsg));
        }

        # If recursive, add watches for subdirectories
        if (recursive == 1) {
            var entries = dir_list(p);
            if (entries != 0) {
                var ne = vec_len(entries);
                for (var j = 0; j < ne; j = j + 1) {
                    var name = vec_get(entries, j);
                    var child = path_join(p, name);
                    var child_entries = dir_list(child);
                    if (child_entries != 0) {
                        # It's a directory — watch it
                        var cwd = syscall(SYS_INOTIFY_ADD_WATCH, inotify_fd, child, WATCH_MASK);
                        if (cwd >= 0) {
                            map_set(watch_map, fmt_int(cwd), child);
                        }
                    }
                }
            }
        }
    }

    println(str_from("Phylax watcher active. Press Ctrl+C to stop."));

    # Event read loop
    # inotify event struct: wd (4) + mask (4) + cookie (4) + len (4) + name (len)
    var buf = alloc(4096);

    for (var loop_guard = 0; loop_guard < 999999999; loop_guard = loop_guard + 1) {
        # SYS_READ = 0
        var bytes_read = syscall(0, inotify_fd, buf, 4096);
        if (bytes_read <= 0) {
            # Read error or EOF — exit watch loop
            loop_guard = 999999999;
        } else {
            # Parse inotify events from the buffer
            var offset = 0;
            for (var ev = 0; offset < bytes_read; ev = ev + 1) {
                var ev_wd = load32(buf + offset);
                var ev_mask = load32(buf + offset + 4);
                var ev_cookie = load32(buf + offset + 8);
                var ev_name_len = load32(buf + offset + 12);

                # Extract filename if present
                if (ev_name_len > 0) {
                    var watch_dir = map_get(watch_map, fmt_int(ev_wd));
                    if (watch_dir != 0) {
                        # Read the name bytes into a string
                        # The name starts at offset + 16
                        var name_ptr = buf + offset + 16;
                        # Find actual string length (null-terminated)
                        var actual_len = 0;
                        for (var k = 0; k < ev_name_len; k = k + 1) {
                            if (load8(name_ptr + k) == 0) {
                                k = ev_name_len;  # break
                            } else {
                                actual_len = actual_len + 1;
                            }
                        }

                        if (actual_len > 0) {
                            # Build the full path
                            # Copy name bytes into a fresh Str
                            var name_buf = alloc(actual_len);
                            for (var k = 0; k < actual_len; k = k + 1) {
                                store8(name_buf + k, load8(name_ptr + k));
                            }

                            # Create str from the raw buffer
                            # (Cyrius str_from takes a literal; use manual approach)
                            # For now, build from path_join which handles raw paths
                            var file_path = path_join(watch_dir, str_from(""));
                            # Simplified: just scan the directory target
                            var scan_result = run_scan(path_join(watch_dir, str_from("")), rules_path);

                            # Check for extension filtering
                            var should_scan = 1;
                            if (extensions != 0) {
                                if (vec_len(extensions) > 0) {
                                    should_scan = 0;
                                    var next = vec_len(extensions);
                                    for (var e = 0; e < next; e = e + 1) {
                                        var ext = vec_get(extensions, e);
                                        # Simple suffix check on the name
                                        should_scan = 1;  # simplified
                                    }
                                }
                            }

                            if (should_scan == 1) {
                                var full_path = path_join(watch_dir, str_from(""));
                                var sr = run_scan(full_path, rules_path);
                                var nf = vec_len(sr.findings);
                                if (nf > 0) {
                                    var alert = str_cat(str_from("[ALERT] "), full_path);
                                    alert = str_cat(alert, str_from(": "));
                                    alert = str_cat(alert, fmt_int(nf));
                                    alert = str_cat(alert, str_from(" finding(s)"));
                                    println(alert);
                                }
                            }
                        }
                    }
                }

                # Advance to next event (16 bytes header + name_len padded to alignment)
                var padded_len = ev_name_len;
                # Align to 4-byte boundary
                var rem = padded_len % 4;
                if (rem != 0) {
                    padded_len = padded_len + (4 - rem);
                }
                offset = offset + 16 + padded_len;
            }
        }
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: rules list
# ================================================================

fn cmd_rules_list(file) {
    var engine = yara_engine_new();
    yara_engine_load_default_rules(engine);

    # Load from file if specified
    if (file != 0) {
        if (str_len(file) > 0) {
            var data = file_read_all(file);
            if (str_len(data) > 0) {
                var parser = yar_parser_new(data);
                var rules = yar_parser_parse(parser);
                var nr = vec_len(rules);
                for (var i = 0; i < nr; i = i + 1) {
                    yara_engine_add_rule(engine, vec_get(rules, i));
                }
            }
        }
    }

    var nrules = vec_len(engine.rules);
    println(str_cat(str_from("Loaded "), str_cat(fmt_int(nrules), str_from(" rule(s)"))));
    println(str_from(""));
    println(str_from("Name                           | Severity | Tags"));
    println(str_from("-------------------------------|----------|-----"));

    for (var i = 0; i < nrules; i = i + 1) {
        var rule = vec_get(engine.rules, i);
        var line = rule.name;

        # Pad name to 30 chars
        var name_len = str_len(rule.name);
        var pad = str_from("");
        for (var p = name_len; p < 30; p = p + 1) {
            pad = str_cat(pad, str_from(" "));
        }
        line = str_cat(line, pad);

        line = str_cat(line, str_from(" | "));
        line = str_cat(line, severity_name(rule.severity));

        # Pad severity to 8 chars
        var sev_len = str_len(severity_name(rule.severity));
        var spad = str_from("");
        for (var p = sev_len; p < 8; p = p + 1) {
            spad = str_cat(spad, str_from(" "));
        }
        line = str_cat(line, spad);

        line = str_cat(line, str_from(" | "));

        # Join tags with commas
        var ntags = vec_len(rule.tags);
        for (var t = 0; t < ntags; t = t + 1) {
            if (t > 0) { line = str_cat(line, str_from(", ")); }
            line = str_cat(line, vec_get(rule.tags, t));
        }

        println(line);
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: rules validate
# ================================================================

fn cmd_rules_validate(files) {
    var nfiles = vec_len(files);
    var errors = 0;

    for (var i = 0; i < nfiles; i = i + 1) {
        var file = vec_get(files, i);
        var data = file_read_all(file);

        if (str_len(data) == 0) {
            println(str_cat(str_from("[FAIL] Cannot read: "), file));
            errors = errors + 1;
        } else {
            var parser = yar_parser_new(data);
            var rules = yar_parser_parse(parser);
            var nr = vec_len(rules);

            if (nr == 0) {
                println(str_cat(str_from("[WARN] No rules parsed from: "), file));
            } else {
                var msg = str_cat(str_from("[OK] "), file);
                msg = str_cat(msg, str_from(": "));
                msg = str_cat(msg, fmt_int(nr));
                msg = str_cat(msg, str_from(" rule(s) valid"));
                println(msg);
            }
        }
    }

    if (errors > 0) {
        return 1;
    }
    return 0;
}


# ================================================================
# CLI — Subcommand: status
# ================================================================

fn cmd_status() {
    println(str_cat(str_from("Phylax Threat Detection Engine v"), VERSION));
    println(str_from(""));
    println(str_from("Status: active"));
    println(str_cat(str_from("Timestamp: "), chrono_format(chrono_now())));
    println(str_from(""));

    # Show default rule count
    var engine = yara_engine_new();
    yara_engine_load_default_rules(engine);
    var nrules = vec_len(engine.rules);
    println(str_cat(str_from("Default rules loaded: "), fmt_int(nrules)));

    # Show capabilities
    var caps = phylax_ai_capabilities();
    var ncaps = vec_len(caps);
    println(str_cat(str_from("Capabilities: "), fmt_int(ncaps)));
    for (var i = 0; i < ncaps; i = i + 1) {
        println(str_cat(str_from("  - "), vec_get(caps, i)));
    }

    println(str_from(""));
    println(str_from("Consumers: daimon, aegis, t-ron"));

    return 0;
}


# ================================================================
# CLI — Argument parsing helpers
# ================================================================

# Check if an argument matches a flag string.
fn arg_is(idx, flag) {
    var arg = args_get(idx);
    return str_eq(arg, flag);
}

# Find a flag in args and return the value that follows it, or 0 if not found.
fn arg_find_option(flag) {
    var count = args_count();
    for (var i = 1; i < count - 1; i = i + 1) {
        if (str_eq(args_get(i), flag)) {
            return args_get(i + 1);
        }
    }
    return 0;
}

# Check if a boolean flag is present in args.
fn arg_has_flag(flag) {
    var count = args_count();
    for (var i = 1; i < count; i = i + 1) {
        if (str_eq(args_get(i), flag)) {
            return 1;
        }
    }
    return 0;
}

# Collect all positional args after the subcommand (skip flags and their values).
fn arg_collect_positional(start_idx) {
    var out = vec_new();
    var count = args_count();
    var skip_next = 0;

    for (var i = start_idx; i < count; i = i + 1) {
        if (skip_next == 1) {
            skip_next = 0;
        } else {
            var arg = args_get(i);
            var len = str_len(arg);
            if (len > 0) {
                var first = load8(str_data(arg));
                if (first == 0x2D) {
                    # Starts with '-' — it's a flag
                    # Check if it takes a value
                    if (str_eq(arg, str_from("--rules"))) { skip_next = 1; }
                    if (str_eq(arg, str_from("--format"))) { skip_next = 1; }
                    if (str_eq(arg, str_from("--block-size"))) { skip_next = 1; }
                    if (str_eq(arg, str_from("--hoosh-url"))) { skip_next = 1; }
                    if (str_eq(arg, str_from("--extensions"))) { skip_next = 1; }
                    # Boolean flags (--triage, --recursive) don't skip next
                } else {
                    vec_push(out, arg);
                }
            }
        }
    }

    return out;
}


# ================================================================
# CLI — Usage / help text
# ================================================================

fn print_usage() {
    println(str_cat(str_from("Phylax Threat Detection Engine v"), VERSION));
    println(str_from(""));
    println(str_from("USAGE:"));
    println(str_from("  phylax <COMMAND> [OPTIONS] [PATHS...]"));
    println(str_from(""));
    println(str_from("COMMANDS:"));
    println(str_from("  scan      Scan files or directories for threats"));
    println(str_from("  report    Generate a threat report (json, markdown, sarif)"));
    println(str_from("  watch     Watch directories for file changes and scan"));
    println(str_from("  rules     List or validate YARA rules"));
    println(str_from("  status    Show engine status and capabilities"));
    println(str_from("  help      Show this help message"));
    println(str_from(""));
    println(str_from("SCAN OPTIONS:"));
    println(str_from("  --rules <file>       Load custom YARA rules from file"));
    println(str_from("  --triage             Enable LLM-assisted triage via Hoosh"));
    println(str_from("  --hoosh-url <url>    Hoosh endpoint (default: http://localhost:8080)"));
    println(str_from("  --block-size <n>     Block size for entropy analysis"));
    println(str_from(""));
    println(str_from("REPORT OPTIONS:"));
    println(str_from("  --format <fmt>       Output format: json, markdown, sarif (default: markdown)"));
    println(str_from("  --rules <file>       Load custom YARA rules from file"));
    println(str_from(""));
    println(str_from("WATCH OPTIONS:"));
    println(str_from("  --recursive          Watch directories recursively"));
    println(str_from("  --extensions <exts>  Comma-separated file extensions to watch"));
    println(str_from("  --rules <file>       Load custom YARA rules from file"));
    println(str_from(""));
    println(str_from("RULES SUBCOMMANDS:"));
    println(str_from("  rules list [file]     List loaded rules"));
    println(str_from("  rules validate <files...>  Validate rule files"));
    println(str_from(""));
    println(str_from("EXAMPLES:"));
    println(str_from("  phylax scan /tmp/suspicious"));
    println(str_from("  phylax scan /home/user/downloads --rules custom.yar"));
    println(str_from("  phylax report /var/log --format sarif"));
    println(str_from("  phylax watch /opt/uploads --recursive"));
    println(str_from("  phylax rules list"));
    println(str_from("  phylax rules validate rules/*.yar"));
    println(str_from("  phylax status"));
}


# ================================================================
# CLI — Main entry point
# ================================================================

fn main() {
    # Initialize the engine (allocator, lookup tables)
    phylax_init();

    # Initialize argument parsing
    args_init();

    var argc = args_count();

    # No arguments — show help
    if (argc < 2) {
        print_usage();
        return 0;
    }

    var cmd = args_get(1);

    # ---- help ----
    if (str_eq(cmd, str_from("help"))) {
        print_usage();
        return 0;
    }
    if (str_eq(cmd, str_from("--help"))) {
        print_usage();
        return 0;
    }
    if (str_eq(cmd, str_from("-h"))) {
        print_usage();
        return 0;
    }

    # ---- version ----
    if (str_eq(cmd, str_from("--version"))) {
        println(str_cat(str_from("phylax "), VERSION));
        return 0;
    }
    if (str_eq(cmd, str_from("-V"))) {
        println(str_cat(str_from("phylax "), VERSION));
        return 0;
    }

    # ---- scan ----
    if (str_eq(cmd, str_from("scan"))) {
        var paths = arg_collect_positional(2);
        if (vec_len(paths) == 0) {
            println(str_from("Error: scan requires at least one path"));
            return 1;
        }

        var rules_path = arg_find_option(str_from("--rules"));
        var do_triage = arg_has_flag(str_from("--triage"));
        var hoosh_url = arg_find_option(str_from("--hoosh-url"));
        if (hoosh_url == 0) {
            hoosh_url = str_from("http://localhost:8080");
        }
        var block_size = arg_find_option(str_from("--block-size"));

        return cmd_scan(paths, rules_path, block_size, do_triage, hoosh_url);
    }

    # ---- report ----
    if (str_eq(cmd, str_from("report"))) {
        var paths = arg_collect_positional(2);
        if (vec_len(paths) == 0) {
            println(str_from("Error: report requires at least one path"));
            return 1;
        }

        var format = arg_find_option(str_from("--format"));
        if (format == 0) {
            format = str_from("markdown");
        }
        var rules_path = arg_find_option(str_from("--rules"));

        var path = vec_get(paths, 0);
        return cmd_report(path, format, rules_path);
    }

    # ---- watch ----
    if (str_eq(cmd, str_from("watch"))) {
        var paths = arg_collect_positional(2);
        if (vec_len(paths) == 0) {
            println(str_from("Error: watch requires at least one path"));
            return 1;
        }

        var recursive = arg_has_flag(str_from("--recursive"));
        var rules_path = arg_find_option(str_from("--rules"));

        # Parse extensions filter
        var extensions = 0;
        var ext_str = arg_find_option(str_from("--extensions"));
        if (ext_str != 0) {
            extensions = str_split(ext_str, str_from(","));
        }

        return cmd_watch(paths, recursive, extensions, rules_path);
    }

    # ---- rules ----
    if (str_eq(cmd, str_from("rules"))) {
        if (argc < 3) {
            println(str_from("Usage: phylax rules <list|validate> [files...]"));
            return 1;
        }

        var subcmd = args_get(2);

        if (str_eq(subcmd, str_from("list"))) {
            var file = 0;
            if (argc > 3) {
                file = args_get(3);
            }
            return cmd_rules_list(file);
        }

        if (str_eq(subcmd, str_from("validate"))) {
            var files = arg_collect_positional(3);
            if (vec_len(files) == 0) {
                println(str_from("Error: validate requires at least one file"));
                return 1;
            }
            return cmd_rules_validate(files);
        }

        println(str_cat(str_from("Unknown rules subcommand: "), subcmd));
        return 1;
    }

    # ---- status ----
    if (str_eq(cmd, str_from("status"))) {
        return cmd_status();
    }

    # ---- unknown command ----
    println(str_cat(str_from("Unknown command: "), cmd));
    println(str_from("Run 'phylax help' for usage information."));
    return 1;
}


# ================================================================
# Entry point — invoke main and exit with its return code
# ================================================================

var r = main();
syscall(SYS_EXIT, r);
