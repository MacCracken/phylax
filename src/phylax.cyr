}

fn pearson_lookup(idx) {
    return load8(PEARSON_TABLE_PTR + (idx & 255));
}

# Pearson hash of 3 values: table[table[a ^ b] ^ c]
fn pearson_hash2(a, b, c) {
    return pearson_lookup(pearson_lookup(a ^ b) ^ c);
}

# Log-based length encoding to 8 bits
fn tlsh_length_encode(len) {
    if (len == 0) { return 0; }
    # Approximate log2(len) * 8 using integer arithmetic
    var log2 = 0;
    var tmp = len;
    while (tmp > 1) {
        log2 = log2 + 1;
        tmp = tmp >> 1;
    }
    # Fractional part approximation: use f64
    var flen = f64_from(len);
    var flog = f64_log2(flen);
    var result = f64_to(f64_mul(flog, f64_from(8)));
    if (result > 255) { result = 255; }
    if (result < 0) { result = 0; }
    return result;
}

fn tlsh_diff_byte(a, b) {
    var d = a - b;
    if (d < 0) { d = 0 - d; }
    return d;
}

fn tlsh_diff_nibble(a, b) {
    var lo_a = a & 15;
    var lo_b = b & 15;
    var hi_a = (a >> 4) & 15;
    var hi_b = (b >> 4) & 15;
    var lo_diff = lo_a - lo_b;
    if (lo_diff < 0) { lo_diff = 0 - lo_diff; }
    var hi_diff = hi_a - hi_b;
    if (hi_diff < 0) { hi_diff = 0 - hi_diff; }
    return lo_diff + hi_diff;
}

# Compute the TLSH hash of a byte slice
# Returns TlshHash ptr, or 0 if data is too short or insufficient variance
fn tlsh_hash(data, len) {
    if (len < TLSH_MIN_DATA_LEN) { return 0; }

    # Ensure Pearson table is initialized
    if (PEARSON_TABLE_PTR == 0) { init_pearson_table(); }

    # Step 1: Fill buckets using sliding window Pearson hash
    var buckets = alloc(TLSH_NUM_BUCKETS * 8);
    for (var i = 0; i < TLSH_NUM_BUCKETS; i = i + 1) {
        store64(buckets + i * 8, 0);
    }
    var checksum = 0;

    if (len >= TLSH_WINDOW_SIZE) {
        for (var i = TLSH_WINDOW_SIZE - 1; i < len; i = i + 1) {
            # Window: data[i+1-WINDOW_SIZE .. i]
            var w0 = load8(data + i + 1 - TLSH_WINDOW_SIZE);
            var w1 = load8(data + i + 2 - TLSH_WINDOW_SIZE);
            var w2 = load8(data + i + 3 - TLSH_WINDOW_SIZE);
            var w3 = load8(data + i + 4 - TLSH_WINDOW_SIZE);
            var w4 = load8(data + i);

            # Update checksum
            checksum = pearson_lookup(checksum ^ w0);

            # Hash triplets into bucket indices
            var h1 = pearson_hash2(w0, w1, w2);
            var h2 = pearson_hash2(w0, w1, w3);
            var h3 = pearson_hash2(w0, w2, w3);
            var h4 = pearson_hash2(w0, w1, w4);
            var h5 = pearson_hash2(w0, w2, w4);
            var h6 = pearson_hash2(w0, w3, w4);

            store64(buckets + h1 * 8, load64(buckets + h1 * 8) + 1);
            store64(buckets + h2 * 8, load64(buckets + h2 * 8) + 1);
            store64(buckets + h3 * 8, load64(buckets + h3 * 8) + 1);
            store64(buckets + h4 * 8, load64(buckets + h4 * 8) + 1);
            store64(buckets + h5 * 8, load64(buckets + h5 * 8) + 1);
            store64(buckets + h6 * 8, load64(buckets + h6 * 8) + 1);
        }
    }

    # Step 2: Compute quartile boundaries
    # Collect non-zero bucket values and sort
    var sorted = vec_new();
    for (var i = 0; i < TLSH_NUM_BUCKETS; i = i + 1) {
        var val = load64(buckets + i * 8);
        if (val > 0) { vec_push(sorted, val); }
    }
    var slen = vec_len(sorted);
    if (slen < 4) { return 0; }  # insufficient variance

    # Insertion sort (N <= 256, fast enough)
    for (var i = 1; i < slen; i = i + 1) {
        var key = vec_get(sorted, i);
        var j = i - 1;
        while (j >= 0) {
            if (vec_get(sorted, j) <= key) {
                j = -1;  # break
            } else {
                vec_set(sorted, j + 1, vec_get(sorted, j));
                j = j - 1;
            }
        }
        if (j == -1) {
            vec_set(sorted, 0, key);
        } else {
            vec_set(sorted, j + 1, key);
        }
    }

    var q1 = vec_get(sorted, slen / 4);
    var q2 = vec_get(sorted, slen / 2);
    var q3 = vec_get(sorted, slen * 3 / 4);

    # Step 3: Encode buckets as 2-bit quartile values (4 buckets per byte)
    var body_len = TLSH_NUM_BUCKETS / 4;  # 64 bytes
    var body = alloc(body_len);
    for (var i = 0; i < body_len; i = i + 1) {
        store8(body + i, 0);
    }

    for (var i = 0; i < TLSH_NUM_BUCKETS; i = i + 1) {
        var bval = load64(buckets + i * 8);
        var code = 0;
        if (bval > q1) { code = 1; }
        if (bval > q2) { code = 2; }
        if (bval > q3) { code = 3; }
        var byte_idx = i / 4;
        var bit_shift = (i & 3) * 2;
        var old_byte = load8(body + byte_idx);
        store8(body + byte_idx, old_byte | (code << bit_shift));
    }

    # Step 4: Encode header
    var lvalue = tlsh_length_encode(len);
    var q1_ratio = 0;
    if (q2 > 0) { q1_ratio = (q1 * 100) / q2; }
    if (q1_ratio > 15) { q1_ratio = 15; }
    var q2_ratio = 0;
    if (q3 > 0) { q2_ratio = (q2 * 100) / q3; }
    if (q2_ratio > 15) { q2_ratio = 15; }

    # Step 5: Build hex digest: "T1" + checksum(2) + length(2) + qratios(2) + body(128)
    # Total: 2 + 2 + 2 + 2 + 128 = 136 chars
    var dlen_total = 2 + 2 + 2 + 2 + body_len * 2;
    var dbuf = alloc(dlen_total + 1);
    store8(dbuf, 84);       # 'T'
    store8(dbuf + 1, 49);   # '1'
    var pos = 2;

    # Checksum (2 hex chars)
    store8(dbuf + pos, hex_nibble((checksum >> 4) & 15));
    store8(dbuf + pos + 1, hex_nibble(checksum & 15));
    pos = pos + 2;

    # Length (2 hex chars)
    store8(dbuf + pos, hex_nibble((lvalue >> 4) & 15));
    store8(dbuf + pos + 1, hex_nibble(lvalue & 15));
    pos = pos + 2;

    # Q-ratios (1 hex nibble each = 2 chars)
    store8(dbuf + pos, hex_nibble(q1_ratio & 15));
    store8(dbuf + pos + 1, hex_nibble(q2_ratio & 15));
    pos = pos + 2;

    # Body (64 bytes = 128 hex chars)
    for (var i = 0; i < body_len; i = i + 1) {
        var b = load8(body + i);
        store8(dbuf + pos, hex_nibble((b >> 4) & 15));
        store8(dbuf + pos + 1, hex_nibble(b & 15));
        pos = pos + 2;
    }

    store8(dbuf + pos, 0);  # null terminator

    var result = alloc(8);
    store64(result, str_from_raw(dbuf, pos));
    return result;
}

# Compute the TLSH distance between two hashes (lower = more similar)
# Returns -1 if either hash is invalid
fn tlsh_distance(a, b) {
    var a_dig = load64(a);
    var b_dig = load64(b);
    var a_len = str_len(a_dig);
    var b_len = str_len(b_dig);

    if (a_len != b_len) { return -1; }

    # Check T1 prefix
    var a_data = str_data(a_dig);
    var b_data = str_data(b_dig);
    if (load8(a_data) != 84 || load8(a_data + 1) != 49) { return -1; }
    if (load8(b_data) != 84 || load8(b_data + 1) != 49) { return -1; }

    # Decode hex bytes after "T1" prefix
    var hex_a = str_substr(a_dig, 2, a_len - 2);
    var hex_b = str_substr(b_dig, 2, b_len - 2);
    var alen_ptr = alloc(8);
    var blen_ptr = alloc(8);
    var a_bytes = hex_decode(hex_a, alen_ptr);
    var b_bytes = hex_decode(hex_b, blen_ptr);
    if (a_bytes == 0 || b_bytes == 0) { return -1; }
    var ablen = load64(alen_ptr);
    var bblen = load64(blen_ptr);
    if (ablen != bblen || ablen < 3) { return -1; }

    var dist = 0;

    # Header distance
    dist = dist + tlsh_diff_byte(load8(a_bytes), load8(b_bytes));           # checksum
    dist = dist + tlsh_diff_byte(load8(a_bytes + 1), load8(b_bytes + 1));   # length
    dist = dist + tlsh_diff_nibble(load8(a_bytes + 2), load8(b_bytes + 2)); # q-ratio

    # Body distance (hamming-like on quartile codes)
    for (var i = 3; i < ablen; i = i + 1) {
        var ab = load8(a_bytes + i);
        var bb = load8(b_bytes + i);
        for (var shift = 0; shift < 8; shift = shift + 2) {
            var qa = (ab >> shift) & 3;
            var qb = (bb >> shift) & 3;
            var d = qa - qb;
            if (d < 0) { d = 0 - d; }
            if (d == 3) { d = 6; }
            dist = dist + d;
        }
    }

    return dist;
}

# ================================================================
# Initialization helper
# ================================================================

fn phylax_init() {
    alloc_init();
    _init_version();
    AGENT_NAME = str_from("phylax");
    init_pearson_table();
}

# ================================================================
# Archive Scanning — Constants
# ================================================================

var ARCHIVE_MAX_DEPTH = 3;           # max recursion depth
var ARCHIVE_MAX_ENTRIES = 1024;      # max entries per archive
var ARCHIVE_MAX_EXPAND = 104857600;  # 100 MB max total expanded size

# ================================================================
# Archive Scanning — ZIP (local file headers, stored entries only)
# ================================================================

fn zip_scan_entries(data, data_len, rules_path, max_depth) {
    var findings = vec_new();
    if (max_depth <= 0) { return findings; }

    var offset = 0;
    var entry_count = 0;

    while (offset + 30 < data_len && entry_count < ARCHIVE_MAX_ENTRIES) {
        # Check for local file header signature PK\x03\x04
        if (read_u32_le(data, offset) != 0x04034B50) { break; }

        var method = read_u16_le(data, offset + 8);
        var comp_size = read_u32_le(data, offset + 18);
        var uncomp_size = read_u32_le(data, offset + 22);
        var name_len = read_u16_le(data, offset + 26);
        var extra_len = read_u16_le(data, offset + 28);

        var data_offset = offset + 30 + name_len + extra_len;

        if (method == 0 && uncomp_size > 0 && data_offset + uncomp_size <= data_len) {
            # Stored (uncompressed) — scan the embedded file
            if (uncomp_size <= ARCHIVE_MAX_EXPAND) {
                var entry_data = data + data_offset;
                var entry_findings = analyze_findings(entry_data, uncomp_size,
                    scan_target_new(SCAN_TARGET_FILE, str_from("embedded")));
                # Also run YARA on embedded content (reuse global engine)
                var engine = get_yara_engine();
                var yf = yara_engine_scan(engine, entry_data, uncomp_size);
                # Merge analysis findings
                var nef = vec_len(entry_findings);
                for (var i = 0; i < nef; i = i + 1) {
                    vec_push(findings, vec_get(entry_findings, i));
                }
                # Merge YARA findings
                var nyf = vec_len(yf);
                for (var i = 0; i < nyf; i = i + 1) {
                    vec_push(findings, vec_get(yf, i));
                }
                # Recursive: check if embedded file is also an archive
                var etype = detect_file_type(entry_data, uncomp_size);
                if (etype == FILETYPE_ZIP) {
                    var sub = zip_scan_entries(entry_data, uncomp_size, rules_path, max_depth - 1);
                    var nsub = vec_len(sub);
                    for (var i = 0; i < nsub; i = i + 1) {
                        vec_push(findings, vec_get(sub, i));
                    }
                }
            }
        }

        # Move to next entry
        offset = data_offset + comp_size;
        entry_count = entry_count + 1;
    }
    return findings;
}

# ================================================================
# Archive Scanning — GZIP (header detection, decompression pending)
# ================================================================

fn gzip_scan(data, data_len, rules_path) {
    var findings = vec_new();
    # GZIP magic check
    if (data_len < 10) { return findings; }
    if (load8(data) != 0x1F || load8(data + 1) != 0x8B) { return findings; }

    var method = load8(data + 2);
    if (method != 8) {
        # Not deflate — non-standard gzip, note but cannot decompress
    }

    # Add informational finding about compressed archive
    var f = finding_new(
        scan_target_new(SCAN_TARGET_FILE, str_from("archive")),
        CATEGORY_SUSPICIOUS, SEVERITY_INFO,
        str_from("compressed_archive"),
        str_from("File is a GZIP compressed archive (embedded content not scanned — deflate decompression pending)")
    );
    vec_push(findings, f);
    return findings;
}

# ================================================================
# Archive Scanning — TAR (POSIX ustar format)
# ================================================================

# Parse an ASCII octal string to integer.
# data = pointer to octal bytes, len = number of bytes to parse.
# Stops at null byte or space. Returns parsed integer value.
fn parse_octal(data, len) {
    var result = 0;
    for (var i = 0; i < len; i = i + 1) {
        var c = load8(data + i);
        if (c == 0 || c == 32) { return result; }  # null or space terminates
        if (c < 48 || c > 55) { return result; }    # non-octal digit terminates
        result = result * 8 + (c - 48);
    }
    return result;
}

fn tar_scan_entries(data, data_len, rules_path, max_depth) {
    var findings = vec_new();
    if (max_depth <= 0) { return findings; }

    var offset = 0;
    var entry_count = 0;

    while (offset + 512 <= data_len && entry_count < ARCHIVE_MAX_ENTRIES) {
        var header = data + offset;

        # Check if header block is all zeros (end of archive)
        var all_zero = 1;
        for (var z = 0; z < 512; z = z + 8) {
            if (load64(header + z) != 0) { all_zero = 0; z = 512; }
        }
        if (all_zero == 1) { break; }

        # Parse size from octal ASCII at offset 124, 12 bytes
        var size = parse_octal(header + 124, 12);

        # Parse typeflag at offset 156
        var typeflag = load8(header + 156);

        # Regular file: typeflag '0' (ASCII 48) or '\0' (0)
        if (typeflag == 48 || typeflag == 0) {
            var file_start = offset + 512;
            if (size > 0 && file_start + size <= data_len && size <= ARCHIVE_MAX_EXPAND) {
                var entry_data = data + file_start;

                # Run analysis on embedded file
                var entry_findings = analyze_findings(entry_data, size,
                    scan_target_new(SCAN_TARGET_FILE, str_from("tar-embedded")));

                # Run YARA on embedded content (reuse global engine)
                var engine = get_yara_engine();
                var yf = yara_engine_scan(engine, entry_data, size);

                # Merge analysis findings
                var nef = vec_len(entry_findings);
                for (var i = 0; i < nef; i = i + 1) {
                    vec_push(findings, vec_get(entry_findings, i));
                }

                # Merge YARA findings
                var nyf = vec_len(yf);
                for (var i = 0; i < nyf; i = i + 1) {
                    vec_push(findings, vec_get(yf, i));
                }

                # Recursive: check if embedded file is also an archive
                var etype = detect_file_type(entry_data, size);
                if (etype == FILETYPE_ZIP) {
                    var sub = zip_scan_entries(entry_data, size, rules_path, max_depth - 1);
                    var nsub = vec_len(sub);
                    for (var i = 0; i < nsub; i = i + 1) {
                        vec_push(findings, vec_get(sub, i));
                    }
                }
                if (etype == FILETYPE_TAR) {
                    var sub = tar_scan_entries(entry_data, size, rules_path, max_depth - 1);
                    var nsub = vec_len(sub);
                    for (var i = 0; i < nsub; i = i + 1) {
                        vec_push(findings, vec_get(sub, i));
                    }
                }
                if (etype == FILETYPE_GZIP) {
                    var sub = gzip_scan(entry_data, size, rules_path);
                    var nsub = vec_len(sub);
                    for (var i = 0; i < nsub; i = i + 1) {
                        vec_push(findings, vec_get(sub, i));
                    }
                }
            }
        }

        # Advance to next entry: header (512) + file data rounded up to 512
        var padded_size = size;
        if (size > 0) {
            var remainder = size % 512;
            if (remainder != 0) {
                padded_size = size + (512 - remainder);
            }
        }
        offset = offset + 512 + padded_size;
        entry_count = entry_count + 1;
    }
    return findings;
}

# ================================================================
# ================================================================
#
#   PART 2 — PE Parser, ELF Parser, YARA Engine
#
# ================================================================
# ================================================================


# ================================================================
# PE Parser — Constants
# ================================================================

var PE_MAGIC_MZ = 0x5A4D;  # "MZ"

# Machine types
var PE_MACHINE_UNKNOWN = 0;
var PE_MACHINE_I386    = 0x014c;
var PE_MACHINE_AMD64   = 0x8664;
var PE_MACHINE_ARM     = 0x01c0;
var PE_MACHINE_ARM64   = 0xAA64;
var PE_MACHINE_IA64    = 0x0200;
var PE_MACHINE_RISCV32 = 0x5032;
var PE_MACHINE_RISCV64 = 0x5064;

# Optional header magic
var PE_OPT_MAGIC_32  = 0x10b;
var PE_OPT_MAGIC_64  = 0x20b;

# Section characteristics flags
var PE_SCN_CNT_CODE            = 0x00000020;
var PE_SCN_MEM_EXECUTE         = 0x20000000;
var PE_SCN_MEM_READ            = 0x40000000;
var PE_SCN_MEM_WRITE           = 0x80000000;

# Data directory indices
var PE_DIR_EXPORT    = 0;
var PE_DIR_IMPORT    = 1;
var PE_DIR_RESOURCE  = 2;
var PE_DIR_SECURITY  = 4;
var PE_DIR_DEBUG     = 6;
var PE_DIR_TLS       = 9;

# DLL characteristics
var PE_IMAGE_DLL = 0x2000;

# Limits
var PE_MAX_SECTIONS = 96;
var PE_MAX_IMPORTS  = 256;
var PE_MAX_EXPORTS  = 1024;

# Rich header sentinel
var PE_RICH_SIGNATURE = 0x68636952;  # "Rich"
var PE_DANS_SIGNATURE = 0x536E6144;  # "DanS"

# Debug types
var PE_DEBUG_TYPE_CODEVIEW = 2;
var PE_CODEVIEW_RSDS       = 0x53445352;  # "RSDS"

# ================================================================
# PE Parser — Read helpers
# ================================================================

# Read little-endian u16 from raw byte buffer
fn read_u16_le(data, offset) {
    return load8(data + offset) | (load8(data + offset + 1) << 8);
}

# Read little-endian u32 from raw byte buffer
fn read_u32_le(data, offset) {
    return load8(data + offset)
         | (load8(data + offset + 1) << 8)
         | (load8(data + offset + 2) << 16)
         | (load8(data + offset + 3) << 24);
}

# Read little-endian u64 from raw byte buffer
fn read_u64_le(data, offset) {
    var lo = read_u32_le(data, offset);
    var hi = read_u32_le(data, offset + 4);
    return lo | (hi << 32);
}

# Read null-terminated ASCII string, up to max_len bytes
fn read_ascii(data, offset, max_len) {
    var buf = alloc(max_len + 1);
    var i = 0;
    while (i < max_len) {
        var ch = load8(data + offset + i);
        if (ch == 0) { i = max_len; }  # break
        else {
            store8(buf + i, ch);
            i = i + 1;
        }
    }
    # Re-scan for actual length (since we jump i on break)
    var len = 0;
    while (len < max_len) {
        if (load8(data + offset + len) == 0) { len = max_len + 1; }  # break
        else { len = len + 1; }
    }
    if (len > max_len) { len = len - max_len - 1 + max_len; }
    # Simpler: just count from buf
    var actual = 0;
    while (actual < max_len) {
        if (load8(data + offset + actual) == 0) {
            return str_from_raw(buf, actual);
        }
        store8(buf + actual, load8(data + offset + actual));
        actual = actual + 1;
    }
    return str_from_raw(buf, max_len);
}

# Read a fixed-length ASCII string (e.g. section name, 8 bytes)
fn read_fixed_ascii(data, offset, len) {
    var buf = alloc(len + 1);
    var actual = 0;
    for (var i = 0; i < len; i = i + 1) {
        var ch = load8(data + offset + i);
        if (ch == 0) { i = len; }  # break
        else {
            store8(buf + actual, ch);
            actual = actual + 1;
        }
    }
    return str_from_raw(buf, actual);
}

# ================================================================
# PE Parser — Structs
# ================================================================

struct PeSection {
    name;             # Str
    virtual_size;     # i64
    virtual_address;  # i64
    raw_data_size;    # i64
    raw_data_offset;  # i64
    characteristics;  # i64
}

fn pe_section_new() {
    var s = alloc(48);
    store64(s, str_from(""));
    store64(s + 8, 0);
    store64(s + 16, 0);
    store64(s + 24, 0);
    store64(s + 32, 0);
    store64(s + 40, 0);
    return s;
}

fn pe_section_is_executable(sec) {
    return (load64(sec + 40) & PE_SCN_MEM_EXECUTE) != 0;
}

fn pe_section_is_writable(sec) {
    return (load64(sec + 40) & PE_SCN_MEM_WRITE) != 0;
}

fn pe_section_contains_code(sec) {
    return (load64(sec + 40) & PE_SCN_CNT_CODE) != 0;
}

struct PeImport {
    dll;       # Str — DLL name
    function;  # Str — function name
}

fn pe_import_new(dll, func) {
    var imp = alloc(16);
    store64(imp, dll);
    store64(imp + 8, func);
    return imp;
}

struct PeRichEntry {
    comp_id;    # i64 — compiler/tool ID
    build_id;   # i64 — build number
    use_count;  # i64 — usage count
}

fn pe_rich_entry_new(comp_id, build_id, use_count) {
    var e = alloc(24);
    store64(e, comp_id);
    store64(e + 8, build_id);
    store64(e + 16, use_count);
    return e;
}

struct PeResource {
    res_type; # i64 — resource type ID
    name;     # Str
    size;     # i64
    offset;   # i64
}

fn pe_resource_new() {
    var r = alloc(32);
    store64(r, 0);
    store64(r + 8, str_from(""));
    store64(r + 16, 0);
    store64(r + 24, 0);
    return r;
}

struct PeCertificate {
    present;  # i64 (0/1)
    offset;   # i64
    size;     # i64
}

fn pe_certificate_new() {
    var c = alloc(24);
    store64(c, 0);
    store64(c + 8, 0);
    store64(c + 16, 0);
    return c;
}

struct PeInfo {
    machine;           # i64 — machine type
    num_sections;      # i64
    timestamp;         # i64
    is_dll;            # i64 (0/1)
    is_64bit;          # i64 (0/1)
    entry_point;       # i64 — address of entry point
    image_base;        # i64
    sections;          # Vec of PeSection
    imports;           # Vec of PeImport (dll-level)
    import_functions;  # Vec of PeImport (function-level)
    exports;           # Vec of Str
    has_tls_callbacks; # i64 (0/1)
    pdb_path;          # Str or 0
    rich_entries;      # Vec of PeRichEntry
    resources;         # Vec of PeResource
    certificate;       # PeCertificate
    opt_offset;        # i64 — offset of optional header
    size_of_opt;       # i64 — size of optional header
}

fn pe_info_new() {
    var p = alloc(144);
    store64(p, 0);
    store64(p + 8, 0);
    store64(p + 16, 0);
    store64(p + 24, 0);
    store64(p + 32, 0);
    store64(p + 40, 0);
    store64(p + 48, 0);
    store64(p + 56, vec_new());
    store64(p + 64, vec_new());
    store64(p + 72, vec_new());
    store64(p + 80, vec_new());
    store64(p + 88, 0);
    store64(p + 96, 0);
    store64(p + 104, vec_new());
    store64(p + 112, vec_new());
    store64(p + 120, pe_certificate_new());
    store64(p + 128, 0);
    store64(p + 136, 0);
    return p;
}

# ================================================================
# PE Parser — Machine name
# ================================================================

fn pe_machine_name(machine) {
    if (machine == PE_MACHINE_I386)    { return str_from("i386"); }
    if (machine == PE_MACHINE_AMD64)   { return str_from("AMD64"); }
    if (machine == PE_MACHINE_ARM)     { return str_from("ARM"); }
    if (machine == PE_MACHINE_ARM64)   { return str_from("ARM64"); }
    if (machine == PE_MACHINE_IA64)    { return str_from("IA64"); }
    if (machine == PE_MACHINE_RISCV32) { return str_from("RISC-V 32"); }
    if (machine == PE_MACHINE_RISCV64) { return str_from("RISC-V 64"); }
    return str_from("Unknown");
}

# ================================================================
# PE Parser — RVA to file offset
# ================================================================

# Convert a Relative Virtual Address to a raw file offset
# Uses the section table to find which section contains the RVA
fn rva_to_offset(pe, rva) {
    var nsec = vec_len(load64(pe + 56));
    for (var i = 0; i < nsec; i = i + 1) {
        var sec = vec_get(load64(pe + 56), i);
        var va = load64(sec + 16);
        var vs = load64(sec + 8);
        if (vs == 0) { vs = load64(sec + 24); }
        if (rva >= va) {
            if (rva < va + vs) {
                return load64(sec + 32) + (rva - va);
            }
        }
    }
    return -1;  # not found
}

# RVA to offset using raw data and section parsing (before PeInfo is built)
fn rva_to_offset_raw(data, data_len, pe_offset, num_sections, sec_table_offset, rva) {
    for (var i = 0; i < num_sections; i = i + 1) {
        var soff = sec_table_offset + i * 40;
        if (soff + 40 > data_len) { return -1; }
        var va = read_u32_le(data, soff + 12);
        var vs = read_u32_le(data, soff + 8);
        var raw_off = read_u32_le(data, soff + 20);
        if (vs == 0) { vs = read_u32_le(data, soff + 16); }
        if (rva >= va) {
            if (rva < va + vs) {
                return raw_off + (rva - va);
            }
        }
    }
    return -1;
}

# ================================================================
# PE Parser — Rich header
# ================================================================

fn parse_rich_header(data, data_len, pe_offset) {
    var entries = vec_new();
    # Rich header sits between DOS stub and PE signature
    # Search backward from pe_offset for "Rich" signature
    if (pe_offset < 16) { return entries; }

    var rich_pos = -1;
    var search_start = 128;  # Skip DOS header
    if (search_start > pe_offset - 8) { search_start = pe_offset - 8; }
    for (var i = pe_offset - 8; i >= search_start; i = i - 4) {
        if (read_u32_le(data, i) == PE_RICH_SIGNATURE) {
            rich_pos = i;
            i = search_start - 1;  # break
        }
    }
    if (rich_pos < 0) { return entries; }

    # XOR key is the dword right after "Rich"
    var xor_key = read_u32_le(data, rich_pos + 4);

    # Find "DanS" marker by decrypting backward
    var dans_pos = -1;
    for (var i = rich_pos - 4; i >= 0; i = i - 4) {
        var decrypted = read_u32_le(data, i) ^ xor_key;
        if (decrypted == PE_DANS_SIGNATURE) {
            dans_pos = i;
            i = -1;  # break
        }
    }
    if (dans_pos < 0) { return entries; }

    # Entries start after DanS + 3 padding dwords (all XOR key)
    var entry_start = dans_pos + 16;
    var pos = entry_start;
    while (pos + 8 <= rich_pos) {
        var raw1 = read_u32_le(data, pos) ^ xor_key;
        var raw2 = read_u32_le(data, pos + 4) ^ xor_key;
        var comp_id = (raw1 >> 16) & 0xFFFF;
        var build_id = raw1 & 0xFFFF;
        var use_count = raw2;
        if (comp_id != 0 || build_id != 0) {
            vec_push(entries, pe_rich_entry_new(comp_id, build_id, use_count));
        }
        pos = pos + 8;
    }
    return entries;
}

fn rich_product_name(product_id) {
    if (product_id == 0) { return str_from("[padding]"); }
    if (product_id == 1) { return str_from("Import"); }
    if (product_id >= 2 && product_id <= 6) { return str_from("VS6.0 (1998)"); }
    if (product_id >= 7 && product_id <= 9) { return str_from("VS2002 (7.0)"); }
    if (product_id >= 10 && product_id <= 13) { return str_from("VS2003 (7.1)"); }
    if (product_id >= 14 && product_id <= 39) { return str_from("VS2005 (8.0)"); }
    if (product_id >= 40 && product_id <= 83) { return str_from("VS2008 (9.0)"); }
    if (product_id >= 84 && product_id <= 146) { return str_from("VS2010 (10.0)"); }
    if (product_id >= 147 && product_id <= 169) { return str_from("VS2012 (11.0)"); }
    if (product_id >= 170 && product_id <= 199) { return str_from("VS2013 (12.0)"); }
    if (product_id >= 200 && product_id <= 219) { return str_from("VS2015 (14.0)"); }
    if (product_id >= 220 && product_id <= 260) { return str_from("VS2017 (14.1)"); }
    if (product_id >= 261 && product_id <= 270) { return str_from("VS2019 (14.2)"); }
    if (product_id >= 271 && product_id <= 280) { return str_from("VS2022 (14.3)"); }
    if (product_id >= 281 && product_id <= 300) { return str_from("VS2022 (14.4+)"); }
    return str_from("Unknown");
}

# ================================================================
# PE Parser — Import parsing
# ================================================================

fn parse_pe_imports(data, data_len, pe) {
    var imports = vec_new();
    var import_funcs = vec_new();

    # Locate import directory from optional header
    var opt_off = load64(pe + 128);
    var is_64 = load64(pe + 32);

    # Data directories start at different offsets for PE32 vs PE32+
    var dd_offset = 0;
    if (is_64) {
        dd_offset = opt_off + 112;  # PE32+: data dirs at offset 112
    } else {
        dd_offset = opt_off + 96;   # PE32: data dirs at offset 96
    }

    # Import directory is entry 1 (index 1)
    var import_dir_off = dd_offset + PE_DIR_IMPORT * 8;
    if (import_dir_off + 8 > data_len) { return imports; }
    var import_rva = read_u32_le(data, import_dir_off);
    var import_size = read_u32_le(data, import_dir_off + 4);
    if (import_rva == 0 || import_size == 0) { return imports; }

    var import_file_off = rva_to_offset(pe, import_rva);
    if (import_file_off < 0) { return imports; }

    # Each import descriptor is 20 bytes
    var count = 0;
    var pos = import_file_off;
    while (count < PE_MAX_IMPORTS) {
        if (pos + 20 > data_len) { count = PE_MAX_IMPORTS; }
        else {
            var ilt_rva  = read_u32_le(data, pos);       # Import Lookup Table RVA
            var name_rva = read_u32_le(data, pos + 12);   # DLL name RVA
            # Null descriptor terminates
            if (ilt_rva == 0) { if (name_rva == 0) { count = PE_MAX_IMPORTS; } }
            if (count < PE_MAX_IMPORTS) {
                if (name_rva != 0) {
                    var name_off = rva_to_offset(pe, name_rva);
                    var dll_name = str_from("unknown");
                    if (name_off >= 0) {
                        if (name_off < data_len) {
                            dll_name = read_ascii(data, name_off, 256);
                        }
                    }
                    vec_push(imports, pe_import_new(dll_name, str_from("")));

                    # Parse the Import Lookup Table for function names
                    if (ilt_rva != 0) {
                        var ilt_off = rva_to_offset(pe, ilt_rva);
                        if (ilt_off >= 0) {
                            var fcount = 0;
                            var fpos = ilt_off;
                            var entry_size = 4;
                            if (is_64) { entry_size = 8; }
                            while (fcount < 512) {
                                if (fpos + entry_size > data_len) { fcount = 512; }
                                else {
                                    var entry = 0;
                                    if (is_64) { entry = read_u64_le(data, fpos); }
                                    else { entry = read_u32_le(data, fpos); }
                                    if (entry == 0) { fcount = 512; }  # end
                                    else {
                                        # Check ordinal flag (high bit)
                                        var ordinal_flag = 0;
                                        if (is_64) { ordinal_flag = (entry >> 63) & 1; }
                                        else { ordinal_flag = (entry >> 31) & 1; }
                                        if (ordinal_flag == 0) {
                                            # Hint/Name entry
                                            var hint_rva = entry & 0x7FFFFFFF;
                                            var hint_off = rva_to_offset(pe, hint_rva);
                                            if (hint_off >= 0) {
                                                if (hint_off + 2 < data_len) {
                                                    var func_name = read_ascii(data, hint_off + 2, 256);
                                                    vec_push(import_funcs,
                                                        pe_import_new(dll_name, func_name));
                                                }
                                            }
                                        } else {
                                            # Ordinal import
                                            var ord = entry & 0xFFFF;
                                            var ord_name = str_cat(str_from("ord:"),
                                                           str_from_int(ord));
                                            vec_push(import_funcs,
                                                pe_import_new(dll_name, ord_name));
                                        }
                                        fcount = fcount + 1;
                                        fpos = fpos + entry_size;
                                    }
                                }
                            }
                        }
                    }
                }
                count = count + 1;
                pos = pos + 20;
            }
        }
    }

    # Store results into PeInfo
    store64(pe + 64, imports);
    store64(pe + 72, import_funcs);
    return imports;
}

# ================================================================
# PE Parser — Export parsing
# ================================================================

fn parse_pe_exports(data, data_len, pe) {
    var exports = vec_new();
    var opt_off = load64(pe + 128);
    var is_64 = load64(pe + 32);

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var export_dir_off = dd_offset + PE_DIR_EXPORT * 8;
    if (export_dir_off + 8 > data_len) { return exports; }
    var export_rva = read_u32_le(data, export_dir_off);
    var export_size = read_u32_le(data, export_dir_off + 4);
    if (export_rva == 0 || export_size == 0) { return exports; }

    var export_file_off = rva_to_offset(pe, export_rva);
    if (export_file_off < 0) { return exports; }
    if (export_file_off + 40 > data_len) { return exports; }

    # Export directory table
    var num_names = read_u32_le(data, export_file_off + 24);
    var name_ptr_rva = read_u32_le(data, export_file_off + 32);
    var name_ptr_off = rva_to_offset(pe, name_ptr_rva);
    if (name_ptr_off < 0) { return exports; }

    var limit = num_names;
    if (limit > PE_MAX_EXPORTS) { limit = PE_MAX_EXPORTS; }

    for (var i = 0; i < limit; i = i + 1) {
        var noff = name_ptr_off + i * 4;
        if (noff + 4 <= data_len) {
            var nrva = read_u32_le(data, noff);
            var str_off = rva_to_offset(pe, nrva);
            if (str_off >= 0) {
                if (str_off < data_len) {
                    var name = read_ascii(data, str_off, 256);
                    vec_push(exports, name);
                }
            }
        }
    }

    store64(pe + 80, exports);
    return exports;
}

# ================================================================
# PE Parser — TLS callback detection
# ================================================================

fn detect_tls_callbacks(data, data_len, pe) {
    var opt_off = load64(pe + 128);
    var is_64 = load64(pe + 32);

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var tls_dir_off = dd_offset + PE_DIR_TLS * 8;
    if (tls_dir_off + 8 > data_len) { return 0; }
    var tls_rva = read_u32_le(data, tls_dir_off);
    if (tls_rva == 0) { return 0; }

    var tls_off = rva_to_offset(pe, tls_rva);
    if (tls_off < 0) { return 0; }

    # TLS directory: callbacks pointer is at offset 12 (PE32) or 24 (PE32+)
    var cb_va = 0;
    if (is_64) {
        if (tls_off + 32 > data_len) { return 0; }
        cb_va = read_u64_le(data, tls_off + 24);
    } else {
        if (tls_off + 16 > data_len) { return 0; }
        cb_va = read_u32_le(data, tls_off + 12);
    }

    if (cb_va != 0) {
        # Convert VA to RVA by subtracting image base
        var cb_rva = cb_va - load64(pe + 48);
        var cb_off = rva_to_offset(pe, cb_rva);
        if (cb_off >= 0) {
            if (cb_off + 4 <= data_len) {
                # Check if at least one callback pointer is non-zero
                var first = 0;
                if (is_64) { first = read_u64_le(data, cb_off); }
                else { first = read_u32_le(data, cb_off); }
                if (first != 0) {
                    store64(pe + 88, 1);
                    return 1;
                }
            }
        }
    }
    return 0;
}

# ================================================================
# PE Parser — Debug directory (PDB path extraction)
# ================================================================

fn parse_debug_directory(data, data_len, pe) {
    var opt_off = load64(pe + 128);
    var is_64 = load64(pe + 32);

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var debug_dir_off = dd_offset + PE_DIR_DEBUG * 8;
    if (debug_dir_off + 8 > data_len) { return 0; }
    var debug_rva = read_u32_le(data, debug_dir_off);
    var debug_size = read_u32_le(data, debug_dir_off + 4);
    if (debug_rva == 0 || debug_size == 0) { return 0; }

    var debug_off = rva_to_offset(pe, debug_rva);
    if (debug_off < 0) { return 0; }

    # Each debug directory entry is 28 bytes
    var num_entries = debug_size / 28;
    for (var i = 0; i < num_entries; i = i + 1) {
        var eoff = debug_off + i * 28;
        if (eoff + 28 > data_len) { return 0; }
        var dtype = read_u32_le(data, eoff + 12);
        if (dtype == PE_DEBUG_TYPE_CODEVIEW) {
            var dsize = read_u32_le(data, eoff + 16);
            var daddr = read_u32_le(data, eoff + 24);   # pointer to raw data
            if (daddr > 0) {
                if (daddr + 24 < data_len) {
                    var sig = read_u32_le(data, daddr);
                    if (sig == PE_CODEVIEW_RSDS) {
                        # RSDS: 4 sig + 16 GUID + 4 age = 24 bytes header
                        var pdb_off = daddr + 24;
                        if (pdb_off < data_len) {
                            var pdb = read_ascii(data, pdb_off, 260);
                            store64(pe + 96, pdb);
                            return 1;
                        }
                    }
                }
            }
        }
    }
    return 0;
}

# ================================================================
# PE Parser — Certificate / Authenticode
# ================================================================

fn parse_pe_certificate(data, data_len, pe) {
    var opt_off = load64(pe + 128);
    var is_64 = load64(pe + 32);

    var dd_offset = 0;
    if (is_64) { dd_offset = opt_off + 112; }
    else { dd_offset = opt_off + 96; }

    var cert_dir_off = dd_offset + PE_DIR_SECURITY * 8;
    if (cert_dir_off + 8 > data_len) { return 0; }
    var cert_offset = read_u32_le(data, cert_dir_off);
    var cert_size = read_u32_le(data, cert_dir_off + 4);
    if (cert_offset > 0) {
        if (cert_size > 0) {
            store64(load64(pe + 120), 1);
            store64(load64(pe + 120) + 8, cert_offset);
            store64(load64(pe + 120) + 16, cert_size);
        }
    }
}

# ================================================================
# PE Parser — Sections
# ================================================================

fn parse_pe_sections(data, data_len, sec_table_offset, num_sections) {
    var sections = vec_new();
    var limit = num_sections;
    if (limit > PE_MAX_SECTIONS) { limit = PE_MAX_SECTIONS; }

    for (var i = 0; i < limit; i = i + 1) {
        var soff = sec_table_offset + i * 40;
        if (soff + 40 > data_len) { return sections; }

        var sec = pe_section_new();
        store64(sec, read_fixed_ascii(data, soff, 8));
        store64(sec + 8, read_u32_le(data, soff + 8));
        store64(sec + 16, read_u32_le(data, soff + 12));
        store64(sec + 24, read_u32_le(data, soff + 16));
        store64(sec + 32, read_u32_le(data, soff + 20));
        store64(sec + 40, read_u32_le(data, soff + 36));
        vec_push(sections, sec);
    }
    return sections;
}

# ================================================================
# PE Parser — Import hash (imphash)
# ================================================================

# Compute MD5-based import hash (simplified — uses Pearson-like hash)
# Real imphash: lowercase "dll.function" concatenated, then MD5.
# We approximate with our string hashing since we lack MD5 in stdlib.
fn compute_imphash(import_funcs) {
    var n = vec_len(import_funcs);
    if (n == 0) { return str_from(""); }

    # Build the canonical import string: "dll.func,dll.func,..."
    var result = str_from("");
    for (var i = 0; i < n; i = i + 1) {
        var imp = vec_get(import_funcs, i);
        var dll = str_lower(load64(imp));
        var func = str_lower(load64(imp + 8));

        # Strip .dll extension if present
        var dlen = str_len(dll);
        if (dlen > 4) {
            var ddata = str_data(dll);
            if (load8(ddata + dlen - 4) == 46) {   # '.'
                if (load8(ddata + dlen - 3) == 100) {  # 'd'
                    if (load8(ddata + dlen - 2) == 108) {  # 'l'
                        if (load8(ddata + dlen - 1) == 108) {  # 'l'
                            dll = str_substr(dll, 0, dlen - 4);
                        }
                    }
                }
            }
        }

        var entry = str_cat(dll, str_cat(str_from("."), func));
        if (i > 0) {
            result = str_cat(result, str_cat(str_from(","), entry));
        } else {
            result = entry;
        }
    }

    # Hash the result string with our Pearson hash, encode as hex
    var rdata = str_data(result);
    var rlen = str_len(result);
    var hash_buf = alloc(16);  # 128-bit hash
    for (var h = 0; h < 16; h = h + 1) {
        var hval = h;
        for (var j = 0; j < rlen; j = j + 1) {
            var idx = (hval ^ load8(rdata + j)) & 0xFF;
            hval = pearson_lookup(idx);
        }
        store8(hash_buf + h, hval & 0xFF);
    }
    return hex_encode(hash_buf, 16);
}

# ================================================================
# PE Parser — Main parse function
# ================================================================

fn parse_pe(data, data_len) {
    # Validate minimum size and MZ signature
    if (data_len < 64) { return 0; }
    var mz = read_u16_le(data, 0);
    if (mz != PE_MAGIC_MZ) { return 0; }

    # e_lfanew: offset to PE signature at offset 0x3C
    var pe_offset = read_u32_le(data, 0x3C);
    if (pe_offset + 4 > data_len) { return 0; }

    # Verify PE\0\0 signature
    if (load8(data + pe_offset) != 80) { return 0; }      # 'P'
    if (load8(data + pe_offset + 1) != 69) { return 0; }  # 'E'
    if (load8(data + pe_offset + 2) != 0) { return 0; }
    if (load8(data + pe_offset + 3) != 0) { return 0; }

    var coff_offset = pe_offset + 4;
    if (coff_offset + 20 > data_len) { return 0; }

    var pe = pe_info_new();

    # COFF header fields
    store64(pe, read_u16_le(data, coff_offset));
    store64(pe + 8, read_u16_le(data, coff_offset + 2));
    store64(pe + 16, read_u32_le(data, coff_offset + 4));
    var size_of_opt_hdr = read_u16_le(data, coff_offset + 16);
    var characteristics = read_u16_le(data, coff_offset + 18);

    store64(pe + 24, 0);
    if (characteristics & PE_IMAGE_DLL) { store64(pe + 24, 1); }

    # Optional header
    var opt_offset = coff_offset + 20;
    store64(pe + 128, opt_offset);
    store64(pe + 136, size_of_opt_hdr);
    if (opt_offset + 2 > data_len) { return 0; }
    var opt_magic = read_u16_le(data, opt_offset);

    if (opt_magic == PE_OPT_MAGIC_64) {
        store64(pe + 32, 1);
        if (opt_offset + 24 > data_len) { return 0; }
        store64(pe + 40, read_u32_le(data, opt_offset + 16));
        store64(pe + 48, read_u64_le(data, opt_offset + 24));
    } else {
        if (opt_magic == PE_OPT_MAGIC_32) {
            store64(pe + 32, 0);
            if (opt_offset + 28 > data_len) { return 0; }
            store64(pe + 40, read_u32_le(data, opt_offset + 16));
            store64(pe + 48, read_u32_le(data, opt_offset + 28));
        } else {
            return 0;  # Unknown optional header magic
        }
    }

    # Section table follows optional header
    var sec_table_offset = opt_offset + size_of_opt_hdr;
    store64(pe + 56, parse_pe_sections(data, data_len, sec_table_offset, load64(pe + 8)));

    # Rich header (between DOS stub and PE signature)
    store64(pe + 104, parse_rich_header(data, data_len, pe_offset));

    # Imports, exports, TLS, debug, certificate
    parse_pe_imports(data, data_len, pe);
    parse_pe_exports(data, data_len, pe);
    detect_tls_callbacks(data, data_len, pe);
    parse_debug_directory(data, data_len, pe);
    parse_pe_certificate(data, data_len, pe);

    return pe;
}


# ================================================================
# ================================================================
# ELF Parser
# ================================================================
# ================================================================

# ================================================================
# ELF Parser — Constants
# ================================================================

# ELF magic: 0x7F 'E' 'L' 'F'
var ELF_MAGIC_0 = 0x7F;
var ELF_MAGIC_1 = 69;   # 'E'
var ELF_MAGIC_2 = 76;   # 'L'
var ELF_MAGIC_3 = 70;   # 'F'

# EI_CLASS
var ELF_CLASS_NONE = 0;
var ELF_CLASS_32   = 1;
var ELF_CLASS_64   = 2;

# EI_DATA (endianness)
var ELF_DATA_NONE = 0;
var ELF_DATA_LSB  = 1;  # little-endian
var ELF_DATA_MSB  = 2;  # big-endian

# EI_OSABI
var ELF_OSABI_NONE    = 0;
var ELF_OSABI_LINUX   = 3;
var ELF_OSABI_FREEBSD = 9;

# e_type
var ELF_ET_NONE = 0;
var ELF_ET_REL  = 1;
var ELF_ET_EXEC = 2;
var ELF_ET_DYN  = 3;
var ELF_ET_CORE = 4;

# e_machine
var ELF_EM_NONE    = 0;
var ELF_EM_386     = 3;
var ELF_EM_ARM     = 40;
var ELF_EM_X86_64  = 62;
var ELF_EM_AARCH64 = 183;
var ELF_EM_RISCV   = 243;

# Section types
var ELF_SHT_NULL     = 0;
var ELF_SHT_PROGBITS = 1;
var ELF_SHT_SYMTAB   = 2;
var ELF_SHT_STRTAB   = 3;
var ELF_SHT_DYNAMIC  = 6;
var ELF_SHT_NOTE     = 7;
var ELF_SHT_NOBITS   = 8;
var ELF_SHT_DYNSYM   = 11;

# Section flags
var ELF_SHF_WRITE     = 0x1;
var ELF_SHF_ALLOC     = 0x2;
var ELF_SHF_EXECINSTR = 0x4;

# Segment types
var ELF_PT_NULL    = 0;
var ELF_PT_LOAD    = 1;
var ELF_PT_DYNAMIC = 2;
var ELF_PT_INTERP  = 3;
var ELF_PT_NOTE    = 4;
var ELF_PT_PHDR    = 6;
var ELF_PT_GNU_EH_FRAME = 0x6474e550;
var ELF_PT_GNU_STACK    = 0x6474e551;
var ELF_PT_GNU_RELRO    = 0x6474e552;

# Segment flags
var ELF_PF_X = 0x1;  # Execute
var ELF_PF_W = 0x2;  # Write
var ELF_PF_R = 0x4;  # Read

# Dynamic tags
var ELF_DT_NULL   = 0;
var ELF_DT_NEEDED = 1;
var ELF_DT_STRTAB = 5;
var ELF_DT_STRSZ  = 10;

# Limits
var ELF_MAX_SECTIONS = 1024;
var ELF_MAX_SYMBOLS  = 4096;

# ================================================================
# ELF Parser — Endian-aware read helpers
# ================================================================

# Read u16 from data at offset, respecting endianness
# little_endian: 1 = LE, 0 = BE
fn elf_read_u16(data, offset, little_endian) {
    if (little_endian) {
        return load8(data + offset) | (load8(data + offset + 1) << 8);
    }
    return (load8(data + offset) << 8) | load8(data + offset + 1);
}

fn elf_read_u32(data, offset, little_endian) {
    if (little_endian) {
        return load8(data + offset)
             | (load8(data + offset + 1) << 8)
             | (load8(data + offset + 2) << 16)
             | (load8(data + offset + 3) << 24);
    }
    return (load8(data + offset) << 24)
         | (load8(data + offset + 1) << 16)
         | (load8(data + offset + 2) << 8)
         | load8(data + offset + 3);
}

fn elf_read_u64(data, offset, little_endian) {
    if (little_endian) {
        var lo = elf_read_u32(data, offset, 1);
        var hi = elf_read_u32(data, offset + 4, 1);
        return lo | (hi << 32);
    }
    var hi = elf_read_u32(data, offset, 0);
    var lo = elf_read_u32(data, offset + 4, 0);
    return (hi << 32) | lo;
}

# ================================================================
# ELF Parser — String table lookup
# ================================================================

# Read a null-terminated string from the string table
fn read_strtab_entry(data, data_len, strtab_offset, name_index) {
    var off = strtab_offset + name_index;
    if (off >= data_len) { return str_from(""); }
    var max = 256;
    if (off + max > data_len) { max = data_len - off; }
    return read_ascii(data, off, max);
}

# ================================================================
# ELF Parser — Structs
# ================================================================

struct ElfSection {
    name;          # Str
    section_type;  # i64
    flags;         # i64
    addr;          # i64
    offset;        # i64
    size;          # i64
}

fn elf_section_new() {
    var s = alloc(48);
    store64(s, str_from(""));
    store64(s + 8, 0);
    store64(s + 16, 0);
    store64(s + 24, 0);
    store64(s + 32, 0);
    store64(s + 40, 0);
    return s;
}

fn elf_section_is_executable(sec) {
    return (load64(sec + 16) & ELF_SHF_EXECINSTR) != 0;
}

fn elf_section_is_writable(sec) {
    return (load64(sec + 16) & ELF_SHF_WRITE) != 0;
}

struct ElfSegment {
    seg_type;   # i64
    flags;      # i64
    vaddr;      # i64
    offset;     # i64
    file_size;  # i64
    mem_size;   # i64
}

fn elf_segment_new() {
    var s = alloc(48);
    store64(s, 0);
    store64(s + 8, 0);
    store64(s + 16, 0);
    store64(s + 24, 0);
    store64(s + 32, 0);
    store64(s + 40, 0);
    return s;
}

struct ElfSecurity {
    has_relro;         # i64 (0/1)
    has_rwx_segment;   # i64 (0/1) — dangerous: read+write+execute
    is_static;         # i64 (0/1)
    executable_stack;  # i64 (0/1)
}

fn elf_security_new() {
    var s = alloc(32);
    store64(s, 0);
    store64(s + 8, 0);
    store64(s + 16, 1);  # assume static until we find PT_DYNAMIC
    store64(s + 24, 0);
    return s;
}

struct ElfInfo {
    class;         # i64 — ELF_CLASS_32 or ELF_CLASS_64
    endian;        # i64 — ELF_DATA_LSB or ELF_DATA_MSB
    os_abi;        # i64
    file_type;     # i64 — ET_EXEC, ET_DYN, etc.
    machine;       # i64
    entry_point;   # i64
    sections;      # Vec of ElfSection
    needed_libs;   # Vec of Str
    symbols;       # Vec of Str
    segments;      # Vec of ElfSegment
    interpreter;   # Str or 0
    security;      # ElfSecurity
}

fn elf_info_new() {
    var e = alloc(96);
    store64(e, 0);
    store64(e + 8, 0);
    store64(e + 16, 0);
    store64(e + 24, 0);
    store64(e + 32, 0);
    store64(e + 40, 0);
    store64(e + 48, vec_new());
    store64(e + 56, vec_new());
    store64(e + 64, vec_new());
    store64(e + 72, vec_new());
    store64(e + 80, 0);
    store64(e + 88, elf_security_new());
    return e;
}

# ================================================================
# ELF Parser — Machine name
# ================================================================

fn elf_machine_name(machine) {
    if (machine == ELF_EM_386)     { return str_from("i386"); }
    if (machine == ELF_EM_X86_64)  { return str_from("x86_64"); }
    if (machine == ELF_EM_ARM)     { return str_from("ARM"); }
    if (machine == ELF_EM_AARCH64) { return str_from("AArch64"); }
    if (machine == ELF_EM_RISCV)   { return str_from("RISC-V"); }
    return str_from("Unknown");
}

fn elf_type_name(t) {
    if (t == ELF_ET_REL)  { return str_from("Relocatable"); }
    if (t == ELF_ET_EXEC) { return str_from("Executable"); }
    if (t == ELF_ET_DYN)  { return str_from("Shared object"); }
    if (t == ELF_ET_CORE) { return str_from("Core dump"); }
    return str_from("Unknown");
}

# ================================================================
# ELF Parser — Program headers (segments)
# ================================================================

fn parse_program_headers(data, data_len, elf, ph_offset, ph_entry_size, ph_num) {
    var is64 = load64(elf) == ELF_CLASS_64;
    var le = load64(elf + 8) == ELF_DATA_LSB;

    for (var i = 0; i < ph_num; i = i + 1) {
        var off = ph_offset + i * ph_entry_size;
        if (off + ph_entry_size > data_len) { return 0; }

        var seg = elf_segment_new();
        store64(seg, elf_read_u32(data, off, le));

        if (is64) {
            store64(seg + 8, elf_read_u32(data, off + 4, le));
            store64(seg + 24, elf_read_u64(data, off + 8, le));
            store64(seg + 16, elf_read_u64(data, off + 16, le));
            store64(seg + 32, elf_read_u64(data, off + 32, le));
            store64(seg + 40, elf_read_u64(data, off + 40, le));
        } else {
            store64(seg + 24, elf_read_u32(data, off + 4, le));
            store64(seg + 16, elf_read_u32(data, off + 8, le));
            store64(seg + 32, elf_read_u32(data, off + 16, le));
            store64(seg + 40, elf_read_u32(data, off + 20, le));
            store64(seg + 8, elf_read_u32(data, off + 24, le));
        }

        vec_push(load64(elf + 72), seg);

        # Extract interpreter string from PT_INTERP segment
        if (load64(seg) == ELF_PT_INTERP) {
            if (load64(seg + 24) + load64(seg + 32) <= data_len) {
                if (load64(seg + 32) > 0) {
                    var interp_len = load64(seg + 32);
                    if (interp_len > 256) { interp_len = 256; }
                    store64(elf + 80, read_ascii(data, load64(seg + 24), interp_len));
                }
            }
        }

        # Security: detect GNU_RELRO
        if (load64(seg) == ELF_PT_GNU_RELRO) {
            store64(load64(elf + 88), 1);
        }

        # Security: detect executable stack
        if (load64(seg) == ELF_PT_GNU_STACK) {
            if (load64(seg + 8) & ELF_PF_X) {
                store64(load64(elf + 88) + 24, 1);
            }
        }

        # Security: detect PT_DYNAMIC => not static
        if (load64(seg) == ELF_PT_DYNAMIC) {
            store64(load64(elf + 88) + 16, 0);
        }

        # Security: detect RWX segments
        if (load64(seg) == ELF_PT_LOAD) {
            var rwx = ELF_PF_R | ELF_PF_W | ELF_PF_X;
            if ((load64(seg + 8) & rwx) == rwx) {
                store64(load64(elf + 88) + 8, 1);
            }
        }
    }
}

# ================================================================
# ELF Parser — Section headers
# ================================================================

fn parse_elf_sections(data, data_len, elf, sh_offset, sh_entry_size, sh_num, shstrndx) {
    var is64 = load64(elf) == ELF_CLASS_64;
    var le = load64(elf + 8) == ELF_DATA_LSB;

    # First, find the section header string table offset
    var shstrtab_offset = 0;
    if (shstrndx > 0) {
        if (shstrndx < sh_num) {
            var strtab_hdr = sh_offset + shstrndx * sh_entry_size;
            if (strtab_hdr + sh_entry_size <= data_len) {
                if (is64) {
                    shstrtab_offset = elf_read_u64(data, strtab_hdr + 24, le);
                } else {
                    shstrtab_offset = elf_read_u32(data, strtab_hdr + 16, le);
                }
            }
        }
    }

    var limit = sh_num;
    if (limit > ELF_MAX_SECTIONS) { limit = ELF_MAX_SECTIONS; }

    for (var i = 0; i < limit; i = i + 1) {
        var off = sh_offset + i * sh_entry_size;
        if (off + sh_entry_size > data_len) { return 0; }

        var sec = elf_section_new();
        var name_idx = elf_read_u32(data, off, le);
        store64(sec + 8, elf_read_u32(data, off + 4, le));

        if (is64) {
            store64(sec + 16, elf_read_u64(data, off + 8, le));
            store64(sec + 24, elf_read_u64(data, off + 16, le));
            store64(sec + 32, elf_read_u64(data, off + 24, le));
            store64(sec + 40, elf_read_u64(data, off + 32, le));
        } else {
            store64(sec + 16, elf_read_u32(data, off + 8, le));
            store64(sec + 24, elf_read_u32(data, off + 12, le));
            store64(sec + 32, elf_read_u32(data, off + 16, le));
            store64(sec + 40, elf_read_u32(data, off + 20, le));
        }

        # Resolve section name from string table
        if (shstrtab_offset > 0) {
            store64(sec, read_strtab_entry(data, data_len, shstrtab_offset, name_idx));
        }

        vec_push(load64(elf + 48), sec);
    }
}

# ================================================================
# ELF Parser — Dynamic section (DT_NEEDED libs)
# ================================================================

fn extract_needed_libs(data, data_len, elf) {
    var is64 = load64(elf) == ELF_CLASS_64;
    var le = load64(elf + 8) == ELF_DATA_LSB;

    # Find the .dynamic section (or PT_DYNAMIC segment)
    var dyn_offset = 0;
    var dyn_size = 0;

    # Try sections first
    var nsec = vec_len(load64(elf + 48));
    for (var i = 0; i < nsec; i = i + 1) {
        var sec = vec_get(load64(elf + 48), i);
        if (load64(sec + 8) == ELF_SHT_DYNAMIC) {
            dyn_offset = load64(sec + 32);
            dyn_size = load64(sec + 40);
            i = nsec;  # break
        }
    }

    # Fall back to segments if no .dynamic section
    if (dyn_offset == 0) {
        var nseg = vec_len(load64(elf + 72));
        for (var i = 0; i < nseg; i = i + 1) {
            var seg = vec_get(load64(elf + 72), i);
            if (load64(seg) == ELF_PT_DYNAMIC) {
                dyn_offset = load64(seg + 24);
                dyn_size = load64(seg + 32);
                i = nseg;  # break
            }
        }
    }

    if (dyn_offset == 0 || dyn_size == 0) { return 0; }

    # Find the dynamic string table (DT_STRTAB)
    var dynstr_offset = 0;
    var entry_size = 8;
    if (is64) { entry_size = 16; }

    # First pass: find DT_STRTAB
    var pos = dyn_offset;
    var end = dyn_offset + dyn_size;
    if (end > data_len) { end = data_len; }

    while (pos + entry_size <= end) {
        var tag = 0;
        var val = 0;
        if (is64) {
            tag = elf_read_u64(data, pos, le);
            val = elf_read_u64(data, pos + 8, le);
        } else {
            tag = elf_read_u32(data, pos, le);
            val = elf_read_u32(data, pos + 4, le);
        }
        if (tag == ELF_DT_NULL) { pos = end; }  # break
        else {
            if (tag == ELF_DT_STRTAB) {
                # val is a virtual address; try to find it in loaded sections
                # For files, try matching against section offsets
                var nsec2 = vec_len(load64(elf + 48));
                for (var i = 0; i < nsec2; i = i + 1) {
                    var sec = vec_get(load64(elf + 48), i);
                    if (load64(sec + 24) == val) {
                        dynstr_offset = load64(sec + 32);
                        i = nsec2;  # break
                    }
                }
                # If that failed, try segments for VA-to-offset mapping
                if (dynstr_offset == 0) {
                    var nseg2 = vec_len(load64(elf + 72));
                    for (var i = 0; i < nseg2; i = i + 1) {
                        var seg = vec_get(load64(elf + 72), i);
                        if (load64(seg) == ELF_PT_LOAD) {
                            if (val >= load64(seg + 16)) {
                                if (val < load64(seg + 16) + load64(seg + 32)) {
                                    dynstr_offset = load64(seg + 24) + (val - load64(seg + 16));
                                    i = nseg2;  # break
                                }
                            }
                        }
                    }
                }
                pos = end;  # break, we found strtab
            } else {
                pos = pos + entry_size;
            }
        }
    }

    if (dynstr_offset == 0) { return 0; }

    # Second pass: collect DT_NEEDED entries
    pos = dyn_offset;
    while (pos + entry_size <= end) {
        var tag = 0;
        var val = 0;
        if (is64) {
            tag = elf_read_u64(data, pos, le);
            val = elf_read_u64(data, pos + 8, le);
        } else {
            tag = elf_read_u32(data, pos, le);
            val = elf_read_u32(data, pos + 4, le);
        }
        if (tag == ELF_DT_NULL) { pos = end; }  # break
        else {
            if (tag == ELF_DT_NEEDED) {
                var lib_name = read_strtab_entry(data, data_len, dynstr_offset, val);
                vec_push(load64(elf + 56), lib_name);
            }
            pos = pos + entry_size;
        }
    }
}

# ================================================================
# ELF Parser — Symbol extraction
# ================================================================

fn extract_elf_symbols(data, data_len, elf) {
    var is64 = load64(elf) == ELF_CLASS_64;
    var le = load64(elf + 8) == ELF_DATA_LSB;

    # Find .dynsym and its linked string table
    var nsec = vec_len(load64(elf + 48));
    for (var i = 0; i < nsec; i = i + 1) {
        var sec = vec_get(load64(elf + 48), i);
        if (load64(sec + 8) == ELF_SHT_DYNSYM || load64(sec + 8) == ELF_SHT_SYMTAB) {
            # The linked string table index is stored in sh_link
            # We need to re-read sh_link from the raw section header
            # For simplicity, look for SHT_STRTAB sections
            var strtab_off = 0;
            for (var j = 0; j < nsec; j = j + 1) {
                var strsec = vec_get(load64(elf + 48), j);
                if (load64(strsec + 8) == ELF_SHT_STRTAB) {
                    if (j != 0) {  # Skip null section
                        # Use the first STRTAB that is not .shstrtab
                        if (str_eq(load64(strsec), str_from(".shstrtab")) == 0) {
                            strtab_off = load64(strsec + 32);
                            j = nsec;  # break
                        }
                    }
                }
            }
            if (strtab_off == 0) { return 0; }

            var entry_size = 16;  # ELF32 sym entry
            if (is64) { entry_size = 24; }  # ELF64 sym entry

            var num_syms = load64(sec + 40) / entry_size;
            if (num_syms > ELF_MAX_SYMBOLS) { num_syms = ELF_MAX_SYMBOLS; }

            var sym_off = load64(sec + 32);
            for (var k = 1; k < num_syms; k = k + 1) {  # skip index 0
                var soff = sym_off + k * entry_size;
                if (soff + entry_size > data_len) { k = num_syms; }  # break
                else {
                    var name_idx = elf_read_u32(data, soff, le);
                    if (name_idx > 0) {
                        var sym_name = read_strtab_entry(data, data_len, strtab_off, name_idx);
                        if (str_len(sym_name) > 0) {
                            vec_push(load64(elf + 64), sym_name);
                        }
                    }
                }
            }
            return 0;  # done after first symbol table
        }
    }
}

# ================================================================
# ELF Parser — Main parse function
# ================================================================

fn parse_elf(data, data_len) {
    # Validate minimum size and magic
    if (data_len < 52) { return 0; }  # Minimum ELF32 header
    if (load8(data) != ELF_MAGIC_0) { return 0; }
    if (load8(data + 1) != ELF_MAGIC_1) { return 0; }
    if (load8(data + 2) != ELF_MAGIC_2) { return 0; }
    if (load8(data + 3) != ELF_MAGIC_3) { return 0; }

    var elf = elf_info_new();

    # ELF identification
    store64(elf, load8(data + 4));
    store64(elf + 8, load8(data + 5));
    store64(elf + 16, load8(data + 7));

    var is64 = load64(elf) == ELF_CLASS_64;
    var le = load64(elf + 8) == ELF_DATA_LSB;

    if (is64) {
        if (data_len < 64) { return 0; }  # Minimum ELF64 header
    }

    # Header fields
    store64(elf + 24, elf_read_u16(data, 16, le));
    store64(elf + 32, elf_read_u16(data, 18, le));

    if (is64) {
        store64(elf + 40, elf_read_u64(data, 24, le));
        var ph_offset     = elf_read_u64(data, 32, le);
        var sh_offset     = elf_read_u64(data, 40, le);
        var ph_entry_size = elf_read_u16(data, 54, le);
        var ph_num        = elf_read_u16(data, 56, le);
        var sh_entry_size = elf_read_u16(data, 58, le);
        var sh_num        = elf_read_u16(data, 60, le);
        var shstrndx      = elf_read_u16(data, 62, le);

        # Parse program headers (segments)
        if (ph_offset > 0) {
            if (ph_num > 0) {
                parse_program_headers(data, data_len, elf, ph_offset, ph_entry_size, ph_num);
            }
        }

        # Parse section headers
        if (sh_offset > 0) {
            if (sh_num > 0) {
                parse_elf_sections(data, data_len, elf, sh_offset, sh_entry_size, sh_num, shstrndx);
            }
        }
    } else {
        store64(elf + 40, elf_read_u32(data, 24, le));
        var ph_offset     = elf_read_u32(data, 28, le);
        var sh_offset     = elf_read_u32(data, 32, le);
        var ph_entry_size = elf_read_u16(data, 42, le);
        var ph_num        = elf_read_u16(data, 44, le);
        var sh_entry_size = elf_read_u16(data, 46, le);
        var sh_num        = elf_read_u16(data, 48, le);
        var shstrndx      = elf_read_u16(data, 50, le);

        if (ph_offset > 0) {
            if (ph_num > 0) {
                parse_program_headers(data, data_len, elf, ph_offset, ph_entry_size, ph_num);
            }
        }

        if (sh_offset > 0) {
            if (sh_num > 0) {
                parse_elf_sections(data, data_len, elf, sh_offset, sh_entry_size, sh_num, shstrndx);
            }
        }
    }

    # Extract dynamic libraries and symbols
    extract_needed_libs(data, data_len, elf);
    extract_elf_symbols(data, data_len, elf);

    return elf;
}


# ================================================================
# ================================================================
# YARA Engine
# ================================================================
# ================================================================

# ================================================================
# YARA Engine — Constants
# ================================================================

# Pattern types
var YARA_PAT_LITERAL = 0;  # Literal byte sequence
var YARA_PAT_HEX     = 1;  # Hex byte string (e.g. { 4D 5A })
var YARA_PAT_REGEX   = 2;  # Simplified regex (literal search)
var YARA_PAT_STRING  = 3;  # ASCII string match

# Condition types
var YARA_COND_ALL        = 0;  # All patterns must match
var YARA_COND_ANY        = 1;  # Any pattern matches
var YARA_COND_AT_LEAST   = 2;  # At least N patterns match
var YARA_COND_EXPRESSION = 3;  # Complex boolean expression

# Expression node types (for condition tree)
var YARA_EXPR_AND       = 0;
var YARA_EXPR_OR        = 1;
var YARA_EXPR_NOT       = 2;
var YARA_EXPR_PAT_MATCH = 3;   # Pattern ID matched
var YARA_EXPR_PAT_AT    = 4;   # Pattern at specific offset
var YARA_EXPR_PAT_COUNT = 5;   # #pattern comparison
var YARA_EXPR_FILESIZE  = 6;   # filesize comparison
var YARA_EXPR_TRUE      = 7;
var YARA_EXPR_FALSE     = 8;
var YARA_EXPR_ALL_OF    = 9;   # all of them
var YARA_EXPR_ANY_OF    = 10;  # any of them
var YARA_EXPR_N_OF      = 11;  # N of them
var YARA_EXPR_PE_IS_DLL    = 12;  # pe.is_dll
var YARA_EXPR_PE_IS_64BIT  = 13;  # pe.is_64bit (pe.is_pe32 negated, pe.is_pe64)
var YARA_EXPR_PE_MACHINE   = 14;  # pe.machine == <value>
var YARA_EXPR_ELF_MACHINE  = 15;  # elf.machine == <value>
var YARA_EXPR_ELF_TYPE     = 16;  # elf.type == <value>

# Comparison operators
var YARA_CMP_LT = 0;
var YARA_CMP_LE = 1;
var YARA_CMP_GT = 2;
var YARA_CMP_GE = 3;
var YARA_CMP_EQ = 4;
var YARA_CMP_NE = 5;

# Match limits
var YARA_MAX_MATCH_OFFSETS = 4096;

# ================================================================
# YARA Engine — Hex string parsing
# ================================================================

# Parse a hex string like "4D5A90" into a byte buffer
# Returns: ptr to bytes, sets *out_len
fn parse_hex_pattern(hex_str, out_len_ptr) {
    var sdata = str_data(hex_str);
    var slen = str_len(hex_str);

    # First pass: count non-space hex chars
    var hex_chars = 0;
    for (var i = 0; i < slen; i = i + 1) {
        var ch = load8(sdata + i);
        if (ch != 32) {  # skip spaces
            if (ch != 123) {  # skip '{'
                if (ch != 125) {  # skip '}'
                    hex_chars = hex_chars + 1;
                }
            }
        }
    }

    if (hex_chars == 0 || (hex_chars & 1) != 0) {
        store64(out_len_ptr, 0);
        return 0;
    }

    var byte_count = hex_chars / 2;
    var buf = alloc(byte_count);
    var bi = 0;
    var hi_nibble = -1;

    for (var i = 0; i < slen; i = i + 1) {
        var ch = load8(sdata + i);
        if (ch != 32) {
            if (ch != 123) {
                if (ch != 125) {
                    var val = hex_digit_value(ch);
                    if (val < 0) {
                        # Wildcard '?' — treat as 0
                        if (ch == 63) { val = 0; }
                        else {
                            store64(out_len_ptr, 0);
                            return 0;
                        }
                    }
                    if (hi_nibble < 0) {
                        hi_nibble = val;
                    } else {
                        store8(buf + bi, (hi_nibble << 4) | val);
                        bi = bi + 1;
                        hi_nibble = -1;
                    }
                }
            }
        }
    }

    store64(out_len_ptr, byte_count);
    return buf;
}

# ================================================================
# YARA Engine — Pattern struct
# ================================================================

struct YaraPattern {
    id;         # Str — pattern identifier ($a, $b, etc.)
    pat_type;   # i64 — YARA_PAT_*
    data;       # ptr to byte pattern (for literal/hex)
    data_len;   # i64
    text;       # Str — original text (for string patterns)
    nocase;     # i64 (0/1) — case-insensitive
}

fn yara_pattern_new(id, pat_type) {
    var p = alloc(48);
    store64(p, id);
    store64(p + 8, pat_type);
    store64(p + 16, 0);
    store64(p + 24, 0);
    store64(p + 32, str_from(""));
    store64(p + 40, 0);
    return p;
}

# Create a pattern from a hex string like "4D 5A"
fn yara_pattern_from_hex(id, hex_str) {
    var p = yara_pattern_new(id, YARA_PAT_HEX);
    var len_ptr = alloc(8);
    var bytes = parse_hex_pattern(hex_str, len_ptr);
    store64(p + 16, bytes);
    store64(p + 24, load64(len_ptr));
    store64(p + 32, hex_str);
    return p;
}

# Create a pattern from an ASCII string
fn yara_pattern_from_string(id, text) {
    var p = yara_pattern_new(id, YARA_PAT_STRING);
    var sdata = str_data(text);
    var slen = str_len(text);
    var buf = alloc(slen);
    for (var i = 0; i < slen; i = i + 1) {
        store8(buf + i, load8(sdata + i));
    }
    store64(p + 16, buf);
    store64(p + 24, slen);
    store64(p + 32, text);
    return p;
}

# Create a pattern from raw bytes
fn yara_pattern_from_bytes(id, bytes, blen) {
    var p = yara_pattern_new(id, YARA_PAT_LITERAL);
    store64(p + 16, bytes);
    store64(p + 24, blen);
    return p;
}

# ================================================================
# YARA Engine — Pattern matching
# ================================================================

# Check if pattern matches anywhere in data
fn yara_pattern_matches(pat, data, data_len) {
    if (load64(pat + 16) == 0 || load64(pat + 24) == 0) { return 0; }
    if (load64(pat + 24) > data_len) { return 0; }

    if (load64(pat + 40)) {
        # Case-insensitive search
        var plen = load64(pat + 24);
        var limit = data_len - plen;
        for (var i = 0; i <= limit; i = i + 1) {
            var hit = 1;
            for (var j = 0; j < plen; j = j + 1) {
                var a = load8(data + i + j);
                var b = load8(load64(pat + 16) + j);
                # Lowercase both
                if (a >= 65) { if (a <= 90) { a = a + 32; } }
                if (b >= 65) { if (b <= 90) { b = b + 32; } }
                if (a != b) {
                    hit = 0;
                    j = plen;  # break
                }
            }
            if (hit) { return 1; }
        }
        return 0;
    }

    return memmem(data, data_len, load64(pat + 16), load64(pat + 24)) >= 0;
}

# Find all offsets where pattern matches, capped at YARA_MAX_MATCH_OFFSETS
# Returns a vec of i64 offsets
fn yara_pattern_find_offsets(pat, data, data_len) {
    var offsets = vec_new();
    if (load64(pat + 16) == 0 || load64(pat + 24) == 0) { return offsets; }
    if (load64(pat + 24) > data_len) { return offsets; }

    var plen = load64(pat + 24);
    var pos = 0;
    var count = 0;

    while (pos + plen <= data_len) {
        if (count >= YARA_MAX_MATCH_OFFSETS) { return offsets; }

        var found = -1;
        if (load64(pat + 40)) {
            # Case-insensitive scan from pos
            var limit = data_len - plen;
            for (var i = pos; i <= limit; i = i + 1) {
                var hit = 1;
                for (var j = 0; j < plen; j = j + 1) {
                    var a = load8(data + i + j);
                    var b = load8(load64(pat + 16) + j);
                    if (a >= 65) { if (a <= 90) { a = a + 32; } }
                    if (b >= 65) { if (b <= 90) { b = b + 32; } }
                    if (a != b) {
                        hit = 0;
                        j = plen;  # break
                    }
                }
                if (hit) {
                    found = i;
                    i = limit + 1;  # break
                }
            }
        } else {
            var result = memmem(data + pos, data_len - pos, load64(pat + 16), plen);
            if (result >= 0) {
                found = pos + result;
            }
        }

        if (found < 0) { return offsets; }
        vec_push(offsets, found);
        count = count + 1;
        pos = found + 1;
    }
    return offsets;
}

# ================================================================
# YARA Engine — Condition expression tree
# ================================================================

# ConditionExpr — a node in the expression tree
# We use a flat struct; the "left" and "right" fields are pointers
# to other ConditionExpr nodes (or 0 for leaf nodes).
struct ConditionExpr {
    node_type;  # i64 — YARA_EXPR_*
    left;       # ptr to ConditionExpr (or 0)
    right;      # ptr to ConditionExpr (or 0)
    pat_index;  # i64 — pattern index (for PAT_MATCH)
    cmp_op;     # i64 — YARA_CMP_* (for FILESIZE, PAT_COUNT)
    cmp_value;  # i64 — comparison value
    n_count;    # i64 — for N_OF
}

fn cond_expr_new(node_type) {
    var e = alloc(56);
    store64(e, node_type);
    store64(e + 8, 0);
    store64(e + 16, 0);
    store64(e + 24, 0);
    store64(e + 32, YARA_CMP_EQ);
    store64(e + 40, 0);
    store64(e + 48, 0);
    return e;
}

fn cond_expr_pat(pat_index) {
    var e = cond_expr_new(YARA_EXPR_PAT_MATCH);
    store64(e + 24, pat_index);
    return e;
}

fn cond_expr_and(left, right) {
    var e = cond_expr_new(YARA_EXPR_AND);
    store64(e + 8, left);
    store64(e + 16, right);
    return e;
}

fn cond_expr_or(left, right) {
    var e = cond_expr_new(YARA_EXPR_OR);
    store64(e + 8, left);
    store64(e + 16, right);
    return e;
}

fn cond_expr_not(child) {
    var e = cond_expr_new(YARA_EXPR_NOT);
    store64(e + 8, child);
    return e;
}

fn cond_expr_filesize(cmp_op, value) {
    var e = cond_expr_new(YARA_EXPR_FILESIZE);
    store64(e + 32, cmp_op);
    store64(e + 40, value);
    return e;
}

fn cond_expr_all_of() {
    return cond_expr_new(YARA_EXPR_ALL_OF);
}

fn cond_expr_any_of() {
    return cond_expr_new(YARA_EXPR_ANY_OF);
}

fn cond_expr_n_of(n) {
    var e = cond_expr_new(YARA_EXPR_N_OF);
    store64(e + 48, n);
    return e;
}

fn cond_expr_pe_is_dll() {
    return cond_expr_new(YARA_EXPR_PE_IS_DLL);
}

fn cond_expr_pe_is_64bit() {
    return cond_expr_new(YARA_EXPR_PE_IS_64BIT);
}

fn cond_expr_pe_machine(cmp_op, value) {
    var e = cond_expr_new(YARA_EXPR_PE_MACHINE);
    store64(e + 32, cmp_op);
    store64(e + 40, value);
    return e;
}

fn cond_expr_elf_machine(cmp_op, value) {
    var e = cond_expr_new(YARA_EXPR_ELF_MACHINE);
    store64(e + 32, cmp_op);
    store64(e + 40, value);
    return e;
}

fn cond_expr_elf_type(cmp_op, value) {
    var e = cond_expr_new(YARA_EXPR_ELF_TYPE);
    store64(e + 32, cmp_op);
    store64(e + 40, value);
    return e;
}

# ================================================================
# YARA Engine — Condition evaluation
# ================================================================

# match_info: vec of i64 (0/1) indicating which patterns matched
# data_len: file size for filesize comparisons
# pe_info: PeInfo ptr (or 0 if not a PE file)
# elf_info: ElfInfo ptr (or 0 if not an ELF file)
fn eval_condition(expr, match_info, data_len, pe_info, elf_info) {
    if (expr == 0) { return 0; }

    var t = load64(expr);

    if (t == YARA_EXPR_TRUE)  { return 1; }
    if (t == YARA_EXPR_FALSE) { return 0; }

    if (t == YARA_EXPR_PAT_MATCH) {
        var idx = load64(expr + 24);
        if (idx >= 0) {
            if (idx < vec_len(match_info)) {
                return vec_get(match_info, idx);
            }
        }
        return 0;
    }

    if (t == YARA_EXPR_AND) {
        if (eval_condition(load64(expr + 8), match_info, data_len, pe_info, elf_info) == 0) { return 0; }
        return eval_condition(load64(expr + 16), match_info, data_len, pe_info, elf_info);
    }

    if (t == YARA_EXPR_OR) {
        if (eval_condition(load64(expr + 8), match_info, data_len, pe_info, elf_info)) { return 1; }
        return eval_condition(load64(expr + 16), match_info, data_len, pe_info, elf_info);
    }

    if (t == YARA_EXPR_NOT) {
        if (eval_condition(load64(expr + 8), match_info, data_len, pe_info, elf_info) == 0) { return 1; }
        return 0;
    }

    if (t == YARA_EXPR_FILESIZE) {
        return cmp_eval(load64(expr + 32), data_len, load64(expr + 40));
    }

    if (t == YARA_EXPR_ALL_OF) {
        var n = vec_len(match_info);
        for (var i = 0; i < n; i = i + 1) {
            if (vec_get(match_info, i) == 0) { return 0; }
        }
        return 1;
    }

    if (t == YARA_EXPR_ANY_OF) {
        var n = vec_len(match_info);
        for (var i = 0; i < n; i = i + 1) {
            if (vec_get(match_info, i)) { return 1; }
        }
        return 0;
    }

    if (t == YARA_EXPR_N_OF) {
        var matched = 0;
        var n = vec_len(match_info);
        for (var i = 0; i < n; i = i + 1) {
            if (vec_get(match_info, i)) { matched = matched + 1; }
        }
        return matched >= load64(expr + 48);
    }

    if (t == YARA_EXPR_PAT_COUNT) {
        # Compare count of pattern matches
        var idx = load64(expr + 24);
        var count = 0;
        if (idx >= 0) {
            if (idx < vec_len(match_info)) {
                count = vec_get(match_info, idx);
            }
        }
        return cmp_eval(load64(expr + 32), count, load64(expr + 40));
    }

    # PE module conditions
    if (t == YARA_EXPR_PE_IS_DLL) {
        if (pe_info == 0) { return 0; }
        return load64(pe_info + 24);  # PeInfo.is_dll at offset +24
    }

    if (t == YARA_EXPR_PE_IS_64BIT) {
        if (pe_info == 0) { return 0; }
        return load64(pe_info + 32);  # PeInfo.is_64bit at offset +32
    }

    if (t == YARA_EXPR_PE_MACHINE) {
        if (pe_info == 0) { return 0; }
        return cmp_eval(load64(expr + 32), load64(pe_info), load64(expr + 40));  # PeInfo.machine at offset +0
    }

    # ELF module conditions
    if (t == YARA_EXPR_ELF_MACHINE) {
        if (elf_info == 0) { return 0; }
        return cmp_eval(load64(expr + 32), load64(elf_info + 32), load64(expr + 40));  # ElfInfo.machine at offset +32
    }

    if (t == YARA_EXPR_ELF_TYPE) {
        if (elf_info == 0) { return 0; }
        return cmp_eval(load64(expr + 32), load64(elf_info + 24), load64(expr + 40));  # ElfInfo.file_type at offset +24
    }

    return 0;
}

# Generic comparison evaluator
fn cmp_eval(op, lhs, rhs) {
    if (op == YARA_CMP_LT) { return lhs < rhs; }
    if (op == YARA_CMP_LE) { return lhs <= rhs; }
    if (op == YARA_CMP_GT) { return lhs > rhs; }
    if (op == YARA_CMP_GE) { return lhs >= rhs; }
    if (op == YARA_CMP_EQ) { return lhs == rhs; }
    if (op == YARA_CMP_NE) { return lhs != rhs; }
    return 0;
}

# ================================================================
# YARA Engine — Rule struct
# ================================================================

struct YaraConstraints {
    min_file_size; # i64 (0 = no constraint)
    max_file_size; # i64 (0 = no constraint)
    at_offset;     # i64 (-1 = no constraint)
}

fn yara_constraints_new() {
    var c = alloc(24);
    store64(c, 0);
    store64(c + 8, 0);
    store64(c + 16, -1);
    return c;
}

struct YaraRule {
    name;         # Str — rule name
    description;  # Str
    severity;     # i64 — SEVERITY_*
    tags;         # Vec of Str
    patterns;     # Vec of YaraPattern
    cond_type;    # i64 — YARA_COND_*
    cond_expr;    # ConditionExpr ptr (for EXPRESSION type)
    cond_count;   # i64 — for AT_LEAST
    constraints;  # YaraConstraints
}

fn yara_rule_new(name) {
    var r = alloc(72);
    store64(r, name);
    store64(r + 8, str_from(""));
    store64(r + 16, SEVERITY_MEDIUM);
    store64(r + 24, vec_new());
    store64(r + 32, vec_new());
    store64(r + 40, YARA_COND_ALL);
    store64(r + 48, 0);
    store64(r + 56, 0);
    store64(r + 64, yara_constraints_new());
    return r;
}

# ================================================================
# YARA Engine — Rule matching
# ================================================================

# Check if a single rule matches against data
# Returns: 1 if rule fires, 0 otherwise
# pe_info/elf_info: parsed module data (0 if not applicable)
fn yara_rule_matches(rule, data, data_len, pe_info, elf_info) {
    # Check constraints first
    var c = load64(rule + 64);
    if (load64(c) > 0) {
        if (data_len < load64(c)) { return 0; }
    }
    if (load64(c + 8) > 0) {
        if (data_len > load64(c + 8)) { return 0; }
    }

    var npats = vec_len(load64(rule + 32));
    if (npats == 0) {
        # No patterns — condition might be filesize-only or module-only
        if (load64(rule + 40) == YARA_COND_EXPRESSION) {
            if (load64(rule + 48) != 0) {
                var empty_info = vec_new();
                return eval_condition(load64(rule + 48), empty_info, data_len, pe_info, elf_info);
            }
        }
        return 0;
    }

    # Build match info — which patterns matched
    var match_info = vec_new();
    var total_matched = 0;
    for (var i = 0; i < npats; i = i + 1) {
        var pat = vec_get(load64(rule + 32), i);
        var matched = 0;

        if (load64(c + 16) >= 0) {
            # Pattern must match at specific offset
            if (load64(c + 16) + load64(pat + 24) <= data_len) {
                if (load64(pat + 16) != 0) {
                    var m = 1;
                    for (var j = 0; j < load64(pat + 24); j = j + 1) {
                        if (load8(data + load64(c + 16) + j) != load8(load64(pat + 16) + j)) {
                            m = 0;
                            j = load64(pat + 24);  # break
                        }
                    }
                    matched = m;
                }
            }
        } else {
            matched = yara_pattern_matches(pat, data, data_len);
        }

        vec_push(match_info, matched);
        if (matched) { total_matched = total_matched + 1; }
    }

    # Evaluate condition
    if (load64(rule + 40) == YARA_COND_ALL) {
        return total_matched == npats;
    }
    if (load64(rule + 40) == YARA_COND_ANY) {
        return total_matched > 0;
    }
    if (load64(rule + 40) == YARA_COND_AT_LEAST) {
        return total_matched >= load64(rule + 56);
    }
    if (load64(rule + 40) == YARA_COND_EXPRESSION) {
        if (load64(rule + 48) != 0) {
            return eval_condition(load64(rule + 48), match_info, data_len, pe_info, elf_info);
        }
    }

    return 0;
}

# ================================================================
# YARA Engine — Finding from rule match
# ================================================================

struct YaraFinding {
    rule_name;   # Str
    description; # Str
    severity;    # i64
    tags;        # Vec of Str
    offsets;     # Vec of i64 — where patterns matched
}

fn yara_finding_new(rule) {
    var f = alloc(40);
    store64(f, load64(rule));
    store64(f + 8, load64(rule + 8));
    store64(f + 16, load64(rule + 16));
    store64(f + 24, load64(rule + 24));
    store64(f + 32, vec_new());
    return f;
}

# ================================================================
# YARA Engine — Engine struct
# ================================================================

struct YaraEngine {
    rules;  # Vec of YaraRule
}

fn yara_engine_new() {
    var e = alloc(8);
    store64(e, vec_new());
    return e;
}

fn yara_engine_add_rule(engine, rule) {
    vec_push(load64(engine), rule);
}

fn yara_engine_rule_count(engine) {
    return vec_len(load64(engine));
}

# Scan data against all loaded rules
# Returns a vec of YaraFinding
fn yara_engine_scan(engine, data, data_len) {
    var findings = vec_new();
    var nrules = vec_len(load64(engine));

    # Parse PE/ELF module data for condition evaluation
    var pe_info = 0;
    var elf_info = 0;
    var ft = detect_file_type(data, data_len);
    if (ft == FILETYPE_PE) {
        pe_info = parse_pe(data, data_len);
    }
    if (ft == FILETYPE_ELF) {
        elf_info = parse_elf(data, data_len);
    }

    for (var i = 0; i < nrules; i = i + 1) {
        var rule = vec_get(load64(engine), i);
        if (yara_rule_matches(rule, data, data_len, pe_info, elf_info)) {
            var finding = yara_finding_new(rule);

            # Collect match offsets for the first matching pattern
            var npats = vec_len(load64(rule + 32));
            for (var j = 0; j < npats; j = j + 1) {
                var pat = vec_get(load64(rule + 32), j);
                if (yara_pattern_matches(pat, data, data_len)) {
                    var offsets = yara_pattern_find_offsets(pat, data, data_len);
                    store64(finding + 32, offsets);
                    j = npats;  # break — use first matching pattern's offsets
                }
            }

            vec_push(findings, finding);
        }
    }
    return findings;
}

# ================================================================
# YARA Engine — TOML rule loading
# ================================================================

# Load rules from a TOML string
# Expected format:
#   [[rules]]
#   name = "SuspiciousMZ"
#   description = "Detects MZ header"
#   severity = "high"
#   tags = ["pe", "executable"]
#   condition = "all"
#
#   [[rules.patterns]]
#   id = "$mz"
#   type = "hex"
#   value = "4D 5A"
fn yara_engine_load_rules_toml(engine, toml_str) {
    var sections = toml_parse(toml_str);
    if (sections == 0) { return Err(ERR_RULE_PARSE); }

    # Walk all sections in order. [[rule]] starts a new rule,
    # [[rule.patterns]] adds a pattern to the current rule.
    var nsections = vec_len(sections);
    var current_rule = 0;
    var nrules = 0;
    var pat_idx = 0;

    for (var i = 0; i < nsections; i = i + 1) {
        var sec = vec_get(sections, i);
        var sec_name = toml_section_name(sec);
        var pairs = toml_section_pairs(sec);

        if (str_eq(sec_name, str_from("rule"))) {
            # Commit previous rule if any
            if (current_rule != 0) {
                yara_engine_add_rule(engine, current_rule);
                nrules = nrules + 1;
            }

            var name = toml_get(pairs, str_from("name"));
            if (name == 0) { name = str_from("unnamed"); }

            current_rule = yara_rule_new(name);
            pat_idx = 0;

            var desc = toml_get(pairs, str_from("description"));
            if (desc != 0) { store64(current_rule + 8, desc); }

            # Parse severity
            var sev_str = toml_get(pairs, str_from("severity"));
            if (sev_str != 0) {
                store64(current_rule + 16, parse_severity_str(sev_str));
            }

            # Parse tags — comma-separated in the flat TOML value
            var tags_str = toml_get(pairs, str_from("tags"));
            if (tags_str != 0) {
                var tag_parts = str_split(tags_str, str_from(","));
                var ntags = vec_len(tag_parts);
                for (var t = 0; t < ntags; t = t + 1) {
                    var tag = str_trim(vec_get(tag_parts, t));
                    if (str_len(tag) > 0) {
                        vec_push(load64(current_rule + 24), tag);
                    }
                }
            }

            # Parse condition
            var cond_str = toml_get(pairs, str_from("condition"));
            if (cond_str != 0) {
                if (str_eq(cond_str, str_from("all"))) {
                    store64(current_rule + 40, YARA_COND_ALL);
                } else {
                    if (str_eq(cond_str, str_from("any"))) {
                        store64(current_rule + 40, YARA_COND_ANY);
                    }
                }
            }

            var cond_count_str = toml_get(pairs, str_from("condition_count"));
            if (cond_count_str != 0) {
                var cond_count = str_to_int(cond_count_str);
                if (cond_count > 0) {
                    store64(current_rule + 40, YARA_COND_AT_LEAST);
                    store64(current_rule + 56, cond_count);
                }
            }

            # Parse constraints
            var min_size_str = toml_get(pairs, str_from("min_file_size"));
            if (min_size_str != 0) {
                var min_size = str_to_int(min_size_str);
                if (min_size > 0) { store64(load64(current_rule + 64), min_size); }
            }
            var max_size_str = toml_get(pairs, str_from("max_file_size"));
            if (max_size_str != 0) {
                var max_size = str_to_int(max_size_str);
                if (max_size > 0) { store64(load64(current_rule + 64) + 8, max_size); }
            }
            var at_off_str = toml_get(pairs, str_from("at_offset"));
            if (at_off_str != 0) {
                var at_off = str_to_int(at_off_str);
                if (at_off >= 0) { store64(load64(current_rule + 64) + 16, at_off); }
            }
        } else {
            if (str_eq(sec_name, str_from("rule.patterns"))) {
                # Pattern subsection — attach to current rule
                if (current_rule == 0) {
                    sakshi_warn("rule.patterns section without preceding rule", 48);
                } else {
                    var pid = toml_get(pairs, str_from("id"));
                    if (pid == 0) { pid = str_cat(str_from("$p"), str_from_int(pat_idx)); }
                    pat_idx = pat_idx + 1;
                    var ptype = toml_get(pairs, str_from("type"));
                    var pval = toml_get(pairs, str_from("value"));
                    if (pval != 0) {
                        var pat = 0;
                        if (ptype != 0) {
                            if (str_eq(ptype, str_from("hex"))) {
                                pat = yara_pattern_from_hex(pid, pval);
                            } else {
                                if (str_eq(ptype, str_from("string"))) {
                                    pat = yara_pattern_from_string(pid, pval);
                                } else {
                                    pat = yara_pattern_from_string(pid, pval);
                                }
                            }
                        } else {
                            pat = yara_pattern_from_string(pid, pval);
                        }

                        # Check nocase flag
                        var nocase_str = toml_get(pairs, str_from("nocase"));
                        if (nocase_str != 0) {
                            var nocase = str_to_int(nocase_str);
                            if (nocase) { store64(pat + 40, 1); }
                        }

                        vec_push(load64(current_rule + 32), pat);
                    }
                }
            }
        }
    }

    # Commit the last rule
    if (current_rule != 0) {
        yara_engine_add_rule(engine, current_rule);
        nrules = nrules + 1;
    }

    if (nrules == 0) { return Err(ERR_RULE_PARSE); }
    return Ok(nrules);
}

# Helper: parse severity string to constant
fn parse_severity_str(s) {
    if (str_eq(s, str_from("critical"))) { return SEVERITY_CRITICAL; }
    if (str_eq(s, str_from("CRITICAL"))) { return SEVERITY_CRITICAL; }
    if (str_eq(s, str_from("high")))     { return SEVERITY_HIGH; }
    if (str_eq(s, str_from("HIGH")))     { return SEVERITY_HIGH; }
    if (str_eq(s, str_from("medium")))   { return SEVERITY_MEDIUM; }
    if (str_eq(s, str_from("MEDIUM")))   { return SEVERITY_MEDIUM; }
    if (str_eq(s, str_from("low")))      { return SEVERITY_LOW; }
    if (str_eq(s, str_from("LOW")))      { return SEVERITY_LOW; }
    if (str_eq(s, str_from("info")))     { return SEVERITY_INFO; }
    if (str_eq(s, str_from("INFO")))     { return SEVERITY_INFO; }
    return SEVERITY_MEDIUM;
}

# Parse severity from cstr (CLI argument). Case-insensitive via str_lower.
# Returns SEVERITY_INFO as default if null or unrecognized.
fn parse_severity(s) {
    if (s == 0) { return SEVERITY_INFO; }
    var low = str_lower(str_from(s));
    if (str_eq(low, str_from("critical"))) { return SEVERITY_CRITICAL; }
    if (str_eq(low, str_from("high")))     { return SEVERITY_HIGH; }
    if (str_eq(low, str_from("medium")))   { return SEVERITY_MEDIUM; }
    if (str_eq(low, str_from("low")))      { return SEVERITY_LOW; }
    return SEVERITY_INFO;
}

# ================================================================
# YARA Parser — .yar syntax lexer
# ================================================================

# Token types
var YAR_TOK_EOF        = 0;
var YAR_TOK_RULE       = 1;   # "rule" keyword
var YAR_TOK_STRINGS    = 2;   # "strings:" keyword
var YAR_TOK_CONDITION  = 3;   # "condition:" keyword
var YAR_TOK_IMPORT     = 4;   # "import" keyword
var YAR_TOK_LBRACE     = 5;   # {
var YAR_TOK_RBRACE     = 6;   # }
var YAR_TOK_LPAREN     = 7;   # (
var YAR_TOK_RPAREN     = 8;   # )
var YAR_TOK_EQ         = 9;   # =
var YAR_TOK_COLON      = 10;  # :
var YAR_TOK_DOLLAR     = 11;  # $identifier
var YAR_TOK_STRING_LIT = 12;  # "..."
var YAR_TOK_HEX_BLOCK  = 13;  # { 4D 5A ... }
var YAR_TOK_IDENT      = 14;  # identifier
var YAR_TOK_NUMBER     = 15;  # integer literal
var YAR_TOK_AND        = 16;  # "and"
var YAR_TOK_OR         = 17;  # "or"
var YAR_TOK_NOT        = 18;  # "not"
var YAR_TOK_ALL        = 19;  # "all"
var YAR_TOK_ANY        = 20;  # "any"
var YAR_TOK_OF         = 21;  # "of"
var YAR_TOK_THEM       = 22;  # "them"
var YAR_TOK_FILESIZE   = 23;  # "filesize"
var YAR_TOK_LT         = 24;  # <
var YAR_TOK_GT         = 25;  # >
var YAR_TOK_LE         = 26;  # <=
var YAR_TOK_GE         = 27;  # >=
var YAR_TOK_EQEQ       = 28;  # ==
var YAR_TOK_NE         = 29;  # !=
var YAR_TOK_META       = 30;  # "meta:" keyword
var YAR_TOK_TRUE       = 31;  # "true"
var YAR_TOK_FALSE      = 32;  # "false"
var YAR_TOK_AT         = 33;  # "at"
var YAR_TOK_DOT        = 34;  # "."

# Lexer state
struct YarLexer {
    src;    # Str — source text
    pos;    # i64 — current position
    len;    # i64 — source length
    sdata;  # ptr — raw source bytes
}

fn yar_lexer_new(src) {
    var l = alloc(32);
    store64(l, src);
    store64(l + 8, 0);
    store64(l + 16, str_len(src));
    store64(l + 24, str_data(src));
    return l;
}

# Skip whitespace and comments
fn yar_skip_ws(lex) {
    while (load64(lex + 8) < load64(lex + 16)) {
        var ch = load8(load64(lex + 24) + load64(lex + 8));
        if (ch == 32 || ch == 9 || ch == 10 || ch == 13) {
            store64(lex + 8, load64(lex + 8) + 1);
        } else {
            if (ch == 47) {  # '/'
                if (load64(lex + 8) + 1 < load64(lex + 16)) {
                    var next = load8(load64(lex + 24) + load64(lex + 8) + 1);
                    if (next == 47) {
                        # // line comment
                        store64(lex + 8, load64(lex + 8) + 2);
                        while (load64(lex + 8) < load64(lex + 16)) {
                            if (load8(load64(lex + 24) + load64(lex + 8)) == 10) {
                                store64(lex + 8, load64(lex + 8) + 1);
                                store64(lex + 8, load64(lex + 8));  # continue outer
                                return yar_skip_ws(lex);  # restart
                            }
                            store64(lex + 8, load64(lex + 8) + 1);
                        }
                    } else {
                        if (next == 42) {
                            # /* block comment */
                            store64(lex + 8, load64(lex + 8) + 2);
                            while (load64(lex + 8) + 1 < load64(lex + 16)) {
                                if (load8(load64(lex + 24) + load64(lex + 8)) == 42) {
                                    if (load8(load64(lex + 24) + load64(lex + 8) + 1) == 47) {
                                        store64(lex + 8, load64(lex + 8) + 2);
                                        return yar_skip_ws(lex);  # restart
                                    }
                                }
                                store64(lex + 8, load64(lex + 8) + 1);
                            }
                        } else {
                            return 0;  # not a comment
                        }
                    }
                } else {
                    return 0;
                }
            } else {
                return 0;
            }
        }
    }
}

# Token struct
struct YarToken {
    tok_type;  # i64 — YAR_TOK_*
    value;     # Str — text value
    num_val;   # i64 — numeric value (for NUMBER)
}

fn yar_token_new(tok_type, value) {
    var t = alloc(24);
    store64(t, tok_type);
    store64(t + 8, value);
    store64(t + 16, 0);
    return t;
}

fn yar_is_alpha(ch) {
    if (ch >= 65) { if (ch <= 90)  { return 1; } }
    if (ch >= 97) { if (ch <= 122) { return 1; } }
    if (ch == 95) { return 1; }  # '_'
    return 0;
}

fn yar_is_alnum(ch) {
    if (yar_is_alpha(ch)) { return 1; }
    if (ch >= 48) { if (ch <= 57) { return 1; } }
    return 0;
}

fn yar_is_digit(ch) {
    if (ch >= 48) { if (ch <= 57) { return 1; } }
    return 0;
}

# Read next token
fn yar_next_token(lex) {
    yar_skip_ws(lex);
    if (load64(lex + 8) >= load64(lex + 16)) {
        return yar_token_new(YAR_TOK_EOF, str_from(""));
    }

    var ch = load8(load64(lex + 24) + load64(lex + 8));

    # Single-character tokens
    if (ch == 123) { store64(lex + 8, load64(lex + 8) + 1); return yar_token_new(YAR_TOK_LBRACE, str_from("{")); }
    if (ch == 125) { store64(lex + 8, load64(lex + 8) + 1); return yar_token_new(YAR_TOK_RBRACE, str_from("}")); }
    if (ch == 40)  { store64(lex + 8, load64(lex + 8) + 1); return yar_token_new(YAR_TOK_LPAREN, str_from("(")); }
    if (ch == 41)  { store64(lex + 8, load64(lex + 8) + 1); return yar_token_new(YAR_TOK_RPAREN, str_from(")")); }
    if (ch == 58)  { store64(lex + 8, load64(lex + 8) + 1); return yar_token_new(YAR_TOK_COLON, str_from(":")); }
    if (ch == 46)  { store64(lex + 8, load64(lex + 8) + 1); return yar_token_new(YAR_TOK_DOT, str_from(".")); }

    # Two-char operators
    if (ch == 60) {  # '<'
        if (load64(lex + 8) + 1 < load64(lex + 16)) {
            if (load8(load64(lex + 24) + load64(lex + 8) + 1) == 61) {
                store64(lex + 8, load64(lex + 8) + 2);
                return yar_token_new(YAR_TOK_LE, str_from("<="));
            }
        }
        store64(lex + 8, load64(lex + 8) + 1);
        return yar_token_new(YAR_TOK_LT, str_from("<"));
    }
    if (ch == 62) {  # '>'
        if (load64(lex + 8) + 1 < load64(lex + 16)) {
            if (load8(load64(lex + 24) + load64(lex + 8) + 1) == 61) {
                store64(lex + 8, load64(lex + 8) + 2);
                return yar_token_new(YAR_TOK_GE, str_from(">="));
            }
        }
        store64(lex + 8, load64(lex + 8) + 1);
        return yar_token_new(YAR_TOK_GT, str_from(">"));
    }
    if (ch == 61) {  # '='
        if (load64(lex + 8) + 1 < load64(lex + 16)) {
            if (load8(load64(lex + 24) + load64(lex + 8) + 1) == 61) {
                store64(lex + 8, load64(lex + 8) + 2);
                return yar_token_new(YAR_TOK_EQEQ, str_from("=="));
            }
        }
        store64(lex + 8, load64(lex + 8) + 1);
        return yar_token_new(YAR_TOK_EQ, str_from("="));
    }
    if (ch == 33) {  # '!'
        if (load64(lex + 8) + 1 < load64(lex + 16)) {
            if (load8(load64(lex + 24) + load64(lex + 8) + 1) == 61) {
                store64(lex + 8, load64(lex + 8) + 2);
                return yar_token_new(YAR_TOK_NE, str_from("!="));
            }
        }
        # standalone '!' is handled as NOT in parsing
        store64(lex + 8, load64(lex + 8) + 1);
        return yar_token_new(YAR_TOK_NOT, str_from("!"));
    }

    # $ pattern identifier
    if (ch == 36) {  # '$'
        store64(lex + 8, load64(lex + 8) + 1);
        var start = load64(lex + 8);
        while (load64(lex + 8) < load64(lex + 16)) {
            if (yar_is_alnum(load8(load64(lex + 24) + load64(lex + 8)))) {
                store64(lex + 8, load64(lex + 8) + 1);
            } else {
                store64(lex + 8, load64(lex + 8));  # stop
                var id_len = load64(lex + 8) - start;
                var id = str_from("$");
                if (id_len > 0) {
                    id = str_cat(str_from("$"), str_substr(load64(lex), start, id_len));
                }
                return yar_token_new(YAR_TOK_DOLLAR, id);
            }
        }
        var id_len = load64(lex + 8) - start;
        var id = str_cat(str_from("$"), str_substr(load64(lex), start, id_len));
        return yar_token_new(YAR_TOK_DOLLAR, id);
    }

    # String literal "..."
    if (ch == 34) {  # '"'
        store64(lex + 8, load64(lex + 8) + 1);
        var start = load64(lex + 8);
        while (load64(lex + 8) < load64(lex + 16)) {
            var c = load8(load64(lex + 24) + load64(lex + 8));
            if (c == 34) {
                var sval = str_substr(load64(lex), start, load64(lex + 8) - start);
                store64(lex + 8, load64(lex + 8) + 1);  # skip closing quote
                return yar_token_new(YAR_TOK_STRING_LIT, sval);
            }
            if (c == 92) {  # backslash escape
                store64(lex + 8, load64(lex + 8) + 2);
            } else {
                store64(lex + 8, load64(lex + 8) + 1);
            }
        }
        # Unterminated string
        var sval = str_substr(load64(lex), start, load64(lex + 8) - start);
        return yar_token_new(YAR_TOK_STRING_LIT, sval);
    }

    # Number literal
    if (yar_is_digit(ch)) {
        var start = load64(lex + 8);
        var val = 0;
        # Check for hex prefix 0x
        if (ch == 48) {
            if (load64(lex + 8) + 1 < load64(lex + 16)) {
                var nx = load8(load64(lex + 24) + load64(lex + 8) + 1);
                if (nx == 120 || nx == 88) {  # 'x' or 'X'
                    store64(lex + 8, load64(lex + 8) + 2);
                    while (load64(lex + 8) < load64(lex + 16)) {
                        var d = hex_digit_value(load8(load64(lex + 24) + load64(lex + 8)));
                        if (d < 0) {
                            var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(load64(lex), start, load64(lex + 8) - start));
                            store64(tok + 16, val);
                            return tok;
                        }
                        val = (val << 4) | d;
                        store64(lex + 8, load64(lex + 8) + 1);
                    }
                    var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(load64(lex), start, load64(lex + 8) - start));
                    store64(tok + 16, val);
                    return tok;
                }
            }
        }
        while (load64(lex + 8) < load64(lex + 16)) {
            var d = load8(load64(lex + 24) + load64(lex + 8));
            if (d >= 48) {
                if (d <= 57) {
                    val = val * 10 + (d - 48);
                    store64(lex + 8, load64(lex + 8) + 1);
                } else {
                    var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(load64(lex), start, load64(lex + 8) - start));
                    store64(tok + 16, val);
                    return tok;
                }
            } else {
                var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(load64(lex), start, load64(lex + 8) - start));
                store64(tok + 16, val);
                return tok;
            }
        }
        # Handle suffix multipliers (KB, MB)
        var tok = yar_token_new(YAR_TOK_NUMBER, str_substr(load64(lex), start, load64(lex + 8) - start));
        store64(tok + 16, val);
        return tok;
    }

    # Identifier or keyword
    if (yar_is_alpha(ch)) {
        var start = load64(lex + 8);
        while (load64(lex + 8) < load64(lex + 16)) {
            if (yar_is_alnum(load8(load64(lex + 24) + load64(lex + 8)))) {
                store64(lex + 8, load64(lex + 8) + 1);
            } else {
                store64(lex + 8, load64(lex + 8));
                var word = str_substr(load64(lex), start, load64(lex + 8) - start);
                return yar_classify_keyword(word);
            }
        }
        var word = str_substr(load64(lex), start, load64(lex + 8) - start);
        return yar_classify_keyword(word);
    }

    # Unknown character — skip
    store64(lex + 8, load64(lex + 8) + 1);
    return yar_token_new(YAR_TOK_IDENT, str_from("?"));
}

# Classify an identifier as a keyword or plain identifier
fn yar_classify_keyword(word) {
    if (str_eq(word, str_from("rule")))      { return yar_token_new(YAR_TOK_RULE, word); }
    if (str_eq(word, str_from("strings")))   { return yar_token_new(YAR_TOK_STRINGS, word); }
    if (str_eq(word, str_from("condition"))) { return yar_token_new(YAR_TOK_CONDITION, word); }
    if (str_eq(word, str_from("import")))    { return yar_token_new(YAR_TOK_IMPORT, word); }
    if (str_eq(word, str_from("meta")))      { return yar_token_new(YAR_TOK_META, word); }
    if (str_eq(word, str_from("and")))       { return yar_token_new(YAR_TOK_AND, word); }
    if (str_eq(word, str_from("or")))        { return yar_token_new(YAR_TOK_OR, word); }
    if (str_eq(word, str_from("not")))       { return yar_token_new(YAR_TOK_NOT, word); }
    if (str_eq(word, str_from("all")))       { return yar_token_new(YAR_TOK_ALL, word); }
    if (str_eq(word, str_from("any")))       { return yar_token_new(YAR_TOK_ANY, word); }
    if (str_eq(word, str_from("of")))        { return yar_token_new(YAR_TOK_OF, word); }
    if (str_eq(word, str_from("them")))      { return yar_token_new(YAR_TOK_THEM, word); }
    if (str_eq(word, str_from("filesize")))  { return yar_token_new(YAR_TOK_FILESIZE, word); }
    if (str_eq(word, str_from("true")))      { return yar_token_new(YAR_TOK_TRUE, word); }
    if (str_eq(word, str_from("false")))     { return yar_token_new(YAR_TOK_FALSE, word); }
    if (str_eq(word, str_from("at")))        { return yar_token_new(YAR_TOK_AT, word); }
    # Size suffixes
    if (str_eq(word, str_from("KB")))        { return yar_token_new(YAR_TOK_IDENT, word); }
    if (str_eq(word, str_from("MB")))        { return yar_token_new(YAR_TOK_IDENT, word); }
    return yar_token_new(YAR_TOK_IDENT, word);
}

# ================================================================
# YARA Parser — .yar syntax parser
# ================================================================

struct YarParser {
    lex;          # YarLexer
    current;      # YarToken — current lookahead token
    patterns;     # Vec of YaraPattern (current rule)
    pattern_map;  # map from pattern id str -> index
}

fn yar_parser_new(src) {
    var p = alloc(32);
    store64(p, yar_lexer_new(src));
    store64(p + 8, yar_next_token(load64(p)));
    store64(p + 16, vec_new());
    store64(p + 24, map_new());
    return p;
}

fn yar_advance(parser) {
    store64(parser + 8, yar_next_token(load64(parser)));
    return load64(parser + 8);
}

fn yar_expect(parser, tok_type) {
    if (load64(load64(parser + 8)) == tok_type) {
        var tok = load64(parser + 8);
        yar_advance(parser);
        return tok;
    }
    return 0;  # unexpected token
}

# Parse a size value with optional KB/MB suffix
fn yar_parse_size(parser) {
    var tok = load64(parser + 8);
    if (load64(tok) != YAR_TOK_NUMBER) { return 0; }
    var val = load64(tok + 16);
    yar_advance(parser);
    # Check for KB/MB suffix
    if (load64(load64(parser + 8)) == YAR_TOK_IDENT) {
        if (str_eq(load64(load64(parser + 8) + 8), str_from("KB"))) {
            val = val * 1024;
            yar_advance(parser);
        } else {
            if (str_eq(load64(load64(parser + 8) + 8), str_from("MB"))) {
                val = val * 1024 * 1024;
                yar_advance(parser);
            }
        }
    }
    return val;
}

# Parse the strings section
fn yar_parse_strings(parser) {
    store64(parser + 16, vec_new());
    store64(parser + 24, map_new());

    # Expect "strings" ":"
    # "strings" was already consumed; expect ":"
    yar_expect(parser, YAR_TOK_COLON);

    var idx = 0;
    while (load64(load64(parser + 8)) == YAR_TOK_DOLLAR) {
        var pat_id = load64(load64(parser + 8) + 8);
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_EQ);

        var pat = 0;
        if (load64(load64(parser + 8)) == YAR_TOK_STRING_LIT) {
            pat = yara_pattern_from_string(pat_id, load64(load64(parser + 8) + 8));
            yar_advance(parser);
        } else {
            if (load64(load64(parser + 8)) == YAR_TOK_LBRACE) {
                # Hex block: { XX XX XX }
                yar_advance(parser);  # skip '{'
                var hex_str = str_from("");
                while (load64(load64(parser + 8)) != YAR_TOK_RBRACE) {
                    if (load64(load64(parser + 8)) == YAR_TOK_EOF) {
                        return 0;  # error
                    }
                    hex_str = str_cat(hex_str, load64(load64(parser + 8) + 8));
                    if (load64(load64(parser + 8)) == YAR_TOK_NUMBER |
                        load64(load64(parser + 8)) == YAR_TOK_IDENT) {
                        hex_str = str_cat(hex_str, str_from(" "));
                    }
                    yar_advance(parser);
                }
                yar_advance(parser);  # skip '}'
                pat = yara_pattern_from_hex(pat_id, hex_str);
            } else {
                # Unknown pattern type — skip
                yar_advance(parser);
            }
        }

        if (pat != 0) {
            # Check for modifiers: nocase, ascii, wide
            while (load64(load64(parser + 8)) == YAR_TOK_IDENT) {
                if (str_eq(load64(load64(parser + 8) + 8), str_from("nocase"))) {
                    store64(pat + 40, 1);
                    yar_advance(parser);
                } else {
                    if (str_eq(load64(load64(parser + 8) + 8), str_from("ascii"))) {
                        yar_advance(parser);  # skip, default is ascii
                    } else {
                        if (str_eq(load64(load64(parser + 8) + 8), str_from("wide"))) {
                            yar_advance(parser);  # acknowledged but not fully supported
                        } else {
                            store64(parser + 8, load64(parser + 8));  # stop modifier parsing
                            var dummy = 0;
                            dummy = 1;  # force break from while
                            return 0;
                        }
                    }
                }
            }

            vec_push(load64(parser + 16), pat);
            map_set(load64(parser + 24), pat_id, idx);
            idx = idx + 1;
        }
    }
}

# Parse condition expression (recursive descent)
fn yar_parse_condition(parser) {
    # Expect "condition" ":"
    yar_expect(parser, YAR_TOK_COLON);
    return yar_parse_or_expr(parser);
}

fn yar_parse_or_expr(parser) {
    var left = yar_parse_and_expr(parser);
    while (load64(load64(parser + 8)) == YAR_TOK_OR) {
        yar_advance(parser);
        var right = yar_parse_and_expr(parser);
        left = cond_expr_or(left, right);
    }
    return left;
}

fn yar_parse_and_expr(parser) {
    var left = yar_parse_not_expr(parser);
    while (load64(load64(parser + 8)) == YAR_TOK_AND) {
        yar_advance(parser);
        var right = yar_parse_not_expr(parser);
        left = cond_expr_and(left, right);
    }
    return left;
}

fn yar_parse_not_expr(parser) {
    if (load64(load64(parser + 8)) == YAR_TOK_NOT) {
        yar_advance(parser);
        var child = yar_parse_primary_expr(parser);
        return cond_expr_not(child);
    }
    return yar_parse_primary_expr(parser);
}

fn yar_parse_primary_expr(parser) {
    var tok = load64(parser + 8);

    # Pattern reference: $a
    if (load64(tok) == YAR_TOK_DOLLAR) {
        var pat_id = load64(tok + 8);
        yar_advance(parser);
        var idx = map_get(load64(parser + 24), pat_id);
        if (idx != 0) {
            return cond_expr_pat(idx);
        }
        # Try index 0 explicitly (map_get returns 0 for both missing and index 0)
        var npats = vec_len(load64(parser + 16));
        if (npats > 0) {
            var first_pat = vec_get(load64(parser + 16), 0);
            if (str_eq(load64(first_pat), pat_id)) {
                return cond_expr_pat(0);
            }
        }
        return cond_expr_new(YARA_EXPR_FALSE);
    }

    # "all of them"
    if (load64(tok) == YAR_TOK_ALL) {
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_OF);
        yar_expect(parser, YAR_TOK_THEM);
        return cond_expr_all_of();
    }

    # "any of them"
    if (load64(tok) == YAR_TOK_ANY) {
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_OF);
        yar_expect(parser, YAR_TOK_THEM);
        return cond_expr_any_of();
    }

    # N "of them"
    if (load64(tok) == YAR_TOK_NUMBER) {
        var n = load64(tok + 16);
        yar_advance(parser);
        if (load64(load64(parser + 8)) == YAR_TOK_OF) {
            yar_advance(parser);
            yar_expect(parser, YAR_TOK_THEM);
            return cond_expr_n_of(n);
        }
        # Standalone number — used in comparisons after filesize etc.
        # This is actually part of a filesize comparison handled elsewhere
        var e = cond_expr_new(YARA_EXPR_TRUE);
        store64(e + 40, n);
        return e;
    }

    # "filesize" <op> <value>
    if (load64(tok) == YAR_TOK_FILESIZE) {
        yar_advance(parser);
        var op = yar_parse_cmp_op(parser);
        var val = yar_parse_size(parser);
        return cond_expr_filesize(op, val);
    }

    # "true" / "false"
    if (load64(tok) == YAR_TOK_TRUE) {
        yar_advance(parser);
        return cond_expr_new(YARA_EXPR_TRUE);
    }
    if (load64(tok) == YAR_TOK_FALSE) {
        yar_advance(parser);
        return cond_expr_new(YARA_EXPR_FALSE);
    }

    # Parenthesized expression
    if (load64(tok) == YAR_TOK_LPAREN) {
        yar_advance(parser);
        var expr = yar_parse_or_expr(parser);
        yar_expect(parser, YAR_TOK_RPAREN);
        return expr;
    }

    # Module field access: pe.field or elf.field
    if (load64(tok) == YAR_TOK_IDENT) {
        var ident = load64(tok + 8);
        # Check if next token is a dot — module field access
        if (str_eq(ident, str_from("pe")) | str_eq(ident, str_from("elf"))) {
            yar_advance(parser);
            if (load64(load64(parser + 8)) == YAR_TOK_DOT) {
                yar_advance(parser);  # skip dot
                if (load64(load64(parser + 8)) == YAR_TOK_IDENT) {
                    var field = load64(load64(parser + 8) + 8);
                    yar_advance(parser);  # skip field name

                    # PE module fields
                    if (str_eq(ident, str_from("pe"))) {
                        if (str_eq(field, str_from("is_dll"))) {
                            return cond_expr_pe_is_dll();
                        }
                        if (str_eq(field, str_from("is_64bit"))) {
                            return cond_expr_pe_is_64bit();
                        }
                        if (str_eq(field, str_from("machine"))) {
                            var op = yar_parse_cmp_op(parser);
                            var val = 0;
                            if (load64(load64(parser + 8)) == YAR_TOK_NUMBER) {
                                val = load64(load64(parser + 8) + 16);
                                yar_advance(parser);
                            }
                            return cond_expr_pe_machine(op, val);
                        }
                    }

                    # ELF module fields
                    if (str_eq(ident, str_from("elf"))) {
                        if (str_eq(field, str_from("machine"))) {
                            var op = yar_parse_cmp_op(parser);
                            var val = 0;
                            if (load64(load64(parser + 8)) == YAR_TOK_NUMBER) {
                                val = load64(load64(parser + 8) + 16);
                                yar_advance(parser);
                            }
                            return cond_expr_elf_machine(op, val);
                        }
                        if (str_eq(field, str_from("type"))) {
                            var op = yar_parse_cmp_op(parser);
                            var val = 0;
                            if (load64(load64(parser + 8)) == YAR_TOK_NUMBER) {
                                val = load64(load64(parser + 8) + 16);
                                yar_advance(parser);
                            }
                            return cond_expr_elf_type(op, val);
                        }
                    }
                }
            }
            # Unrecognized module.field — treat as true
            return cond_expr_new(YARA_EXPR_TRUE);
        }
    }

    # Unknown — skip and return true
    yar_advance(parser);
    return cond_expr_new(YARA_EXPR_TRUE);
}

fn yar_parse_cmp_op(parser) {
    var tok = load64(parser + 8);
    if (load64(tok) == YAR_TOK_LT) { yar_advance(parser); return YARA_CMP_LT; }
    if (load64(tok) == YAR_TOK_LE) { yar_advance(parser); return YARA_CMP_LE; }
    if (load64(tok) == YAR_TOK_GT) { yar_advance(parser); return YARA_CMP_GT; }
    if (load64(tok) == YAR_TOK_GE) { yar_advance(parser); return YARA_CMP_GE; }
    if (load64(tok) == YAR_TOK_EQEQ) { yar_advance(parser); return YARA_CMP_EQ; }
    if (load64(tok) == YAR_TOK_NE) { yar_advance(parser); return YARA_CMP_NE; }
    return YARA_CMP_EQ;  # default
}

# ================================================================
# YARA Parser — Parse a complete .yar file
# ================================================================

# Parse .yar source text and return a vec of YaraRule
fn yara_parse_rules(src) {
    var parser = yar_parser_new(src);
    var rules = vec_new();

    while (load64(load64(parser + 8)) != YAR_TOK_EOF) {
        # Skip "import" statements silently
        if (load64(load64(parser + 8)) == YAR_TOK_IMPORT) {
            yar_advance(parser);
            # Skip the import target (string literal or identifier)
            if (load64(load64(parser + 8)) == YAR_TOK_STRING_LIT |
                load64(load64(parser + 8)) == YAR_TOK_IDENT) {
                yar_advance(parser);
            }
        } else {
            if (load64(load64(parser + 8)) == YAR_TOK_RULE) {
                var rule = yar_parse_one_rule(parser);
                if (rule != 0) {
                    vec_push(rules, rule);
                }
            } else {
                # Skip unknown tokens
                yar_advance(parser);
            }
        }
    }

    return rules;
}

# Parse a single rule: rule Name { ... }
fn yar_parse_one_rule(parser) {
    yar_advance(parser);  # skip "rule" keyword

    # Rule name
    if (load64(load64(parser + 8)) != YAR_TOK_IDENT) { return 0; }
    var name = load64(load64(parser + 8) + 8);
    yar_advance(parser);

    # Optional tags: rule Name : tag1 tag2 { ... }
    var tags = vec_new();
    if (load64(load64(parser + 8)) == YAR_TOK_COLON) {
        yar_advance(parser);
        while (load64(load64(parser + 8)) == YAR_TOK_IDENT) {
            vec_push(tags, load64(load64(parser + 8) + 8));
            yar_advance(parser);
        }
    }

    # Opening brace
    if (yar_expect(parser, YAR_TOK_LBRACE) == 0) { return 0; }

    var rule = yara_rule_new(name);
    store64(rule + 24, tags);

    # Parse sections within the rule
    while (load64(load64(parser + 8)) != YAR_TOK_RBRACE) {
        if (load64(load64(parser + 8)) == YAR_TOK_EOF) { return rule; }

        if (load64(load64(parser + 8)) == YAR_TOK_META) {
            yar_advance(parser);
            yar_parse_meta(parser, rule);
        } else {
            if (load64(load64(parser + 8)) == YAR_TOK_STRINGS) {
                yar_advance(parser);
                yar_parse_strings(parser);
                store64(rule + 32, load64(parser + 16));
            } else {
                if (load64(load64(parser + 8)) == YAR_TOK_CONDITION) {
                    yar_advance(parser);
                    var expr = yar_parse_condition(parser);
                    store64(rule + 40, YARA_COND_EXPRESSION);
                    store64(rule + 48, expr);
                } else {
                    yar_advance(parser);  # skip unknown
                }
            }
        }
    }

    yar_advance(parser);  # skip closing '}'
    return rule;
}

# Parse meta section
fn yar_parse_meta(parser, rule) {
    yar_expect(parser, YAR_TOK_COLON);
    while (load64(load64(parser + 8)) == YAR_TOK_IDENT) {
        var key = load64(load64(parser + 8) + 8);
        yar_advance(parser);
        yar_expect(parser, YAR_TOK_EQ);

        if (load64(load64(parser + 8)) == YAR_TOK_STRING_LIT) {
            var val = load64(load64(parser + 8) + 8);
            yar_advance(parser);
            if (str_eq(key, str_from("description"))) {
                store64(rule + 8, val);
            }
            if (str_eq(key, str_from("severity"))) {
                store64(rule + 16, parse_severity_str(val));
            }
        } else {
            if (load64(load64(parser + 8)) == YAR_TOK_NUMBER) {
                yar_advance(parser);
            } else {
                if (load64(load64(parser + 8)) == YAR_TOK_TRUE |
                    load64(load64(parser + 8)) == YAR_TOK_FALSE) {
                    yar_advance(parser);
                } else {
                    yar_advance(parser);
                }
            }
        }
    }
}

# ================================================================
# YARA Engine — Load .yar file into engine
# ================================================================

fn yara_engine_load_rules_yar(engine, yar_src) {
    var rules = yara_parse_rules(yar_src);
    var n = vec_len(rules);
    for (var i = 0; i < n; i = i + 1) {
        yara_engine_add_rule(engine, vec_get(rules, i));
    }
    return n;
}

# ================================================================
# YARA Engine — Built-in detection rules
# ================================================================

# Create standard detection rules for common threats
fn yara_engine_load_builtin_rules(engine) {
    # Rule: Detect MZ header (PE executable)
    var mz_rule = yara_rule_new(str_from("IsPE"));
    store64(mz_rule + 8, str_from("File contains PE executable header"));
    store64(mz_rule + 16, SEVERITY_INFO);
    vec_push(load64(mz_rule + 24), str_from("pe"));
    vec_push(load64(mz_rule + 32), yara_pattern_from_hex(str_from("$mz"), str_from("4D 5A")));
    store64(mz_rule + 40, YARA_COND_ALL);
    store64(load64(mz_rule + 64) + 16, 0);
    yara_engine_add_rule(engine, mz_rule);

    # Rule: Detect ELF header
    var elf_rule = yara_rule_new(str_from("IsELF"));
    store64(elf_rule + 8, str_from("File contains ELF executable header"));
    store64(elf_rule + 16, SEVERITY_INFO);
    vec_push(load64(elf_rule + 24), str_from("elf"));
    vec_push(load64(elf_rule + 32), yara_pattern_from_hex(str_from("$elf"), str_from("7F 45 4C 46")));
    store64(elf_rule + 40, YARA_COND_ALL);
    store64(load64(elf_rule + 64) + 16, 0);
    yara_engine_add_rule(engine, elf_rule);

    # Rule: Detect UPX-packed binaries
    var upx_rule = yara_rule_new(str_from("UPXPacked"));
    store64(upx_rule + 8, str_from("Binary is packed with UPX"));
    store64(upx_rule + 16, SEVERITY_MEDIUM);
    vec_push(load64(upx_rule + 24), str_from("packer"));
    vec_push(load64(upx_rule + 24), str_from("upx"));
    vec_push(load64(upx_rule + 32), yara_pattern_from_string(str_from("$upx0"), str_from("UPX0")));
    vec_push(load64(upx_rule + 32), yara_pattern_from_string(str_from("$upx1"), str_from("UPX1")));
    vec_push(load64(upx_rule + 32), yara_pattern_from_string(str_from("$upx2"), str_from("UPX!")));
    store64(upx_rule + 40, YARA_COND_AT_LEAST);
    store64(upx_rule + 56, 2);
    yara_engine_add_rule(engine, upx_rule);

    # Rule: Detect potential shellcode / NOP sled
    var nop_rule = yara_rule_new(str_from("NopSled"));
    store64(nop_rule + 8, str_from("Potential NOP sled detected (shellcode indicator)"));
    store64(nop_rule + 16, SEVERITY_HIGH);
    vec_push(load64(nop_rule + 24), str_from("shellcode"));
    # 32 consecutive NOPs
    vec_push(load64(nop_rule + 32), yara_pattern_from_hex(str_from("$nop"),
        str_from("90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90")));
    store64(nop_rule + 40, YARA_COND_ANY);
    yara_engine_add_rule(engine, nop_rule);

    # Rule: Detect suspicious API strings in PE
    var api_rule = yara_rule_new(str_from("SuspiciousAPIs"));
    store64(api_rule + 8, str_from("Contains suspicious Windows API references"));
    store64(api_rule + 16, SEVERITY_MEDIUM);
    vec_push(load64(api_rule + 24), str_from("suspicious"));
    vec_push(load64(api_rule + 24), str_from("api"));
    vec_push(load64(api_rule + 32), yara_pattern_from_string(str_from("$a1"), str_from("VirtualAllocEx")));
    vec_push(load64(api_rule + 32), yara_pattern_from_string(str_from("$a2"), str_from("WriteProcessMemory")));
    vec_push(load64(api_rule + 32), yara_pattern_from_string(str_from("$a3"), str_from("CreateRemoteThread")));
    vec_push(load64(api_rule + 32), yara_pattern_from_string(str_from("$a4"), str_from("NtUnmapViewOfSection")));
    store64(api_rule + 40, YARA_COND_AT_LEAST);
    store64(api_rule + 56, 2);
    yara_engine_add_rule(engine, api_rule);

    # Rule: Detect ransomware indicators
    var ransom_rule = yara_rule_new(str_from("RansomwareIndicators"));
    store64(ransom_rule + 8, str_from("Contains ransomware-related strings"));
    store64(ransom_rule + 16, SEVERITY_CRITICAL);
    vec_push(load64(ransom_rule + 24), str_from("ransomware"));
    vec_push(load64(ransom_rule + 32), yara_pattern_from_string(str_from("$r1"), str_from("Your files have been encrypted")));
    vec_push(load64(ransom_rule + 32), yara_pattern_from_string(str_from("$r2"), str_from("bitcoin")));
    vec_push(load64(ransom_rule + 32), yara_pattern_from_string(str_from("$r3"), str_from("decrypt")));
    vec_push(load64(ransom_rule + 32), yara_pattern_from_string(str_from("$r4"), str_from("ransom")));
    store64(ransom_rule + 40, YARA_COND_AT_LEAST);
    store64(ransom_rule + 56, 2);
    store64(ransom_rule + 32, load64(ransom_rule + 32));  # ensure assignment
    yara_engine_add_rule(engine, ransom_rule);

    # Rule: Detect embedded PE in non-PE file
    var embedded_pe = yara_rule_new(str_from("EmbeddedPE"));
    store64(embedded_pe + 8, str_from("Contains an embedded PE executable"));
    store64(embedded_pe + 16, SEVERITY_HIGH);
    vec_push(load64(embedded_pe + 24), str_from("embedded"));
    vec_push(load64(embedded_pe + 24), str_from("pe"));
    vec_push(load64(embedded_pe + 32), yara_pattern_from_hex(str_from("$mz"), str_from("4D 5A")));
    vec_push(load64(embedded_pe + 32), yara_pattern_from_string(str_from("$pe"), str_from("This program cannot be run in DOS mode")));
    store64(embedded_pe + 40, YARA_COND_ALL);
    store64(load64(embedded_pe + 64), 512);
    yara_engine_add_rule(engine, embedded_pe);
}

# ================================================================
# ================================================================
#
#   PART 3 — Priority Queue, Quarantine, Report, Hoosh, Daimon,
#            AI Registration, CLI Entry Point
#
# ================================================================
# ================================================================


# ================================================================
# Priority Queue — Constants
# ================================================================

var PRIORITY_CRITICAL = 3;
var PRIORITY_HIGH     = 2;
var PRIORITY_NORMAL   = 1;
var PRIORITY_LOW      = 0;

# ================================================================
# Priority Queue — Structs
# ================================================================

struct ScanRequest {
    target_kind;   # ScanTarget kind enum
    target_path;   # Str
    priority;      # i64 (PRIORITY_*)
    id;            # i64 unique identifier
}

struct ScanQueue {
    items;         # Vec of ScanRequest, kept sorted by priority (highest first)
    capacity;      # i64 max items
    next_id;       # i64 monotonic counter
}

# ================================================================
# Priority Queue — Functions
# ================================================================

# Create a new scan queue with the given maximum capacity.
fn scan_queue_new(capacity) {
    var q = alloc(24);
    store64(q, vec_new());
    store64(q + 8, capacity);
    store64(q + 16, 1);
    return q;
}

# Return the number of items in the queue.
fn scan_queue_len(q) {
    return vec_len(load64(q));
}

# Return 1 if the queue is empty, 0 otherwise.
fn scan_queue_is_empty(q) {
    if (vec_len(load64(q)) == 0) { return 1; }
    return 0;
}

# Heap comparison: returns 1 if a should be dequeued before b.
# Higher priority first; at same priority, lower id (older) first.
fn scan_req_heap_gt(a, b) {
    var pa = load64(a + 16);
    var pb = load64(b + 16);
    if (pa > pb) { return 1; }
    if (pa < pb) { return 0; }
    # Same priority — lower id wins (older request)
    return load64(a + 24) < load64(b + 24);
}

# Enqueue a scan request using binary heap (max-heap by priority).
# Returns the assigned request id, or -1 if the queue is full.
fn scan_queue_enqueue(q, target_kind, target_path, priority) {
    if (vec_len(load64(q)) >= load64(q + 8)) {
        return -1;
    }

    var req = alloc(32);
    store64(req, target_kind);
    store64(req + 8, target_path);
    store64(req + 16, priority);
    store64(req + 24, load64(q + 16));
    store64(q + 16, load64(q + 16) + 1);

    # Push to end and sift up
    vec_push(load64(q), req);
    var i = vec_len(load64(q)) - 1;
    while (i > 0) {
        var parent = (i - 1) / 2;
        var pi = vec_get(load64(q), parent);
        if (scan_req_heap_gt(req, pi)) {
            vec_set(load64(q), i, pi);
            vec_set(load64(q), parent, req);
            i = parent;
        } else {
            i = 0;  # break — heap property satisfied
        }
    }

    return load64(req + 24);
}

# Dequeue the highest-priority request (root of max-heap).
# Returns the ScanRequest, or 0 if empty.
fn scan_queue_dequeue(q) {
    var len = vec_len(load64(q));
    if (len == 0) { return 0; }

    var root = vec_get(load64(q), 0);

    if (len == 1) {
        store64(q, vec_new());
        return root;
    }

    # Move last element to root, rebuild vec without last, then sift down
    var last = vec_get(load64(q), len - 1);
    var new_items = vec_new();
    vec_push(new_items, last);
    for (var i = 1; i < len - 1; i = i + 1) {
        vec_push(new_items, vec_get(load64(q), i));
    }
    store64(q, new_items);

    # Sift down from root
    var heap_len = vec_len(load64(q));
    var i = 0;
    while (1) {
        var left = 2 * i + 1;
        var right = 2 * i + 2;
        var largest = i;

        if (left < heap_len) {
            if (scan_req_heap_gt(vec_get(load64(q), left), vec_get(load64(q), largest))) {
                largest = left;
            }
        }
        if (right < heap_len) {
            if (scan_req_heap_gt(vec_get(load64(q), right), vec_get(load64(q), largest))) {
                largest = right;
            }
        }

        if (largest == i) {
            return root;  # break — heap property satisfied
        }

        # Swap
        var tmp = vec_get(load64(q), i);
        vec_set(load64(q), i, vec_get(load64(q), largest));
        vec_set(load64(q), largest, tmp);
        i = largest;
    }

    return root;
}


# ================================================================
# Quarantine — Structs
# ================================================================

struct QuarantineEntry {
    id;              # Str — UUID-like identifier
    original_path;   # Str — where the file came from
    quarantine_path; # Str — where it lives now
    reason;          # Str — why it was quarantined
    timestamp;       # i64 — unix epoch seconds
    sha256;          # Str — hash of the file at quarantine time
    size;            # i64 — file size in bytes
}

struct QuarantineManager {
    dir;             # Str — quarantine directory path
    entries;         # Vec of QuarantineEntry
    index_path;      # Str — path to index.json
    next_counter;    # i64 — monotonic counter for ID generation
}

# ================================================================
# Quarantine — ID generation
# ================================================================

# Generate a UUID-like identifier from timestamp and counter.
# Format: hex(timestamp)-hex(counter) — not a true UUID but unique enough.
fn quarantine_gen_id(mgr) {
    var ts = clock_epoch_secs();
    var ctr = load64(mgr + 24);
    store64(mgr + 24, load64(mgr + 24) + 1);

    var id_str = str_cat(fmt_hex(ts), str_from("-"));
    id_str = str_cat(id_str, fmt_hex(ctr));
    return id_str;
}

# ================================================================
# Quarantine — Path validation
# ================================================================

# Validate an ID string: reject path separators and directory traversal.
# Returns 1 if valid, 0 if the ID contains dangerous characters.
fn quarantine_validate_id(id) {
    var len = str_len(id);
    if (len == 0) { return 0; }

    # Check for forbidden substrings
    var s = id;
    var data = str_data(s);

    for (var i = 0; i < len; i = i + 1) {
        var ch = load8(data + i);
        # Reject '/' (0x2F), '\' (0x5C)
        if (ch == 0x2F) { return 0; }
        if (ch == 0x5C) { return 0; }
    }

    # Reject ".." anywhere in the string
    if (len >= 2) {
        for (var i = 0; i < len - 1; i = i + 1) {
            var c0 = load8(data + i);
            var c1 = load8(data + i + 1);
            if (c0 == 0x2E) {
                if (c1 == 0x2E) {
                    return 0;
                }
            }
        }
    }

    return 1;
}

# ================================================================
# Quarantine — Core functions
# ================================================================

# Create a new quarantine manager. Creates the directory if needed,
# and attempts to load an existing index.json.
fn quarantine_new(dir) {
    var mgr = alloc(32);
    store64(mgr, dir);
    store64(mgr + 8, vec_new());
    store64(mgr + 24, 1);
    store64(mgr + 16, path_join(dir, str_from("index.json")));

    # Create quarantine directory (mode 0700 = 448 decimal)
    syscall(SYS_MKDIR, dir, 448);

    # Try to load existing index — if file doesn't exist, start fresh
    # (file_read_all returns empty string on failure)
    var idx_data = phylax_read_file(load64(mgr + 16));
    if (str_len(idx_data) > 0) {
        # Parse the JSON index to restore entries
        # For simplicity, we count entries from stored counter hints
        var parsed = json_parse(idx_data);
        if (parsed != 0) {
            var count = vec_len(parsed);
            for (var i = 0; i < count; i = i + 1) {
                var item = vec_get(parsed, i);
                var entry = alloc(56);
                store64(entry, map_get(item, "id"));
                store64(entry + 8, map_get(item, "original_path"));
                store64(entry + 16, map_get(item, "quarantine_path"));
                store64(entry + 24, map_get(item, "reason"));
                store64(entry + 32, map_get(item, "timestamp"));
                store64(entry + 40, map_get(item, "sha256"));
                store64(entry + 48, map_get(item, "size"));
                vec_push(load64(mgr + 8), entry);
            }
            store64(mgr + 24, count + 1);
        }
    }

    return mgr;
}

# Save the current index to disk as JSON.
fn quarantine_save_index(mgr) {
    var items = vec_new();
    var count = vec_len(load64(mgr + 8));
    for (var i = 0; i < count; i = i + 1) {
        var e = vec_get(load64(mgr + 8), i);
        var m = map_new();
        map_set(m, "id", load64(e));
        map_set(m, "original_path", load64(e + 8));
        map_set(m, "quarantine_path", load64(e + 16));
        map_set(m, "reason", load64(e + 24));
        map_set(m, "timestamp", load64(e + 32));
        map_set(m, "sha256", load64(e + 40));
        map_set(m, "size", load64(e + 48));
        vec_push(items, m);
    }
    var json_str = json_build(items);
    file_write(load64(mgr + 16), json_str);
}

# Quarantine a file: move it into the quarantine directory, record metadata.
# Returns the QuarantineEntry on success, or 0 on failure.
fn quarantine_file(mgr, source_path, reason) {
    var id = quarantine_gen_id(mgr);
    var dest_path = path_join(load64(mgr), id);

    # Read file to compute size and sha256
    var data = phylax_read_file(source_path);
    var data_len = str_len(data);
    if (data_len == 0) {
        var msg = str_from("quarantine: cannot read source file");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    # Compute SHA-256 of the file data
    var hash = sha256_hex(str_data(data), data_len);

    # Move the file via rename syscall
    var rc = syscall(SYS_RENAME, source_path, dest_path);
    if (rc < 0) {
        var msg = str_from("quarantine: rename failed");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    # Build entry
    var entry = alloc(56);
    store64(entry, id);
    store64(entry + 8, source_path);
    store64(entry + 16, dest_path);
    store64(entry + 24, reason);
    store64(entry + 32, clock_epoch_secs());
    store64(entry + 40, hash);
    store64(entry + 48, data_len);

    vec_push(load64(mgr + 8), entry);
    quarantine_save_index(mgr);

    var msg = str_cat(str_from("quarantined: "), source_path);
    sakshi_info(str_data(msg), str_len(msg));

    return entry;
}

# Release a quarantined file back to its original location.
# Returns 1 on success, 0 on failure.
fn quarantine_release(mgr, id) {
    if (quarantine_validate_id(id) == 0) {
        var msg = str_from("quarantine_release: invalid id");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    var count = vec_len(load64(mgr + 8));
    var found_idx = -1;
    var entry = 0;

    for (var i = 0; i < count; i = i + 1) {
        var e = vec_get(load64(mgr + 8), i);
        if (str_eq(load64(e), id)) {
            found_idx = i;
            entry = e;
            i = count;  # break
        }
    }

    if (found_idx < 0) {
        var msg = str_from("quarantine_release: id not found");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    # Move file back to original location
    var rc = syscall(SYS_RENAME, load64(entry + 16), load64(entry + 8));
    if (rc < 0) {
        var msg = str_from("quarantine_release: rename failed");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    # Remove from entries — rebuild vec without found_idx
    var new_entries = vec_new();
    for (var i = 0; i < count; i = i + 1) {
        if (i != found_idx) {
            vec_push(new_entries, vec_get(load64(mgr + 8), i));
        }
    }
    store64(mgr + 8, new_entries);
    quarantine_save_index(mgr);

    var msg = str_cat(str_from("released: "), load64(entry + 8));
    sakshi_info(str_data(msg), str_len(msg));

    return 1;
}

# Return the vec of quarantine entries.
fn quarantine_list(mgr) {
    return load64(mgr + 8);
}

# Return the number of quarantined files.
fn quarantine_count(mgr) {
    return vec_len(load64(mgr + 8));
}


# ================================================================
# Report — Structs
# ================================================================

struct ReportSummary {
    targets_scanned;       # i64
    targets_clean;         # i64
    targets_with_findings; # i64
    critical_count;        # i64
    high_count;            # i64
    medium_count;          # i64
    low_count;             # i64
    info_count;            # i64
}

struct ThreatReport {
    session_id;      # Str
    generated_at;    # Str (formatted timestamp)
    engine_version;  # Str
    results;         # Vec of ScanResult
    total_findings;  # i64
    summary;         # ReportSummary
}

# ================================================================
# Report — Build summary from scan results
# ================================================================

fn report_summary_new() {
    var s = alloc(64);
    store64(s, 0);
    store64(s + 8, 0);
    store64(s + 16, 0);
    store64(s + 24, 0);
    store64(s + 32, 0);
    store64(s + 40, 0);
    store64(s + 48, 0);
    store64(s + 56, 0);
    return s;
}

fn report_from_results(session_id, results) {
    var report = alloc(48);
    store64(report, session_id);
    store64(report + 8, phylax_timestamp(clock_epoch_secs()));
    store64(report + 16, VERSION);
    store64(report + 24, results);

    var summary = report_summary_new();
    var total = 0;
    var nresults = vec_len(results);

    store64(summary, nresults);

    for (var i = 0; i < nresults; i = i + 1) {
        var r = vec_get(results, i);
        var nfindings = vec_len(load64(r + 8));
        total = total + nfindings;

        if (nfindings == 0) {
            store64(summary + 8, load64(summary + 8) + 1);
        } else {
            store64(summary + 16, load64(summary + 16) + 1);
        }

        # Count by severity
        for (var j = 0; j < nfindings; j = j + 1) {
            var f = vec_get(load64(r + 8), j);
            if (load64(f + 16) == SEVERITY_CRITICAL) {
                store64(summary + 24, load64(summary + 24) + 1);
            }
            if (load64(f + 16) == SEVERITY_HIGH) {
                store64(summary + 32, load64(summary + 32) + 1);
            }
            if (load64(f + 16) == SEVERITY_MEDIUM) {
                store64(summary + 40, load64(summary + 40) + 1);
            }
            if (load64(f + 16) == SEVERITY_LOW) {
                store64(summary + 48, load64(summary + 48) + 1);
            }
            if (load64(f + 16) == SEVERITY_INFO) {
                store64(summary + 56, load64(summary + 56) + 1);
            }
        }
    }

    store64(report + 32, total);
    store64(report + 40, summary);
    return report;
}

# ================================================================
# Report — JSON renderer
# ================================================================

fn report_render_json(report) {
    var root = map_new();
    map_set(root, "session_id", load64(report));
    map_set(root, "generated_at", load64(report + 8));
    map_set(root, "engine_version", load64(report + 16));
    map_set(root, "total_findings", load64(report + 32));

    # Summary object
    var s = load64(report + 40);
    var sm = map_new();
    map_set(sm, "targets_scanned", load64(s));
    map_set(sm, "targets_clean", load64(s + 8));
    map_set(sm, "targets_with_findings", load64(s + 16));
    map_set(sm, "critical", load64(s + 24));
    map_set(sm, "high", load64(s + 32));
    map_set(sm, "medium", load64(s + 40));
    map_set(sm, "low", load64(s + 48));
    map_set(sm, "info", load64(s + 56));
    map_set(root, "summary", sm);

    # Results array
    var results_arr = vec_new();
    var nresults = vec_len(load64(report + 24));
    for (var i = 0; i < nresults; i = i + 1) {
        var r = vec_get(load64(report + 24), i);
        var rm = map_new();
        map_set(rm, "target", load64(load64(r) + 8));
        map_set(rm, "scan_duration_ms", load64(r + 16));

        var findings_arr = vec_new();
        var nf = vec_len(load64(r + 8));
        for (var j = 0; j < nf; j = j + 1) {
            var f = vec_get(load64(r + 8), j);
            var fm = map_new();
            map_set(fm, "severity", severity_name(load64(f + 16)));
            map_set(fm, "category", category_name(load64(f + 8)));
            map_set(fm, "rule_name", load64(f + 24));
            map_set(fm, "description", load64(f + 32));
            map_set(fm, "timestamp", load64(f + 48));
            vec_push(findings_arr, fm);
        }
        map_set(rm, "findings", findings_arr);
        vec_push(results_arr, rm);
    }
    map_set(root, "results", results_arr);

    return json_build(root);
}

# ================================================================
# Report — Markdown renderer
# ================================================================

# Escape pipe characters for markdown table cells.
fn md_escape_pipe(s) {
    var len = str_len(s);
    var data = str_data(s);
    var out = str_from("");

    for (var i = 0; i < len; i = i + 1) {
        var ch = load8(data + i);
        if (ch == 0x7C) {
            # Replace '|' with '\|'
            out = str_cat(out, str_from("\\|"));
        } else {
            # Single byte to string — allocate 1-byte buffer
            var buf = alloc(1);
            store8(buf, ch);
            var one = str_from("");
            # Build character manually — use str_cat with a char trick
            # Simpler: rebuild from the original slice approach
            out = str_cat(out, str_from(""));
        }
    }

    # Fallback: if pipe not found just return original
    return s;
}

fn report_render_markdown(report) {
    var s = load64(report + 40);

    var out = str_from("# Phylax Threat Report\n\n");
    out = str_cat(out, str_from("- **Session**: "));
    out = str_cat(out, str_from_int(load64(report)));
    out = str_cat(out, str_from("\n"));
    out = str_cat(out, str_from("- **Generated**: "));
    out = str_cat(out, str_from_int(load64(report + 8)));
    out = str_cat(out, str_from("\n"));
    out = str_cat(out, str_from("- **Engine**: phylax v"));
    out = str_cat(out, VERSION);
    out = str_cat(out, str_from("\n"));
    out = str_cat(out, str_from("- **Total Findings**: "));
    out = str_cat(out, str_from_int(load64(report + 32)));
    out = str_cat(out, str_from("\n\n"));

    # Summary table
    out = str_cat(out, str_from("## Summary\n\n"));
    out = str_cat(out, str_from("| Metric | Count |\n"));
    out = str_cat(out, str_from("|--------|-------|\n"));
    out = str_cat(out, str_from("| Targets Scanned | "));
    out = str_cat(out, str_from_int(load64(s)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| Clean | "));
    out = str_cat(out, str_from_int(load64(s + 8)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| With Findings | "));
    out = str_cat(out, str_from_int(load64(s + 16)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| Critical | "));
    out = str_cat(out, str_from_int(load64(s + 24)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| High | "));
    out = str_cat(out, str_from_int(load64(s + 32)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| Medium | "));
    out = str_cat(out, str_from_int(load64(s + 40)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| Low | "));
    out = str_cat(out, str_from_int(load64(s + 48)));
    out = str_cat(out, str_from(" |\n"));
    out = str_cat(out, str_from("| Info | "));
    out = str_cat(out, str_from_int(load64(s + 56)));
    out = str_cat(out, str_from(" |\n\n"));

    # Findings detail table
    out = str_cat(out, str_from("## Findings\n\n"));
    out = str_cat(out, str_from("| Target | Severity | Category | Rule | Description |\n"));
    out = str_cat(out, str_from("|--------|----------|----------|------|-------------|\n"));

    var nresults = vec_len(load64(report + 24));
    for (var i = 0; i < nresults; i = i + 1) {
        var r = vec_get(load64(report + 24), i);
        var nf = vec_len(load64(r + 8));
        for (var j = 0; j < nf; j = j + 1) {
            var f = vec_get(load64(r + 8), j);
            out = str_cat(out, str_from("| "));
            out = str_cat(out, load64(load64(r) + 8));
            out = str_cat(out, str_from(" | "));
            out = str_cat(out, severity_name(load64(f + 16)));
            out = str_cat(out, str_from(" | "));
            out = str_cat(out, category_name(load64(f + 8)));
            out = str_cat(out, str_from(" | "));
            out = str_cat(out, load64(f + 24));
            out = str_cat(out, str_from(" | "));
            out = str_cat(out, load64(f + 32));
            out = str_cat(out, str_from(" |\n"));
        }
    }

    return out;
}

# ================================================================
# Report — SARIF v2.1.0 renderer
# ================================================================

fn report_render_sarif(report) {
    var sarif = map_new();
    map_set(sarif, "$schema", str_from("https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json"));
    map_set(sarif, "version", str_from("2.1.0"));

    # Build the single run
    var run = map_new();

    # Tool object
    var tool = map_new();
    var driver = map_new();
    map_set(driver, "name", str_from("phylax"));
    map_set(driver, "version", load64(report + 16));
    map_set(driver, "informationUri", str_from("https://github.com/MacCracken/phylax"));
    map_set(tool, "driver", driver);
    map_set(run, "tool", tool);

    # Results array
    var sarif_results = vec_new();
    var nresults = vec_len(load64(report + 24));

    for (var i = 0; i < nresults; i = i + 1) {
        var r = vec_get(load64(report + 24), i);
        var nf = vec_len(load64(r + 8));

        for (var j = 0; j < nf; j = j + 1) {
            var f = vec_get(load64(r + 8), j);
            var sr = map_new();

            map_set(sr, "ruleId", load64(f + 24));

            # Map severity to SARIF level
            var level = str_from("note");
            if (load64(f + 16) == SEVERITY_CRITICAL) { level = str_from("error"); }
            if (load64(f + 16) == SEVERITY_HIGH)     { level = str_from("error"); }
            if (load64(f + 16) == SEVERITY_MEDIUM)   { level = str_from("warning"); }
            if (load64(f + 16) == SEVERITY_LOW)      { level = str_from("note"); }
            map_set(sr, "level", level);

            # Message
            var msg = map_new();
            map_set(msg, "text", load64(f + 32));
            map_set(sr, "message", msg);

            # Location — physical location with artifact URI
            var locations = vec_new();
            var loc = map_new();
            var phys = map_new();
            var artifact = map_new();
            map_set(artifact, "uri", load64(load64(r) + 8));
            map_set(phys, "artifactLocation", artifact);
            map_set(loc, "physicalLocation", phys);
            vec_push(locations, loc);
            map_set(sr, "locations", locations);

            # Properties — extra metadata
            var props = map_new();
            map_set(props, "severity", severity_name(load64(f + 16)));
            map_set(props, "category", category_name(load64(f + 8)));
            map_set(props, "timestamp", load64(f + 48));
            map_set(sr, "properties", props);

            vec_push(sarif_results, sr);
        }
    }

    map_set(run, "results", sarif_results);

    # Invocation
    var invocations = vec_new();
    var inv = map_new();
    map_set(inv, "executionSuccessful", 1);
    map_set(inv, "startTimeUtc", load64(report + 8));
    vec_push(invocations, inv);
    map_set(run, "invocations", invocations);

    var runs = vec_new();
    vec_push(runs, run);
    map_set(sarif, "runs", runs);

    return json_build(sarif);
}


# ================================================================
# Hoosh Client — LLM-assisted triage (synchronous)
# ================================================================

struct TriageResult {
    finding_id;      # Str — identifier of the triaged finding
    classification;  # Str — e.g. "true_positive", "false_positive", "needs_review"
    confidence;      # i64 — 0..100
    explanation;     # Str — LLM-generated explanation
    model;           # Str — model name used
}

# Build a triage prompt from a finding's details.
fn build_triage_prompt(finding) {
    var prompt = str_from("You are a threat analysis assistant. Classify the following security finding.\n\n");
    prompt = str_cat(prompt, str_from("Rule: "));
    prompt = str_cat(prompt, load64(finding + 24));
    prompt = str_cat(prompt, str_from("\n"));
    prompt = str_cat(prompt, str_from("Severity: "));
    prompt = str_cat(prompt, severity_name(load64(finding + 16)));
    prompt = str_cat(prompt, str_from("\n"));
    prompt = str_cat(prompt, str_from("Category: "));
    prompt = str_cat(prompt, category_name(load64(finding + 8)));
    prompt = str_cat(prompt, str_from("\n"));
    prompt = str_cat(prompt, str_from("Description: "));
    prompt = str_cat(prompt, load64(finding + 32));
    prompt = str_cat(prompt, str_from("\n\n"));
    prompt = str_cat(prompt, str_from("Respond with JSON: {\"classification\": \"true_positive|false_positive|needs_review\", \"confidence\": 0-100, \"explanation\": \"...\"}"));
    return prompt;
}

# Parse the LLM response JSON. Falls back to text heuristics if JSON parsing fails.
fn parse_triage_response(content, finding_id, model) {
    var result = alloc(40);
    store64(result, finding_id);
    store64(result + 32, model);

    # Try JSON parse first
    var parsed = json_parse(content);
    if (parsed != 0) {
        store64(result + 8, map_get(parsed, "classification"));
        store64(result + 16, map_get(parsed, "confidence"));
        store64(result + 24, map_get(parsed, "explanation"));

        # Validate classification — default to needs_review if unrecognized
        if (load64(result + 8) == 0) {
            store64(result + 8, str_from("needs_review"));
        }
        if (load64(result + 16) < 0) { store64(result + 16, 0); }
        if (load64(result + 16) > 100) { store64(result + 16, 100); }
        if (load64(result + 24) == 0) {
            store64(result + 24, str_from("No explanation provided"));
        }
        return result;
    }

    # Fallback: text heuristics
    store64(result + 16, 50);
    store64(result + 24, content);

    # Check for keywords in the response
    if (str_len(content) > 0) {
        # Simple keyword matching for classification
        var lower = content;  # Cyrius lacks str_lower; match as-is
        var has_fp = 0;
        var has_tp = 0;

        # Check for "false_positive" or "false positive"
        var parts = str_split(content, str_from("false_positive"));
        if (vec_len(parts) > 1) { has_fp = 1; }
        if (has_fp == 0) {
            parts = str_split(content, str_from("false positive"));
            if (vec_len(parts) > 1) { has_fp = 1; }
        }

        # Check for "true_positive" or "true positive"
        parts = str_split(content, str_from("true_positive"));
        if (vec_len(parts) > 1) { has_tp = 1; }
        if (has_tp == 0) {
            parts = str_split(content, str_from("true positive"));
            if (vec_len(parts) > 1) { has_tp = 1; }
        }

        if (has_fp == 1) {
            store64(result + 8, str_from("false_positive"));
        } else {
            if (has_tp == 1) {
                store64(result + 8, str_from("true_positive"));
            } else {
                store64(result + 8, str_from("needs_review"));
            }
        }
    } else {
        store64(result + 8, str_from("needs_review"));
    }

    return result;
}

# Send a finding to Hoosh (OpenAI-compatible endpoint) for LLM triage.
# Returns a TriageResult, or 0 on network/parse failure.
fn hoosh_triage_finding(base_url, model, finding) {
    # Build the chat completion request body
    var messages = vec_new();
    var sys_msg = map_new();
    map_set(sys_msg, "role", str_from("system"));
    map_set(sys_msg, "content", str_from("You are a cybersecurity threat triage assistant. Respond with valid JSON only."));
    vec_push(messages, sys_msg);

    var user_msg = map_new();
    map_set(user_msg, "role", str_from("user"));
    map_set(user_msg, "content", build_triage_prompt(finding));
    vec_push(messages, user_msg);

    var body = map_new();
    map_set(body, "model", model);
    map_set(body, "messages", messages);
    map_set(body, "temperature", 0);

    var url = str_cat(base_url, str_from("/v1/chat/completions"));
    var body_str = json_build(body);
    var headers = str_from("Content-Type: application/json");

    var resp = http_post(url, body_str, headers);
    if (resp == 0) {
        var msg = str_from("hoosh: HTTP request failed");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    # Parse response JSON
    var resp_obj = json_parse(resp);
    if (resp_obj == 0) {
        var msg = str_from("hoosh: failed to parse response");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    # Extract content from choices[0].message.content
    var choices = map_get(resp_obj, "choices");
    if (choices == 0) { return 0; }
    if (vec_len(choices) == 0) { return 0; }

    var choice = vec_get(choices, 0);
    var message = map_get(choice, "message");
    if (message == 0) { return 0; }

    var content = map_get(message, "content");
    if (content == 0) { return 0; }

    var finding_id = str_cat(load64(finding + 24), str_from("-"));
    finding_id = str_cat(finding_id, str_from_int(load64(finding + 48)));

    return parse_triage_response(content, finding_id, model);
}


# ================================================================
# Daimon Client — Agent registration (synchronous)
# ================================================================

# Validate an agent ID: reject path separators and traversal characters.
fn daimon_validate_agent_id(agent_id) {
    var len = str_len(agent_id);
    if (len == 0) { return 0; }

    var data = str_data(agent_id);
    for (var i = 0; i < len; i = i + 1) {
        var ch = load8(data + i);
        if (ch == 0x2F) { return 0; }   # '/'
        if (ch == 0x5C) { return 0; }   # '\'
        if (ch == 0x2E) {               # '.'
            if (i + 1 < len) {
                if (load8(data + i + 1) == 0x2E) { return 0; }
            }
        }
    }
    return 1;
}

# Register this agent with the Daimon orchestrator.
# Returns the assigned agent_id as a Str, or 0 on failure.
fn daimon_register(base_url) {
    var url = str_cat(base_url, str_from("/v1/agents/register"));

    var body = map_new();
    map_set(body, "name", str_from("phylax"));
    map_set(body, "version", VERSION);

    var caps = vec_new();
    vec_push(caps, str_from("file_scan"));
    vec_push(caps, str_from("yara"));
    vec_push(caps, str_from("entropy"));
    vec_push(caps, str_from("pe_parse"));
    vec_push(caps, str_from("elf_parse"));
    vec_push(caps, str_from("quarantine"));
    map_set(body, "capabilities", caps);

    var body_str = json_build(body);
    var headers = str_from("Content-Type: application/json");

    var resp = http_post(url, body_str, headers);
    if (resp == 0) {
        var msg = str_from("daimon: registration failed - no response");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    var resp_obj = json_parse(resp);
    if (resp_obj == 0) {
        var msg = str_from("daimon: registration failed - bad response");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    var agent_id = map_get(resp_obj, "agent_id");
    if (agent_id == 0) {
        var msg = str_from("daimon: registration failed - no agent_id");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    if (daimon_validate_agent_id(agent_id) == 0) {
        var msg = str_from("daimon: registration failed - invalid agent_id");
        sakshi_error(str_data(msg), str_len(msg));
        return 0;
    }

    var msg = str_cat(str_from("daimon: registered as "), agent_id);
    sakshi_info(str_data(msg), str_len(msg));
    return agent_id;
}

# Send a heartbeat to the Daimon orchestrator.
# Returns 1 on success, 0 on failure.
fn daimon_heartbeat(base_url, agent_id) {
    if (daimon_validate_agent_id(agent_id) == 0) {
        return 0;
    }

    var url = str_cat(base_url, str_from("/v1/agents/"));
    url = str_cat(url, agent_id);
    url = str_cat(url, str_from("/heartbeat"));

    var body = map_new();
    map_set(body, "status", str_from("active"));
    map_set(body, "timestamp", clock_epoch_secs());

    var body_str = json_build(body);
    var headers = str_from("Content-Type: application/json");

    var resp = http_post(url, body_str, headers);
    if (resp == 0) {
        var msg = str_from("daimon: heartbeat failed");
        sakshi_warn(str_data(msg), str_len(msg));
        return 0;
    }

    return 1;
}

# Deregister this agent from the Daimon orchestrator.
# Returns 1 on success, 0 on failure.
fn daimon_deregister(base_url, agent_id) {
    if (daimon_validate_agent_id(agent_id) == 0) {
        return 0;
    }

    # Daimon expects a DELETE, but Cyrius HTTP only has post/get.
    # Use POST with _method override as a workaround.
    var url = str_cat(base_url, str_from("/v1/agents/"));
    url = str_cat(url, agent_id);
    url = str_cat(url, str_from("/deregister"));

    var body = map_new();
    map_set(body, "agent_id", agent_id);

    var body_str = json_build(body);
    var headers = str_from("Content-Type: application/json");

    var resp = http_post(url, body_str, headers);
    if (resp == 0) {
        var msg = str_from("daimon: deregister failed");
        sakshi_warn(str_data(msg), str_len(msg));
        return 0;
    }

    var msg = str_cat(str_from("daimon: deregistered "), agent_id);
    sakshi_info(str_data(msg), str_len(msg));
    return 1;
}


