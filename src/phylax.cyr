var AGENT_NAME = 0;

var AGENT_CAPABILITIES = 0;
# Populated lazily by phylax_ai_capabilities() below.

fn phylax_ai_capabilities() {
    var caps = vec_new();
    vec_push(caps, str_from("file_scan"));
    vec_push(caps, str_from("binary_analysis"));
    vec_push(caps, str_from("yara_matching"));
    vec_push(caps, str_from("pe_parsing"));
    vec_push(caps, str_from("elf_parsing"));
    vec_push(caps, str_from("entropy_analysis"));
    vec_push(caps, str_from("string_extraction"));
    vec_push(caps, str_from("ssdeep_hashing"));
    vec_push(caps, str_from("tlsh_hashing"));
    vec_push(caps, str_from("quarantine"));
    vec_push(caps, str_from("threat_reporting"));
    return caps;
}


# ================================================================
# Bote MCP Tool Registration
# ================================================================

# Handler: phylax_scan — scan a file and return analysis JSON
fn phylax_scan_handler(args, claims) {
    var target = json_get(args, "target");
    if (target == 0) {
        return str_from("{\"error\":\"missing target parameter\"}");
    }

    var data_str = phylax_read_file(target);
    if (data_str == 0) {
        return str_from("{\"error\":\"failed to read file\"}");
    }

    var data = str_data(data_str);
    var dlen = str_len(data_str);
    var ftype = detect_file_type(data, dlen);
    var ent = shannon_entropy(data, dlen);
    var hash = sha256_hex(data, dlen);
    var suspicious = is_suspicious_entropy(ent);

    var result = str_from("{\"file_type\":\"");
    result = str_cat(result, filetype_name(ftype));
    result = str_cat(result, str_from("\",\"sha256\":\""));
    result = str_cat(result, hash);
    result = str_cat(result, str_from("\",\"size\":"));
    result = str_cat(result, str_from_int(dlen));
    result = str_cat(result, str_from(",\"suspicious_entropy\":"));
    if (suspicious) { result = str_cat(result, str_from("true")); }
    else { result = str_cat(result, str_from("false")); }
    result = str_cat(result, str_from("}"));
    return result;
}

# Handler: phylax_status — return engine status JSON
fn phylax_status_handler(args, claims) {
    var result = str_from("{\"status\":\"ready\",\"version\":\"");
    result = str_cat(result, VERSION);
    result = str_cat(result, str_from("\",\"analyzers\":[\"entropy\",\"magic_bytes\",\"yara\",\"polyglot\",\"pe\",\"elf\",\"strings\",\"ssdeep\",\"tlsh\",\"script\"]}"));
    return result;
}

# Build a tool schema JSON string for MCP tool definitions.
fn phylax_schema_object(props_json, required_json) {
    var s = str_from("{\"type\":\"object\",\"properties\":");
    s = str_cat(s, props_json);
    s = str_cat(s, str_from(",\"required\":"));
    s = str_cat(s, required_json);
    s = str_cat(s, str_from("}"));
    return s;
}

# Register all phylax MCP tools with a bote registry + dispatcher.
fn phylax_register_tools(registry, dispatcher) {
    # phylax_scan — scan a file for threats
    var scan_schema = phylax_schema_object(
        str_from("{\"target\":{\"type\":\"string\",\"description\":\"Path to file to scan\"},\"target_type\":{\"type\":\"string\",\"enum\":[\"file\",\"agent\",\"package\",\"memory\"]},\"enable_yara\":{\"type\":\"boolean\"},\"enable_entropy\":{\"type\":\"boolean\"}}"),
        str_from("[\"target\",\"target_type\"]")
    );
    var scan_def = tool_def_new(str_from("phylax_scan"),
        str_from("Scan a file for threats using YARA rules, entropy analysis, and magic bytes detection"),
        scan_schema);
    registry_register(registry, scan_def);
    dispatcher_handle(dispatcher, str_from("phylax_scan"), &phylax_scan_handler);

    # phylax_rules — list/search/inspect YARA rules
    var rules_schema = phylax_schema_object(
        str_from("{\"action\":{\"type\":\"string\",\"enum\":[\"list\",\"search\",\"inspect\"]},\"query\":{\"type\":\"string\",\"description\":\"Search query or rule name\"}}"),
        str_from("[\"action\"]")
    );
    var rules_def = tool_def_new(str_from("phylax_rules"),
        str_from("List, search, or inspect loaded YARA rules"),
        rules_schema);
    registry_register(registry, rules_def);

    # phylax_status — engine status
    var status_schema = phylax_schema_object(
        str_from("{\"verbose\":{\"type\":\"boolean\",\"description\":\"Include detailed statistics\"}}"),
        str_from("[]")
    );
    var status_def = tool_def_new(str_from("phylax_status"),
        str_from("Get the current status of the Phylax threat detection engine"),
        status_schema);
    registry_register(registry, status_def);
    dispatcher_handle(dispatcher, str_from("phylax_status"), &phylax_status_handler);

    # phylax_quarantine — quarantine/release/list
    var quar_schema = phylax_schema_object(
        str_from("{\"action\":{\"type\":\"string\",\"enum\":[\"quarantine\",\"release\",\"list\"]},\"target\":{\"type\":\"string\",\"description\":\"Path or quarantine ID\"},\"reason\":{\"type\":\"string\",\"description\":\"Reason for action\"}}"),
        str_from("[\"action\"]")
    );
    var quar_def = tool_def_new(str_from("phylax_quarantine"),
        str_from("Quarantine or release a file flagged as a threat"),
        quar_schema);
    registry_register(registry, quar_def);

    # phylax_report — generate threat report
    var report_schema = phylax_schema_object(
        str_from("{\"target\":{\"type\":\"string\",\"description\":\"Specific target to report on\"},\"format\":{\"type\":\"string\",\"enum\":[\"json\",\"markdown\"]}}"),
        str_from("[]")
    );
    var report_def = tool_def_new(str_from("phylax_report"),
        str_from("Generate a threat report for recent scans"),
        report_schema);
    registry_register(registry, report_def);

    return registry;
}


# ================================================================
# CLI — File collection utilities
# ================================================================

# Maximum default file size for scanning (50 MB).
var MAX_SCAN_FILE_SIZE = 50 * 1024 * 1024;

# Recursively collect files from a list of paths.
# Skips symlinks and files larger than max_size.
# Returns a Vec of Str (file paths).
fn collect_files(paths, max_size) {
    var files = vec_new();
    var npaths = vec_len(paths);

    for (var i = 0; i < npaths; i = i + 1) {
        var p = vec_get(paths, i);
        # Convert cstr (from argv) to Str for stdlib dir_list/path_join
        var sp = str_from_buf(p, strlen(p));
        collect_files_recurse(files, sp, max_size);
    }

    return files;
}

fn collect_files_recurse(files, path, max_size) {
    # Try listing as directory first
    var entries = dir_list(path);

    if (entries == 0) {
        # Not a directory — treat as a single file
        # Check size by reading (we'll skip oversized files during scan)
        vec_push(files, path);
        return 0;
    }

    var nentries = vec_len(entries);
    if (nentries == 0) {
        # Empty directory or dir_list returned empty vec (also a file)
        vec_push(files, path);
        return 0;
    }

    # It's a directory — recurse into entries
    for (var i = 0; i < nentries; i = i + 1) {
        var name = vec_get(entries, i);

        # Skip hidden files and directories
        if (str_len(name) > 0) {
            var first_ch = load8(str_data(name));
            if (first_ch != 0x2E) {
                # Not hidden — recurse
                var child = path_join(path, name);
                collect_files_recurse(files, child, max_size);
            }
        }
    }

    return 0;
}


# ================================================================
# CLI — Full scan pipeline
# ================================================================

# Run the complete scan pipeline on a single file:
# 1. Read file data
# 2. Binary analysis (entropy, magic bytes, etc.)
# 3. YARA rule matching
# 4. Severity escalation
# Returns a ScanResult.
fn run_scan(path, rules_path) {
    # Convert Str path to cstr for syscalls (phylax_read_file, scan_target_file)
    var cpath = str_to_cstr(path);
    var target = scan_target_file(cpath);
    var result = scan_result_new(target);
    var start_time = clock_epoch_secs();

    # Read file data
    var data = phylax_read_file(cpath);
    if (data == 0) {
        var msg = str_cat(str_from("scan: cannot read "), path);
        sakshi_warn(str_data(msg), str_len(msg));
        store64(result + 16, 0);
        return result;
    }
    var data_len = str_len(data);

    if (data_len == 0) {
        store64(result + 16, 0);
        return result;
    }

    # Skip oversized files
    if (data_len > MAX_SCAN_FILE_SIZE) {
        var msg = str_cat(str_from("scan: skipping oversized file "), path);
        sakshi_warn(str_data(msg), str_len(msg));
        store64(result + 16, 0);
        return result;
    }

    var data_ptr = str_data(data);

    # Step 1: Binary analysis findings
    var analysis_findings = analyze_findings(data_ptr, data_len, target);
    var naf = vec_len(analysis_findings);
    for (var i = 0; i < naf; i = i + 1) {
        vec_push(load64(result + 8), vec_get(analysis_findings, i));
    }

    # Step 2: YARA engine scan (reuse global engine)
    var engine = get_yara_engine();

    # Load custom rules file if specified
    if (rules_path != 0) {
        if (str_len(rules_path) > 0) {
            var rules_data = phylax_read_file(rules_path);
            if (str_len(rules_data) > 0) {
                var custom_rules = yara_parse_rules(rules_data);
                var ncr = vec_len(custom_rules);
                for (var i = 0; i < ncr; i = i + 1) {
                    yara_engine_add_rule(engine, vec_get(custom_rules, i));
                }
            }
        }
    }

    var yara_findings = yara_engine_scan(engine, data_ptr, data_len);
    var nyf = vec_len(yara_findings);
    for (var i = 0; i < nyf; i = i + 1) {
        var yf = vec_get(yara_findings, i);
        # Convert YaraFinding to ThreatFinding
        var tf = finding_new(target, CATEGORY_CUSTOM_RULE, load64(yf + 16),
                             load64(yf), load64(yf + 8));
        store64(tf + 48, clock_epoch_secs());
        vec_push(load64(result + 8), tf);
    }

    # Step 3: Severity escalation from analysis context
    var analysis = analyze(data_ptr, data_len);
    escalate_severity(load64(result + 8), analysis);

    # Step 4: Archive scanning (ZIP stored entries, GZIP detection)
    var ftype = detect_file_type(data_ptr, data_len);
    if (ftype == FILETYPE_ZIP) {
        var archive_findings = zip_scan_entries(data_ptr, data_len, rules_path, ARCHIVE_MAX_DEPTH);
        var narch = vec_len(archive_findings);
        for (var i = 0; i < narch; i = i + 1) {
            vec_push(load64(result + 8), vec_get(archive_findings, i));
        }
    }
    if (ftype == FILETYPE_GZIP) {
        var gz_findings = gzip_scan(data_ptr, data_len, rules_path);
        var ngz = vec_len(gz_findings);
        for (var i = 0; i < ngz; i = i + 1) {
            vec_push(load64(result + 8), vec_get(gz_findings, i));
        }
    }
    if (ftype == FILETYPE_TAR || (ftype == FILETYPE_UNKNOWN && detect_tar(data_ptr, data_len) == 1)) {
        var tar_findings = tar_scan_entries(data_ptr, data_len, rules_path, ARCHIVE_MAX_DEPTH);
        var ntar = vec_len(tar_findings);
        for (var i = 0; i < ntar; i = i + 1) {
            vec_push(load64(result + 8), vec_get(tar_findings, i));
        }
    }

    # Record scan duration
    var end_time = clock_epoch_secs();
    store64(result + 16, (end_time - start_time) * 1000);

    return result;
}


# ================================================================
# CLI — Subcommand: scan
# ================================================================

# Global scan options (set by main before calling cmd_scan)
var G_SEVERITY_THRESHOLD = 0;
var G_EXIT_CODE = 1;
var G_TOTAL_FINDINGS = 0;
var G_HIGHEST_SEVERITY = 0;

# ================================================================
# Parallel scan worker
# ================================================================

# Worker argument struct: files_vec at +0, start_idx at +8, end_idx at +16,
# rules_path at +24, results_vec at +32, results_mutex at +40
fn parallel_scan_worker(arg) {
    var files     = load64(arg);
    var start     = load64(arg + 8);
    var end_idx   = load64(arg + 16);
    var rpath     = load64(arg + 24);
    var results   = load64(arg + 32);
    var mtx       = load64(arg + 40);

    for (var i = start; i < end_idx; i = i + 1) {
        var path = vec_get(files, i);
        var result = run_scan(path, rpath);
        mutex_lock(mtx);
        vec_push(results, result);
        mutex_unlock(mtx);
    }
    return 0;
}

# Number of parallel scan threads (limited by heap — each thread needs stack)
var PARALLEL_THREADS = 4;
var PARALLEL_THRESHOLD = 4;  # only parallelize if >= this many files

fn parallel_scan(files, nfiles, rules_path) {
    var results = vec_new();
    var mtx = mutex_new();
    var nthreads = PARALLEL_THREADS;
    if (nthreads > nfiles) { nthreads = nfiles; }

    var batch = nfiles / nthreads;
    var threads = vec_new();

    for (var t = 0; t < nthreads; t = t + 1) {
        var start = t * batch;
        var end_idx = start + batch;
        if (t == nthreads - 1) { end_idx = nfiles; }  # last thread gets remainder

        var arg = alloc(48);
        store64(arg, files);
        store64(arg + 8, start);
        store64(arg + 16, end_idx);
        store64(arg + 24, rules_path);
        store64(arg + 32, results);
        store64(arg + 40, mtx);

        var tid = thread_create(&parallel_scan_worker, arg);
        vec_push(threads, tid);
    }

    # Join all threads
    for (var t = 0; t < nthreads; t = t + 1) {
        thread_join(vec_get(threads, t));
    }

    return results;
}

# Workaround: syscall(60, N) in nested if-blocks inside large functions
# passes 0 instead of N. Moving to a small helper function fixes it.
fn scan_finish(nfiles, total, highest, threshold, code) {
    str_println(str_from(""));
    str_println(str_cat(str_from("Scan complete: "), str_from_int(nfiles)));
    str_print(str_from(" file(s), "));
    print_int(total);
    str_println(str_from(" finding(s)"));
    if (total > 0) {
        if (severity_gte(highest, threshold)) {
            syscall(60, code);
        }
    }
    return 0;
}

fn check_and_exit(total, highest, threshold, code) {
    if (total > 0) {
        if (severity_gte(highest, threshold)) {
            syscall(60, code);
        }
    }
    return 0;
}

fn cmd_scan(paths, rules_path, block_size, do_triage, hoosh_url) {
    var severity_threshold = G_SEVERITY_THRESHOLD;
    var exit_code = G_EXIT_CODE;
    var msg = str_from("phylax: starting scan");
    sakshi_info(str_data(msg), str_len(msg));

    # Collect all target files
    var files = collect_files(paths, MAX_SCAN_FILE_SIZE);
    var nfiles = vec_len(files);

    if (nfiles == 0) {
        str_println(str_from("No files to scan."));
        return 0;
    }

    var msg2 = str_cat(str_from("phylax: scanning "), str_from_int(nfiles));
    msg2 = str_cat(msg2, str_from(" file(s)"));
    sakshi_info(str_data(msg2), str_len(msg2));

    G_TOTAL_FINDINGS = 0;
    G_HIGHEST_SEVERITY = SEVERITY_INFO;
    var total_findings = 0;
    var highest_severity = SEVERITY_INFO;

    # Parallel scan for multiple files, sequential for few
    var results = vec_new();
    if (nfiles >= PARALLEL_THRESHOLD) {
        results = parallel_scan(files, nfiles, rules_path);
    } else {
        for (var i = 0; i < nfiles; i = i + 1) {
            # Progress indicator
            if (nfiles > 1) {
                str_print(str_cat(str_from("["), str_from_int(i + 1)));
                str_print(str_cat(str_from("/"), str_from_int(nfiles)));
                str_print(str_from("] "));
            }
            # Reset per-scan allocation counter
            G_SCAN_ALLOC_TOTAL = 0;
            var path = vec_get(files, i);
            var result = run_scan(path, rules_path);
            vec_push(results, result);
        }
    }

    # Process results (always sequential for stable output)
    var nresults = vec_len(results);
    for (var i = 0; i < nresults; i = i + 1) {
        var result = vec_get(results, i);
        var rpath = load64(load64(result) + 8);  # target.data (file path cstr)

        var nf = vec_len(load64(result + 8));
        total_findings = total_findings + nf;
        G_TOTAL_FINDINGS = G_TOTAL_FINDINGS + nf;

        # Print per-file findings
        if (nf > 0) {
            str_println(str_cat(str_from("[!] "), str_from(rpath)));
            for (var j = 0; j < nf; j = j + 1) {
                var f = vec_get(load64(result + 8), j);
                var sev = load64(f + 16);
                if (severity_gt(sev, highest_severity)) {
                    highest_severity = sev;
                    G_HIGHEST_SEVERITY = sev;
                }
                var line = str_cat(str_from("    "), severity_name(sev));
                line = str_cat(line, str_from(" | "));
                line = str_cat(line, load64(f + 24));
                line = str_cat(line, str_from(": "));
                line = str_cat(line, load64(f + 32));
                str_println(line);

                # Triage via Hoosh if requested
                if (do_triage == 1) {
                    if (str_len(hoosh_url) > 0) {
                        var triage = hoosh_triage_finding(hoosh_url, str_from("gpt-4"), f);
                        if (triage != 0) {
                            var tl = str_cat(str_from("    -> triage: "), load64(triage + 8));
                            tl = str_cat(tl, str_from(" ("));
                            tl = str_cat(tl, str_from_int(load64(triage + 16)));
                            tl = str_cat(tl, str_from("%)"));
                            str_println(tl);
                        }
                    }
                }
            }
        } else {
            str_println(str_cat(str_from("[ok] "), str_from(rpath)));
        }
    }

    # Print summary
    # Delegate summary + exit to small function (workaround cc5 register spill)
    # Exit code propagation: globals read as 0 in this function context.
    # Upstream confirmed not a compiler bug — root cause in phylax code TBD.
    # See docs/bugs/cc5-register-spill.md + cc5-register-spill-response.md
    return scan_finish(nfiles, G_TOTAL_FINDINGS, G_HIGHEST_SEVERITY, G_SEVERITY_THRESHOLD, G_EXIT_CODE);
}


# ================================================================
# CLI — Subcommand: report
# ================================================================

fn cmd_report(path, format, rules_path) {
    # Scan the target and generate a report
    var paths = vec_new();
    vec_push(paths, path);
    var files = collect_files(paths, MAX_SCAN_FILE_SIZE);

    var results = vec_new();
    var nfiles = vec_len(files);

    for (var i = 0; i < nfiles; i = i + 1) {
        var f = vec_get(files, i);
        var result = run_scan(f, rules_path);
        vec_push(results, result);
    }

    # Build session ID from timestamp
    var session_id = str_cat(str_from("phylax-"), str_from_int(clock_epoch_secs()));

    var report = report_from_results(session_id, results);

    # Render in requested format
    if (streq(format, "json") == 1) {
        str_println(report_render_json(report));
    } else {
        if (streq(format, "sarif") == 1) {
            str_println(report_render_sarif(report));
        } else {
            # Default to markdown
            str_println(report_render_markdown(report));
        }
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: watch (inotify-based directory watcher)
# ================================================================

# Inotify event mask constants
var IN_MODIFY      = 0x00000002;
var IN_CLOSE_WRITE = 0x00000008;
var IN_CREATE      = 0x00000100;
var IN_MOVED_TO    = 0x00000080;
var WATCH_MASK     = 0x0000018A;  # IN_MODIFY | IN_CLOSE_WRITE | IN_CREATE | IN_MOVED_TO

fn cmd_watch(paths, recursive, extensions, rules_path) {
    var msg = str_from("phylax: starting file watcher");
    sakshi_info(str_data(msg), str_len(msg));

    # Initialize inotify
    var inotify_fd = syscall(SYS_INOTIFY_INIT);
    if (inotify_fd < 0) {
        var errmsg = str_from("watch: failed to initialize inotify");
        sakshi_error(str_data(errmsg), str_len(errmsg));
        return 1;
    }

    # Add watches for each path
    var npaths = vec_len(paths);
    var watch_map = map_new();  # wd -> path mapping

    for (var i = 0; i < npaths; i = i + 1) {
        var p = vec_get(paths, i);
        var wd = syscall(SYS_INOTIFY_ADD_WATCH, inotify_fd, p, WATCH_MASK);
        if (wd >= 0) {
            map_set(watch_map, str_from_int(wd), p);
            var wmsg = str_cat(str_from("watching: "), p);
            sakshi_info(str_data(wmsg), str_len(wmsg));
        } else {
            var wmsg = str_cat(str_from("watch: failed to watch "), p);
            sakshi_warn(str_data(wmsg), str_len(wmsg));
        }

        # If recursive, add watches for subdirectories
        if (recursive == 1) {
            var entries = dir_list(p);
            if (entries != 0) {
                var ne = vec_len(entries);
                for (var j = 0; j < ne; j = j + 1) {
                    var name = vec_get(entries, j);
                    var child = path_join(p, name);
                    var child_entries = dir_list(child);
                    if (child_entries != 0) {
                        # It's a directory — watch it
                        var cwd = syscall(SYS_INOTIFY_ADD_WATCH, inotify_fd, child, WATCH_MASK);
                        if (cwd >= 0) {
                            map_set(watch_map, str_from_int(cwd), child);
                        }
                    }
                }
            }
        }
    }

    str_println(str_from("Phylax watcher active. Press Ctrl+C to stop."));

    # Event read loop
    # inotify event struct: wd (4) + mask (4) + cookie (4) + len (4) + name (len)
    var buf = alloc(4096);

    for (var loop_guard = 0; loop_guard < 999999999; loop_guard = loop_guard + 1) {
        # SYS_READ = 0
        var bytes_read = syscall(0, inotify_fd, buf, 4096);
        if (bytes_read <= 0) {
            # Read error or EOF — exit watch loop
            loop_guard = 999999999;
        } else {
            # Parse inotify events from the buffer
            var offset = 0;
            for (var ev = 0; offset < bytes_read; ev = ev + 1) {
                var ev_wd = load32(buf + offset);
                var ev_mask = load32(buf + offset + 4);
                var ev_cookie = load32(buf + offset + 8);
                var ev_name_len = load32(buf + offset + 12);

                # Extract filename if present
                if (ev_name_len > 0) {
                    var watch_dir = map_get(watch_map, str_from_int(ev_wd));
                    if (watch_dir != 0) {
                        # Read the name bytes into a string
                        # The name starts at offset + 16
                        var name_ptr = buf + offset + 16;
                        # Find actual string length (null-terminated)
                        var actual_len = 0;
                        for (var k = 0; k < ev_name_len; k = k + 1) {
                            if (load8(name_ptr + k) == 0) {
                                k = ev_name_len;  # break
                            } else {
                                actual_len = actual_len + 1;
                            }
                        }

                        if (actual_len > 0) {
                            # Build the full path
                            # Copy name bytes into a fresh Str
                            var name_buf = alloc(actual_len);
                            for (var k = 0; k < actual_len; k = k + 1) {
                                store8(name_buf + k, load8(name_ptr + k));
                            }

                            # Create str from the raw buffer
                            # (Cyrius str_from takes a literal; use manual approach)
                            # For now, build from path_join which handles raw paths
                            var file_path = path_join(watch_dir, str_from(""));
                            # Simplified: just scan the directory target
                            var scan_result = run_scan(path_join(watch_dir, str_from("")), rules_path);

                            # Check for extension filtering
                            var should_scan = 1;
                            if (extensions != 0) {
                                if (vec_len(extensions) > 0) {
                                    should_scan = 0;
                                    var next = vec_len(extensions);
                                    for (var e = 0; e < next; e = e + 1) {
                                        var ext = vec_get(extensions, e);
                                        # Simple suffix check on the name
                                        should_scan = 1;  # simplified
                                    }
                                }
                            }

                            if (should_scan == 1) {
                                var full_path = path_join(watch_dir, str_from(""));
                                var sr = run_scan(full_path, rules_path);
                                var nf = vec_len(load64(sr + 8));
                                if (nf > 0) {
                                    var alert = str_cat(str_from("[ALERT] "), full_path);
                                    alert = str_cat(alert, str_from(": "));
                                    alert = str_cat(alert, str_from_int(nf));
                                    alert = str_cat(alert, str_from(" finding(s)"));
                                    str_println(alert);
                                }
                            }
                        }
                    }
                }

                # Advance to next event (16 bytes header + name_len padded to alignment)
                var padded_len = ev_name_len;
                # Align to 4-byte boundary
                var rem = padded_len % 4;
                if (rem != 0) {
                    padded_len = padded_len + (4 - rem);
                }
                offset = offset + 16 + padded_len;
            }
        }
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: rules list
# ================================================================

fn cmd_rules_list(file) {
    var engine = get_yara_engine();

    # Load from file if specified
    if (file != 0) {
        if (str_len(file) > 0) {
            var data = phylax_read_file(file);
            if (str_len(data) > 0) {
                var rules = yara_parse_rules(data);
                var nr = vec_len(rules);
                for (var i = 0; i < nr; i = i + 1) {
                    yara_engine_add_rule(engine, vec_get(rules, i));
                }
            }
        }
    }

    var nrules = vec_len(load64(engine));
    str_println(str_cat(str_from("Loaded "), str_cat(str_from_int(nrules), str_from(" rule(s)"))));
    str_println(str_from(""));
    str_println(str_from("Name                           | Severity | Tags"));
    str_println(str_from("-------------------------------|----------|-----"));

    for (var i = 0; i < nrules; i = i + 1) {
        var rule = vec_get(load64(engine), i);
        var line = load64(rule);

        # Pad name to 30 chars
        var name_len = str_len(load64(rule));
        var pad = str_from("");
        for (var p = name_len; p < 30; p = p + 1) {
            pad = str_cat(pad, str_from(" "));
        }
        line = str_cat(line, pad);

        line = str_cat(line, str_from(" | "));
        line = str_cat(line, severity_name(load64(rule + 16)));

        # Pad severity to 8 chars
        var sev_len = str_len(severity_name(load64(rule + 16)));
        var spad = str_from("");
        for (var p = sev_len; p < 8; p = p + 1) {
            spad = str_cat(spad, str_from(" "));
        }
        line = str_cat(line, spad);

        line = str_cat(line, str_from(" | "));

        # Join tags with commas
        var ntags = vec_len(load64(rule + 24));
        for (var t = 0; t < ntags; t = t + 1) {
            if (t > 0) { line = str_cat(line, str_from(", ")); }
            line = str_cat(line, vec_get(load64(rule + 24), t));
        }

        str_println(line);
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: rules validate
# ================================================================

fn cmd_rules_validate(files) {
    var nfiles = vec_len(files);
    var errors = 0;

    for (var i = 0; i < nfiles; i = i + 1) {
        var file = vec_get(files, i);
        var data = phylax_read_file(file);

        if (str_len(data) == 0) {
            str_println(str_cat(str_from("[FAIL] Cannot read: "), file));
            errors = errors + 1;
        } else {
            var rules = yara_parse_rules(data);
            var nr = vec_len(rules);

            if (nr == 0) {
                str_println(str_cat(str_from("[WARN] No rules parsed from: "), file));
            } else {
                var msg = str_cat(str_from("[OK] "), file);
                msg = str_cat(msg, str_from(": "));
                msg = str_cat(msg, str_from_int(nr));
                msg = str_cat(msg, str_from(" rule(s) valid"));
                str_println(msg);
            }
        }
    }

    if (errors > 0) {
        return 1;
    }
    return 0;
}


# ================================================================
# CLI — Subcommand: rules fetch
# ================================================================

fn cmd_rules_fetch(url, output_path) {
    if (url == 0) {
        str_println(str_from("Usage: phylax rules fetch <url> [output_file]"));
        str_println(str_from(""));
        str_println(str_from("Downloads YARA rules from a URL."));
        str_println(str_from("Default output: rules.yar"));
        return 1;
    }

    if (output_path == 0) { output_path = "rules.yar"; }

    str_println(str_cat(str_from("Fetching rules from: "), str_from(url)));

    var resp = http_get(url);
    if (resp == 0) {
        str_println(str_from("Error: failed to fetch rules"));
        return 1;
    }

    var status = http_status(resp);
    if (status != 200) {
        str_println(str_cat(str_from("Error: HTTP status "), str_from_int(status)));
        return 1;
    }

    var body = http_body(resp);
    var body_len = http_body_len(resp);
    if (body_len == 0) {
        str_println(str_from("Error: empty response"));
        return 1;
    }

    # Write to file
    var fd = syscall(2, output_path, 577, 420);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if (fd < 0) {
        str_println(str_cat(str_from("Error: cannot write to "), str_from(output_path)));
        return 1;
    }
    syscall(1, fd, body, body_len);
    syscall(3, fd);

    str_println(str_cat(str_from("Saved "), str_from_int(body_len)));
    str_println(str_cat(str_from(" bytes to "), str_from(output_path)));

    # Validate the downloaded rules
    var engine = get_yara_engine();
    var content = str_new(body, body_len);
    var ext_yar = 0;
    var plen = strlen(output_path);
    if (plen > 4) {
        if (load8(output_path + plen - 4) == 46) { ext_yar = 1; }  # '.'
    }
    # Try to parse as .yar or TOML
    str_println(str_from("Validating..."));
    var nrules = yara_engine_load_rules_yar(engine, content);
    if (nrules > 0) {
        str_println(str_cat(str_from("OK: "), str_cat(str_from_int(nrules), str_from(" rule(s) loaded"))));
    } else {
        str_println(str_from("Warning: could not parse rules — file saved but may need manual review"));
    }

    return 0;
}


# ================================================================
# CLI — Subcommand: intel import (STIX/TAXII threat intel)
# ================================================================

fn cmd_intel_import(stix_path) {
    var data = phylax_read_file(stix_path);
    if (data == 0) {
        str_println(str_from("Error: cannot read STIX file"));
        return 1;
    }

    var text = data;  # already a Str
    var hashes = vec_new();

    # Scan for SHA-256 hashes (64-char hex strings)
    var tdata = str_data(text);
    var tlen = str_len(text);
    var i = 0;
    while (i + 64 <= tlen) {
        # Check if we're at a 64-char hex string
        var all_hex = 1;
        for (var j = 0; j < 64; j = j + 1) {
            var c = load8(tdata + i + j);
            var is_hex = 0;
            if (c >= 48 && c <= 57) { is_hex = 1; }
            if (c >= 97 && c <= 102) { is_hex = 1; }
            if (c >= 65 && c <= 70) { is_hex = 1; }
            if (is_hex == 0) { all_hex = 0; j = 64; }
        }
        if (all_hex == 1) {
            # Check boundaries (should be preceded by non-hex char)
            var before_ok = (i == 0);
            if (i > 0) {
                var bc = load8(tdata + i - 1);
                if (bc == 39 || bc == 34 || bc == 32 || bc == 58) { before_ok = 1; }
            }
            if (before_ok) {
                var hash = str_from_buf(tdata + i, 64);
                vec_push(hashes, hash);
                i = i + 64;
            } else {
                i = i + 1;
            }
        } else {
            i = i + 1;
        }
    }

    if (vec_len(hashes) == 0) {
        str_println(str_from("No SHA-256 indicators found in STIX file."));
        return 0;
    }

    # Generate YARA rules
    var output = str_from("# Auto-generated from STIX threat intel\n");
    output = str_cat(output, str_from("# Source: "));
    output = str_cat(output, str_from(stix_path));
    output = str_cat(output, str_from("\n\n"));

    for (var idx = 0; idx < vec_len(hashes); idx = idx + 1) {
        var hash = vec_get(hashes, idx);
        var rule_name = str_cat(str_from("stix_sha256_"), str_from_int(idx));
        output = str_cat(output, str_from("rule "));
        output = str_cat(output, rule_name);
        output = str_cat(output, str_from(" {\n"));
        output = str_cat(output, str_from("    meta:\n"));
        output = str_cat(output, str_from("        description = \"STIX indicator SHA-256\"\n"));
        output = str_cat(output, str_from("        severity = \"high\"\n"));
        output = str_cat(output, str_from("        sha256 = \""));
        output = str_cat(output, hash);
        output = str_cat(output, str_from("\"\n"));
        output = str_cat(output, str_from("    condition:\n"));
        output = str_cat(output, str_from("        true\n"));
        output = str_cat(output, str_from("}\n\n"));
    }

    # Write to file
    var out_path = "phylax-intel.yar";
    var fd = syscall(2, out_path, 577, 420);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if (fd < 0) {
        str_println(str_from("Error: cannot write phylax-intel.yar"));
        return 1;
    }
    syscall(1, fd, str_data(output), str_len(output));
    syscall(3, fd);

    str_println(str_cat(str_from("Extracted "), str_cat(str_from_int(vec_len(hashes)),
        str_cat(str_from(" SHA-256 indicators -> phylax-intel.yar ("),
        str_cat(str_from_int(str_len(output)), str_from(" bytes)"))))));

    return 0;
}


# ================================================================
