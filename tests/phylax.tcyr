fn test_report() {
    test_group("report");

    # Empty report
    var results = vec_new();
    var report = report_from_results(12345, results);
    assert(report != 0, "empty report created");

    # Markdown render
    var md = report_render_markdown(report);
    assert(str_len(md) > 0, "markdown not empty");
}

