# Main test runner
# ================================================================

fn main() {
    phylax_init();

    test_severity();
    test_errors();
    test_entropy();
    test_chi_squared();
    test_file_detection();
    test_sha256();
    test_strings();
    test_pe_parser();
    test_elf_parser();
    test_yara();
    test_queue();
    test_ssdeep();
    test_tlsh();
    test_memmem();
    test_hex();
    test_report();

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
