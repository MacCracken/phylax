# phylax benchmarks
# Ported from 16 Rust benchmark groups

include "src/phylax.cyr"

fn bench_entropy_1k() {
    var data = alloc(1024);
    for (var i = 0; i < 1024; i = i + 1) { store8(data + i, i & 0xff); }
    shannon_entropy(data, 1024);
    return 0;
}

fn bench_entropy_1m() {
    var data = alloc(1048576);
    for (var i = 0; i < 1048576; i = i + 1) { store8(data + i, i & 0xff); }
    shannon_entropy(data, 1048576);
    return 0;
}

fn bench_chi_squared() {
    var data = alloc(4096);
    for (var i = 0; i < 4096; i = i + 1) { store8(data + i, i & 0xff); }
    chi_squared(data, 4096);
    return 0;
}

fn bench_file_detection() {
    var data = alloc(16);
    store8(data, 0x7f); store8(data + 1, 0x45); store8(data + 2, 0x4c); store8(data + 3, 0x46);
    detect_file_type(data, 16);
    return 0;
}

fn bench_sha256() {
    var data = alloc(4096);
    for (var i = 0; i < 4096; i = i + 1) { store8(data + i, i & 0xff); }
    file_sha256(data, 4096);
    return 0;
}

fn bench_memmem() {
    var hay = alloc(4096);
    for (var i = 0; i < 4096; i = i + 1) { store8(hay + i, i & 0xff); }
    var needle = alloc(4);
    store8(needle, 0xfe); store8(needle + 1, 0xff); store8(needle + 2, 0x00); store8(needle + 3, 0x01);
    memmem(hay, 4096, needle, 4);
    return 0;
}

fn bench_hex_encode() {
    var data = alloc(256);
    for (var i = 0; i < 256; i = i + 1) { store8(data + i, i); }
    hex_encode(data, 256);
    return 0;
}

fn bench_extract_ascii() {
    var data = alloc(4096);
    for (var i = 0; i < 4096; i = i + 1) { store8(data + i, 0x41 + (i % 26)); }
    # Insert some nulls to create string boundaries
    for (var i = 0; i < 4096; i = i + 64) { store8(data + i, 0); }
    extract_ascii(data, 4096, 4);
    return 0;
}

fn bench_ssdeep() {
    var data = alloc(4096);
    for (var i = 0; i < 4096; i = i + 1) { store8(data + i, (i * 7 + 3) & 0xff); }
    ssdeep_hash(data, 4096);
    return 0;
}

fn bench_tlsh() {
    var data = alloc(1024);
    for (var i = 0; i < 1024; i = i + 1) { store8(data + i, (i * 13 + 7) & 0xff); }
    tlsh_hash(data, 1024);
    return 0;
}

fn bench_queue_enqueue() {
    var q = scan_queue_new(1000);
    for (var i = 0; i < 1000; i = i + 1) {
        scan_queue_enqueue(q, SCAN_TARGET_MEMORY, 0, i % 4);
    }
    return 0;
}

fn bench_queue_dequeue() {
    var q = scan_queue_new(1000);
    for (var i = 0; i < 1000; i = i + 1) {
        scan_queue_enqueue(q, SCAN_TARGET_MEMORY, 0, i % 4);
    }
    for (var i = 0; i < 1000; i = i + 1) {
        scan_queue_dequeue(q);
    }
    return 0;
}

fn main() {
    phylax_init();

    var benches = vec_new();

    var b1 = bench_new("entropy_1k"); bench_run(b1, &bench_entropy_1k, 10000); vec_push(benches, b1);
    var b2 = bench_new("entropy_1m"); bench_run(b2, &bench_entropy_1m, 100); vec_push(benches, b2);
    var b3 = bench_new("chi_squared"); bench_run(b3, &bench_chi_squared, 10000); vec_push(benches, b3);
    var b4 = bench_new("file_detection"); bench_run(b4, &bench_file_detection, 100000); vec_push(benches, b4);
    var b5 = bench_new("sha256_4k"); bench_run(b5, &bench_sha256, 5000); vec_push(benches, b5);
    var b6 = bench_new("memmem_4k"); bench_run(b6, &bench_memmem, 50000); vec_push(benches, b6);
    var b7 = bench_new("hex_encode_256"); bench_run(b7, &bench_hex_encode, 50000); vec_push(benches, b7);
    var b8 = bench_new("extract_ascii"); bench_run(b8, &bench_extract_ascii, 10000); vec_push(benches, b8);
    var b9 = bench_new("ssdeep_4k"); bench_run(b9, &bench_ssdeep, 1000); vec_push(benches, b9);
    var b10 = bench_new("tlsh_1k"); bench_run(b10, &bench_tlsh, 5000); vec_push(benches, b10);
    var b11 = bench_new("queue_enqueue"); bench_run(b11, &bench_queue_enqueue, 100); vec_push(benches, b11);
    var b12 = bench_new("queue_dequeue"); bench_run(b12, &bench_queue_dequeue, 100); vec_push(benches, b12);

    bench_report_all(benches);
    return 0;
}

var r = main();
syscall(60, r);
